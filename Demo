// QR CODE GENERATION
// ════════════════════════════════════════
function renderQRCode() {
  const container = document.getElementById('qr-code-display');
  if (!container) return;

  const doRender = () => {
    container.innerHTML = '';
    const house = state.houses.find(h => h.id === state.currentHouseId);
    if (document.getElementById('qr-house-name'))
      document.getElementById('qr-house-name').textContent = house?.name || 'Boarding House';
    try {
      new QRCode(container, {
        text: `buhayboarding://register?house=${state.currentHouseId}&name=${encodeURIComponent(house?.name||'')}`,
        width: 200, height: 200,
        colorDark: '#0D2B45', colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.H
      });
    } catch(e) {
      container.innerHTML = `<div style="width:200px;height:200px;background:var(--warm);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);text-align:center;padding:16px">QR Code para sa<br><strong>${house?.name}</strong></div>`;
    }
  };

  // Lazy-load QRCode.js — only downloaded when landlord actually opens QR screen.
  if (window.QRCode) {
    doRender();
  } else {
    const s = document.createElement('script');
    s.src = 'https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js';
    s.crossOrigin = 'anonymous';
    s.onload = doRender;
    s.onerror = () => { container.innerHTML = '<div style="padding:20px;text-align:center;color:var(--muted);font-size:13px">QR load failed. Check connection.</div>'; };
    document.head.appendChild(s);
  }
}

function copyQRLink() {
  const house = state.houses.find(h => h.id === state.currentHouseId);
  const link = `buhayboarding://register?house=${state.currentHouseId}&name=${encodeURIComponent(house?.name||'')}`;
  if(navigator.clipboard) {
    navigator.clipboard.writeText(link).then(()=>showToast(' Na-copy ang registration link!')).catch(()=>showToast('Link: ' + link));
  } else {
    showToast('buhayboarding://register?house=' + state.currentHouseId);
  }
}

