// Helper: set avatar element to photo or emoji
function setAvatarEl(imgId, emojiId, photo, emoji) {
  const img   = document.getElementById(imgId);
  const espan = document.getElementById(emojiId);
  if(!img) return;
  if(photo) {
    img.src = photo;
    img.style.display = 'block';
    if(espan) espan.style.display = 'none';
  } else {
    img.style.display = 'none';
    if(espan) { espan.style.display = ''; espan.textContent = emoji||'🎓'; }
  }
}

