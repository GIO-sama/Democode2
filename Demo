function submitInquiry() {
  const name   = document.getElementById('inq-name');
  const school = document.getElementById('inq-school');
  const course = document.getElementById('inq-course');
  const date   = document.getElementById('inq-date');

  // Clear previous errors
  [name, school, course, date].forEach(el => el.classList.remove('error'));

  // Validate — highlight specific failing fields
  let hasError = false;
  if (!name.value.trim())   { name.classList.add('error');   hasError = true; }
  if (!school.value)        { school.classList.add('error'); hasError = true; }
  if (!course.value.trim()) { course.classList.add('error'); hasError = true; }
  if (!date.value)          { date.classList.add('error');   hasError = true; }

  if (hasError) {
    showToast('<i class="ph ph-warning"></i> Fill in all required fields');
    // Scroll to first error
    const first = document.querySelector('#s-inquiry .error');
    if (first) first.scrollIntoView({ behavior:'smooth', block:'center' });
    return;
  }

  // Clear errors on submit
  [name, school, course, date].forEach(el => el.classList.remove('error'));
  // Remove error on user fix
  [name, school, course, date].forEach(el => {
    el.addEventListener('input', () => el.classList.remove('error'), { once: true });
    el.addEventListener('change', () => el.classList.remove('error'), { once: true });
  });

  const h = state.houses.find(x=>x.id===state.currentHouseId);
  const q = document.getElementById('inq-q').value.trim();
  const inq = {
    id: state.nextId++,
    houseId: state.currentHouseId,
    name: name.value.trim(), school: school.value,
    course: course.value.trim(), date: date.value,
    q: q||'(No specific question)',
    status:'pending', time:'Just now',
    photo: (profiles.seeker.showPhoto && profiles.seeker.photo) ? profiles.seeker.photo : null,
    avatar: '<i class="ph ph-user-circle"></i>'
  };
  state.inquiries.unshift(inq);
  state.myInquiries.unshift({id:inq.id, houseId:inq.houseId, houseName:h.name, status:'pending', q:inq.q, time:'Just now'});
  save();

  ['inq-date','inq-q'].forEach(id=>{ const e=document.getElementById(id); if(e) e.value=''; });
  document.getElementById('cc').textContent='0/200';

  document.getElementById('succ-ic').innerHTML='<i class="ph ph-check-circle"></i>';
  document.getElementById('succ-title').textContent='Inquiry Sent!';
  document.getElementById('succ-body').textContent=`Your inquiry was sent to ${h.name}. Landlords typically respond within 24 hours.`;
  document.getElementById('succ-card').innerHTML=`
    <div style="font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px">Inquiry Summary</div>
    ${[['House',h.name],['Status',' Awaiting Reply'],['School',inq.school],['Move-in',inq.date||'—']].map(([l,v])=>`
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px">
      <span style="color:var(--muted)">${l}</span>
      <span style="font-weight:700">${v}</span>
    </div>`).join('')}`;
  const calBtnInq = document.getElementById('succ-cal-btn');
  if(calBtnInq) calBtnInq.style.display = 'none';
  _successDest = 's-myinq'; goTo('s-success');
  if (state.myInquiries.length === 1) {
    setTimeout(() => showProfileNudge('seeker'), 2500);
  }
}

