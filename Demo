function renderBhlListing() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];

  // Fill info tab
  const sv = (id, v) => { const e = document.getElementById(id); if(e && v !== undefined) e.value = v || ''; };
  sv('bhl-name', h.name);
  sv('bhl-address', h.address);
  sv('bhl-price', h.price);
  sv('bhl-about', h.about || '');
  sv('bhl-devsu', h.distanceEVSU);
  sv('bhl-dbcc', h.distanceBCC);
  // curfew select
  const curfewSel = document.getElementById('bhl-curfew');
  if(curfewSel) {
    [...curfewSel.options].forEach(o => o.selected = (o.value === h.curfew));
  }

  // Preview hero
  const heroBg = document.getElementById('bhl-hero-bg');
  const stripBg = document.getElementById('bhl-strip-bg');
  if(heroBg) heroBg.style.background = h.gradient;
  if(stripBg) stripBg.style.background = h.gradient;
  updateBhlPreview();

  // Availability strip
  const avail = (h.rooms||[]).filter(r=>r.status==='empty').length;
  const availEl = document.getElementById('bhl-strip-avail');
  if(availEl) {
    availEl.textContent = avail > 0 ? `${avail} slot${avail>1?'s':''} open` : 'Full · Waitlist';
    availEl.style.background = avail > 0 ? 'rgba(34,197,94,.35)' : 'rgba(239,68,68,.35)';
  }

  // Gradient picker
  const gradGrid = document.getElementById('bhl-grad-grid');
  if(gradGrid) {
    gradGrid.innerHTML = BHL_GRADIENTS.map((g, i) => `
      <div class="grad-swatch ${g===h.gradient?'on':''}" style="background:${g};"
        onclick="selectBhlGrad('${g}', this)"></div>`).join('');
  }

  // Rules toggles
  ['wifi','cooking','pets','laundry'].forEach(key => {
    const cb = document.getElementById('bhl-' + key);
    if(cb) {
      cb.checked = !!h.rules[key];
      updateToggleVisual(key, cb.checked);
    }
  });
  sv('bhl-visitors', h.rules.visitors);
  sv('bhl-advance', h.rules.advance);
  const vSel = document.getElementById('bhl-visitors');
  if(vSel) [...vSel.options].forEach(o => o.selected = (o.value === h.rules.visitors));
  const aSel = document.getElementById('bhl-advance');
  if(aSel) [...aSel.options].forEach(o => o.selected = (o.value === h.rules.advance));

  // Custom rules list
  renderBhlCustomRules();

  // Snapshots
  renderBhlSnapGrid();

  // Amenity chips
  renderAmenityChips();

  // Reflect current verification state in banner
  updateVerifyBanner(h);
}

function updateToggleVisual(key, checked) {
  const track = document.getElementById('bhl-' + key + '-track');
  const thumb = document.getElementById('bhl-' + key + '-thumb');
  if(track) track.style.background = checked ? 'var(--teal)' : 'var(--border2)';
  if(thumb) thumb.style.left = checked ? '20px' : '2px';
}

function saveBhlToggle() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  ['wifi','cooking','pets','laundry'].forEach(key => {
    const cb = document.getElementById('bhl-' + key);
    if(cb) {
      h.rules[key] = cb.checked;
      updateToggleVisual(key, cb.checked);
    }
  });
  const vSel = document.getElementById('bhl-visitors');
  if(vSel) h.rules.visitors = vSel.value;
  const aSel = document.getElementById('bhl-advance');
  if(aSel) h.rules.advance = aSel.value;
}

