function renderLandlordHome() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  // FIX 18: Update landlord name from profiles (not hardcoded)
  const lName = document.getElementById('lhdr-dyn-name');
  if (lName) {
    const _lh = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
    const displayName = profiles.landlord.name || _lh?.name?.split(' ')[0] || 'Landlord';
    lName.textContent = displayName;
  }
  const paid    = (h.rooms || []).filter(r=>r.status==='paid').length;
  const pending = (h.rooms || []).filter(r=>r.status==='pending').length;
  const empty   = (h.rooms || []).filter(r=>r.status==='empty').length;
  const total   = (h.rooms || []).reduce((s,r)=>s+(r.status!=='empty'?r.amount:0),0);
  const pendAmt = pending * h.price;

  document.getElementById('l-total-amt').innerHTML = `₱<span>${total.toLocaleString()}</span>`;
  document.getElementById('l-pending-amt').textContent = '₱'+pendAmt.toLocaleString();
  document.getElementById('l-rooms-paid').textContent = paid+'/'+(h.rooms||[]).length;
  document.getElementById('l-vacant-count').textContent = empty;

  // Inbox badge
  const newInqCount = state.inquiries.filter(i=>i.status==='pending').length;
  const inboxBadge = document.getElementById('l-inbox-badge');
  if(inboxBadge) {
    if(newInqCount > 0) { inboxBadge.textContent = newInqCount + ' new'; inboxBadge.classList.remove('hidden'); }
    else inboxBadge.classList.add('hidden');
  }

  // Pending tenants badge
  const pendingTenants = state.pendingTenants.filter(t=>t.houseId===state.currentHouseId&&t.status==='pending').length;
  const pendBadge = document.getElementById('l-pending-badge');
  if(pendBadge) {
    if(pendingTenants > 0) { pendBadge.textContent = pendingTenants + ' pending'; pendBadge.classList.remove('hidden'); }
    else pendBadge.classList.add('hidden');
  }

  // Room grid
  document.getElementById('l-room-grid').innerHTML = (h.rooms||[]).map(r => {
    const isSelfReported = r.status === 'self_reported';
    const statusLabel = r.status === 'paid' ? 'Paid' : r.status === 'pending' ? 'Pending' : isSelfReported ? 'Confirm?' : 'Empty';
    const statusClass = r.status === 'paid' ? 'paid' : r.status === 'pending' ? 'pend' : isSelfReported ? 'pend' : 'empty';
    return `<div class="rt${isSelfReported ? ' rt-pulse' : ''}" onclick="${isSelfReported ? `confirmLandlordPayment(${r.id})` : `openRoomModal(${r.id})`}">
      <div class="rt-num">${r.name}</div>
      <div class="rt-st st-${statusClass}">${statusLabel}</div>
      ${isSelfReported ? `<div style="font-size:8px;color:var(--amber);font-weight:700;margin-top:2px;">Tap to confirm</div>` : ''}
    </div>`;
  }).join('');

  // Announce badge: count unread/recent announcements
  const annBadge = document.getElementById('l-announce-badge');
  if(annBadge) {
    const recentAnn = state.announcements.filter(a=>a.time==='Just now'||a.isNew).length;
    if(recentAnn > 0) { annBadge.textContent = recentAnn+' sent'; annBadge.classList.remove('hidden'); }
    else annBadge.classList.add('hidden');
  }

  // Maint badge: open maintenance requests
  const maintBadge = document.getElementById('l-maint-badge');
  if(maintBadge) {
    const openMaint = state.maintenanceRequests.filter(r=>r.status!=='done').length;
    if(openMaint > 0) { maintBadge.textContent = openMaint+' open'; maintBadge.classList.remove('hidden'); }
    else maintBadge.classList.add('hidden');
  }

  // Vacancy alert
  const vacEl = document.getElementById('l-vac-alert');
  if(empty>0) {
    const lost = empty * h.price * 0.5;
    vacEl.innerHTML = `<div class="vac-alert">
      <span style="font-size:20px"><i class="ph ph-money"></i></span>
      <div class="vac-txt"><strong>Vacancy cost this month: ₱${lost.toLocaleString()}</strong><br>${empty} room${empty>1?'s':''} empty — equal to ${Math.round(lost/70)} kilos of rice.</div>
    </div>`;
  } else {
    vacEl.innerHTML = `<div class="callout cl-green"><span class="callout-ic"></span><div class="callout-txt"><strong>All rooms occupied!</strong> 0 vacancy cost this month.</div></div>`;
  }
  renderMoveOutRequests();
  renderPendingPayments();
}

