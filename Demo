function pickSlot(id) {
  state.selectedSlot = id;
  document.querySelectorAll('.slot').forEach(s=>s.classList.remove('on'));
  document.getElementById('slot-'+id)?.classList.add('on');
  const btn = document.getElementById('confirm-visit-btn');
  btn.style.opacity='1'; btn.style.pointerEvents='auto';
  // Show selected slot summary
  const slot = state.visitSlots.find(s=>s.id===id);
  const h = state.houses.find(x=>x.id===state.currentHouseId);
  const slotSummary = document.getElementById('visit-slot-summary');
  if(slotSummary && slot) {
    slotSummary.textContent = `${slot.date} at ${slot.time} — ${h?.name||'Boarding House'}`;
  }
  document.getElementById('visit-confirm-area').classList.remove('hidden');
}

function confirmVisit() {
  if(!state.selectedSlot) return;
  const slot = state.visitSlots.find(s=>s.id===state.selectedSlot);
  if(slot) slot.taken = true;
  const h = state.houses.find(x=>x.id===state.currentHouseId);
  state.visits.unshift({id:state.nextId++,name:'You',house:h.name,date:slot.date,time:slot.time,status:'pending'});
  save();

  document.getElementById('succ-ic').textContent='📅';
  document.getElementById('succ-title').textContent='Visit Requested!';
  document.getElementById('succ-body').textContent=`Your visit request was sent to ${h.name}. The landlord will confirm soon.`;
  document.getElementById('succ-card').innerHTML=`
    <div style="font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px">Visit Details</div>
    ${[['House',h.name],['Date',slot.date],['Time',slot.time],['Status','⏳ Awaiting Confirmation']].map(([l,v])=>`
    <div style="display:flex;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px">
      <span style="color:var(--muted)">${l}</span><span style="font-weight:700">${v}</span>
    </div>`).join('')}`;
  // Principle 14: Commitment Device — offer calendar add
  // Build ICS data for the visit
  try {
    const dateStr = slot.date.replace(/[^0-9]/g,''); // "July 5, 2025" → rough parse
    const calBtn = document.getElementById('succ-cal-btn');
    if(calBtn) {
      const icsContent = [
        'BEGIN:VCALENDAR','VERSION:2.0',
        'BEGIN:VEVENT',
        `SUMMARY:Visit – ${h.name}`,
        `DESCRIPTION:Boarding house visit at ${h.name}\nTime: ${slot.time}\nAddress: ${h.address}`,
        `DTSTART:${(()=>{try{const d=new Date(slot.date+' '+new Date().getFullYear());return d.getFullYear()+''+String(d.getMonth()+1).padStart(2,'0')+''+String(d.getDate()).padStart(2,'0')+'T090000';}catch(e){return new Date().getFullYear()+'0705T090000';}})()}`,
        `DTEND:${(()=>{try{const d=new Date(slot.date+' '+new Date().getFullYear());return d.getFullYear()+''+String(d.getMonth()+1).padStart(2,'0')+''+String(d.getDate()).padStart(2,'0')+'T100000';}catch(e){return new Date().getFullYear()+'0705T100000';}})()}`,
        'END:VEVENT','END:VCALENDAR'
      ].join('\r\n');
      const blob = new Blob([icsContent], {type:'text/calendar'});
      const url = URL.createObjectURL(blob);
      calBtn.style.display='flex';
      calBtn.onclick = () => {
        const a = document.createElement('a');
        a.href = url; a.download='buhay-boarding-visit.ics'; a.click();
        showToast('Calendar file downloaded! Open it to add to your phone calendar 📅');
      };
    }
  } catch(e) {}
  goTo('s-success');
}

