function renderHouses() {
  const list = document.getElementById('houses-list');
  const countEl = document.getElementById('houses-count');
  let houses = state.houses;

  // school filter
  if(state.school==='evsu') houses = houses.sort((a,b)=>a.distanceEVSU-b.distanceEVSU);
  else houses = houses.sort((a,b)=>a.distanceBCC-b.distanceBCC);

  // filter
  if(state.filter==='available') houses = houses.filter(h=>h.available()>0);
  else if(state.filter==='under2k') houses = houses.filter(h=>h.price<2000);
  else if(state.filter==='wifi') houses = houses.filter(h=>h.rules.wifi);
  else if(state.filter==='nocurfew') houses = houses.filter(h=>h.curfew==='No curfew');

  // search
  const q = document.getElementById('srch-inp')?.value?.toLowerCase()||'';
  if(q) houses = houses.filter(h=>h.name.toLowerCase().includes(q)||h.address.toLowerCase().includes(q));

  const school = state.school==='evsu'?'EVSU':'BCC';
  countEl.textContent = houses.length+' house'+(houses.length!==1?'s':'')+' near '+school;

  list.innerHTML = houses.map(h=>{
    const avail = h.available();
    const isFull = avail===0;
    const hasWaitlist = h.waitlist.length>0;
    const dist = state.school==='evsu'?h.distanceEVSU:h.distanceBCC;
    const tagStr = h.amenities.map(a=>`<span class="tag tg">${a}</span>`).join('');
    const badge = isFull
      ? '<span class="lcard-badge" style="background:var(--red)">Full</span>'
      : '<span class="lcard-badge" style="background:var(--teal)">✓ Verified</span>';
    const rooms = isFull
      ? `<span class="lcard-rooms">Waitlist: ${h.waitlist.length}</span>`
      : `<span class="lcard-rooms">${avail} room${avail!==1?'s':''} left</span>`;
    const cta = isFull
      ? `<button class="btn btn-blue" style="background:var(--amberBg);color:var(--amber);font-size:12px;padding:8px 13px;border-radius:8px">Join Waitlist</button>`
      : `<button class="btn btn-blue" style="font-size:12px;padding:8px 13px;border-radius:8px">Ask a Question</button>`;
    return `
      <div class="lcard" onclick="openHouse(${h.id})">
        <div class="lcard-img" style="background:${h.gradient}">
          <span class="lcard-img-ph">🏠</span>
          ${badge}${rooms}
        </div>
        <div class="lcard-body">
          <div class="lcard-name">${h.name}</div>
          <div class="lcard-loc">📍 ${dist} min walk from ${school} gate</div>
          <div class="lcard-tags">${tagStr}</div>
          <div class="lcard-foot">
            <div class="lcard-price">₱${h.price.toLocaleString()}<span>/mo</span></div>
            ${cta}
          </div>
        </div>
      </div>`;
  }).join('');
}

function openHouse(id) {
  state.currentHouseId = id;
  const h = state.houses.find(x=>x.id===id);
  if(!h) return;
  const avail = h.available();
  const isFull = avail===0;
  const dist = state.school==='evsu'?h.distanceEVSU:h.distanceBCC;
  const school = state.school==='evsu'?'EVSU':'BCC';

  document.getElementById('d-topname').textContent = h.name;
  document.getElementById('d-hero').style.background = h.gradient;
  document.getElementById('d-vbadge').textContent = `✓ Verified ${h.verified}`;
  document.getElementById('d-name').textContent = h.name;
  document.getElementById('d-loc').textContent = `📍 ${h.address} — ${dist} min walk from ${school} gate`;

  // Snapshot
  document.getElementById('d-snap').innerHTML = `
    <div class="snap-itm"><span class="snap-lbl">Monthly Rent</span><span class="snap-val">₱${h.price.toLocaleString()}</span></div>
    <div class="snap-itm"><span class="snap-lbl">Available Rooms</span><span class="snap-val ${isFull?'r':'g'}">${isFull?'Full – Waitlist':avail+' of '+h.rooms.length}</span></div>
    <div class="snap-itm"><span class="snap-lbl">Curfew</span><span class="snap-val">${h.curfew}</span></div>
    <div class="snap-itm"><span class="snap-lbl">Utilities</span><span class="snap-val">${h.rules.wifi?'WiFi included':'Utilities separate'}</span></div>
    <div class="snap-itm"><span class="snap-lbl">Bathroom</span><span class="snap-val">Shared</span></div>
    <div class="snap-itm"><span class="snap-lbl">Advance</span><span class="snap-val">${h.rules.advance}</span></div>`;

  // Rules
  document.getElementById('d-rules').innerHTML = [
    ['🌐','WiFi',h.rules.wifi,'Included','Not included'],
    ['🍳','Cooking',h.rules.cooking,'Allowed','Not allowed'],
    ['👥','Visitors',true,h.rules.visitors,'Not allowed'],
    ['🐾','Pets',h.rules.pets,'Allowed','Not allowed'],
    ['👕','Laundry',h.rules.laundry,'On-site area','No laundry area'],
  ].map(([ic,nm,cond,yes,no])=>`
    <div class="rule-row">
      <span class="rule-nm"><span>${ic}</span>${nm}</span>
