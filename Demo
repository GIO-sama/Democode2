// NEW LANDLORD ONBOARDING — 4-STEP FLOW
// ════════════════════════════════════════
let loStep = 1;
const LO_STEPS = 4;
function landlordOnboardNext() {
  if(loStep===1) {
    const name  = document.getElementById('lo-name').value.trim();
    const phone = document.getElementById('lo-phone').value.trim();
    if(!name) { showToast('Please enter your name'); return; }
    if(!phone){ showToast('Please enter your phone number'); return; }
    profiles.newLandlord.name  = name;
    profiles.newLandlord.phone = phone;
    profiles.newLandlord.gcash = document.getElementById('lo-gcash').value.trim();
    loStep = 2; showLoStep(2);
  } else if(loStep===2) {
    const bh   = document.getElementById('lo-bh-name').value.trim();
    const addr = document.getElementById('lo-address').value.trim();
    if(!bh)  { showToast('Please enter your boarding house name'); return; }
    if(!addr){ showToast('Please enter the address'); return; }
    profiles.newLandlord.bhName   = bh;
    profiles.newLandlord.address  = addr;
    profiles.newLandlord.school   = document.getElementById('lo-school').value;
    profiles.newLandlord.distance = parseInt(document.getElementById('lo-distance').value)||5;
    loStep = 3; showLoStep(3);
  } else if(loStep===3) {
    profiles.newLandlord.price    = parseInt(document.getElementById('lo-price').value);
    profiles.newLandlord.rooms    = parseInt(document.getElementById('lo-rooms').value)||4;
    profiles.newLandlord.curfew   = document.getElementById('lo-curfew').value;
    profiles.newLandlord.wifi     = document.getElementById('lo-wifi').classList.contains('on');
    profiles.newLandlord.cooking  = document.getElementById('lo-cooking').classList.contains('on');
    profiles.newLandlord.visitors = document.getElementById('lo-visitors').classList.contains('on');
    profiles.newLandlord.laundry  = document.getElementById('lo-laundry').classList.contains('on');
    // Populate summary
    const el = (id,v)=>{ const e=document.getElementById(id); if(e) e.textContent=v; };
    el('lo-sum-name',  profiles.newLandlord.name);
    el('lo-sum-bh',    profiles.newLandlord.bhName);
    el('lo-sum-addr',  profiles.newLandlord.address);
    el('lo-sum-price', '₱'+profiles.newLandlord.price.toLocaleString()+'/month');
    el('lo-sum-rooms', profiles.newLandlord.rooms+' rooms');
    loStep = 4; showLoStep(4);
  } else if(loStep===4) {
    const nl = profiles.newLandlord;
    // Build a real house entry — not visible to seekers until self-verified
    const gradients = [
      'linear-gradient(135deg,#5B21B6,#7C3AED)',
      'linear-gradient(135deg,#0B7A6A,#0D9480)',
      'linear-gradient(135deg,#1462A8,#1558CC)',
      'linear-gradient(135deg,#B45309,#D97706)',
    ];
    const newHouseId = Math.max(...state.houses.map(h=>h.id)) + 1;
    const rooms = [];
    for (let i = 1; i <= (nl.rooms||4); i++) {
      rooms.push({ id: i, name: 'R'+i, status:'empty', tenant:null, amount: nl.price||1500 });
    }
    const newHouse = {
      id:          newHouseId,
      name:        nl.bhName,
      address:     nl.address,
      price:       nl.price || 1500,
      curfew:      nl.curfew || '10:00 PM',
      distanceEVSU: nl.school==='evsu' ? (nl.distance||8) : (nl.distance||15),
      distanceBCC:  nl.school==='bcc'  ? (nl.distance||5) : (nl.distance||12),
      gradient:    gradients[newHouseId % gradients.length],
      latlng:      [10.9748, 124.8927], // verified Burauen center
      verified:    null,
      selfVerified: false,
      adminStatus: 'pending',
      lastActive:  'Just now',
      about:       '',
      amenities:   [],
      snapshots:   [],
      waitlist:    [],
      rooms,
      rules: {
        wifi:     nl.wifi     || false,
        cooking:  nl.cooking  || false,
        visitors: nl.visitors || false,
        laundry:  nl.laundry  || false,
        advance:  '1 month',
        deposit:  '1 month',
      },
    };
    state.houses.push(newHouse);
    state.currentHouseId = newHouseId;
    // Copy to landlord profile
    profiles.landlord.name   = nl.name;
    profiles.landlord.phone  = nl.phone;
    profiles.landlord.gcash  = nl.gcash;
    profiles.landlord.bhName = nl.bhName;
    profiles.landlord.address= nl.address;
    profiles.landlord.created= new Date().toLocaleDateString('en-PH',{month:'long',year:'numeric'});
    saveProfiles();
    save();
    adminLog(`New landlord registered: ${nl.bhName}`);
    showToast('<i class="ph ph-house"></i> Listing created! Self-verify it to go live.');
    loStep = 1;
    goTo('l-home');
  }
}
function landlordOnboardBack() {
  if(loStep>1) { loStep--; showLoStep(loStep); }
  else goTo('s-role');
}
function showLoStep(n) {
  document.querySelectorAll('#l-onboard .onboard-step').forEach((el,i)=>{
    el.classList.toggle('active', i+1===n);
  });
  const fill = document.getElementById('lo-progress');
  if(fill) fill.style.width = (n/LO_STEPS*100)+'%';
  document.getElementById('lo-back-btn').style.display = n>1 ? '' : 'none';
  const nextBtn = document.getElementById('lo-next-btn');
  if(nextBtn) nextBtn.textContent = n===LO_STEPS ? 'Submit Listing ' : 'Next →';
  const titles = ['List Your Boarding House','Property Details','Rooms & Pricing','Review & Submit'];
  const subs = [
    'Free setup. Verified listing. Start getting serious inquiries.',
    'Tell seekers where you are and how far from school.',
    'Set your price, rules, and available rooms.',
    'Almost done! We will verify your listing in person.'
  ];
  const tEl = document.getElementById('lo-title');
  const sEl = document.getElementById('lo-sub');
  if(tEl) tEl.textContent = titles[n-1];
  if(sEl) sEl.textContent = subs[n-1];
  loStep = n;
}

