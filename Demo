let _adminInqFilter = 'all';
function filterAdminInq(f, btn) {
  _adminInqFilter=f;
  document.querySelectorAll('#a-inquiries .a-btn').forEach(b=>{ b.style.background='var(--warm2)'; b.style.color='var(--navy)'; b.style.border='1px solid var(--border)'; });
  if (btn) { btn.style.background='rgba(255,107,107,.2)'; btn.style.color='#ff6b6b'; btn.style.border='1px solid rgba(255,107,107,.3)'; }
  renderAdminInquiries();
}
function renderAdminInquiries() {
  const list=document.getElementById('a-inq-list'), badge=document.getElementById('a-inq-badge');
  if (!list) return;
  let inqs = state.inquiries;
  if (_adminInqFilter!=='all') inqs=inqs.filter(i=>i.status===_adminInqFilter);
  if (badge) badge.textContent=state.inquiries.filter(i=>i.status==='pending').length;
  if (!inqs.length) { list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;">No inquiries match.</div>'; return; }
  const sMap={pending:'a-pill-pending',replied:'a-pill-active',interested:'a-pill-verified',offered:'a-pill-active',declined:'a-pill-suspended',not_a_fit:'a-pill-suspended'};
  list.innerHTML=inqs.map(i=>{
    const h=state.houses.find(x=>x.id===i.houseId);
    return `<div class="a-row">
      <div class="a-row-top"><div><div class="a-row-name">${i.name}</div><div class="a-row-sub">${i.school||'—'} · ${i.course||'—'}</div></div><span class="a-pill ${sMap[i.status]||'a-pill-pending'}">${i.status}</span></div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:6px;">"${i.q||'—'}"</div>
      <div style="font-size:11px;color:var(--muted);margin-bottom:8px;"><i class="ph ph-house"></i> ${h?.name||'—'} · ${relTime(Date.now()-3600000)}</div>
      <div class="a-row-actions"><button class="a-btn a-btn-suspend" onclick="adminCloseInquiry(${i.id})"><i class="ph ph-x-circle"></i> Close</button></div>
    </div>`;
  }).join('');
}
function adminCloseInquiry(id) {
  const i=state.inquiries.find(x=>x.id===id);
  if (i) { i.status='declined'; save(); renderAdminInquiries(); showToast('Inquiry closed by admin'); }
}

