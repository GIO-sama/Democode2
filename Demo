  const done = reqs.filter(r=>r.status==='done').length;
  document.getElementById('l-maint-pending-count').textContent = pending;
  document.getElementById('l-maint-inprog-count').textContent = inprog;
  document.getElementById('l-maint-done-count').textContent = done;
  const sMap = {
    pending:{bg:C.amberBg,tc:C.amber,label:'Pending'},
    in_progress:{bg:C.tealBg,tc:C.teal,label:'In Progress'},
    done:{bg:C.greenBg,tc:C.green,label:'Done '},
  };
  const el = document.getElementById('l-maint-list');
  if(!reqs.length) { el.innerHTML='<div style="text-align:center;padding:30px;color:var(--muted);font-size:13px">No maintenance requests</div>'; return; }
