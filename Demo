function requestMoveOut() {
  if (!state.tenantProfile) { showToast('No active tenancy found'); return; }
  if (!state.moveOutRequests) state.moveOutRequests = [];
  const tp = state.tenantProfile;
  const existing = state.moveOutRequests.find(r => r.tenantName === tp.name && r.status === 'pending');
  if (existing) { showToast('Move-out request already submitted. Waiting for landlord.'); return; }
  // Remove old card if any
  const old = document.getElementById('moveout-confirm-card');
  if (old) old.remove();
  const card = document.createElement('div');
  card.id = 'moveout-confirm-card';
  card.style.cssText = 'position:fixed;bottom:90px;left:50%;transform:translateX(-50%);width:calc(100% - 32px);max-width:390px;background:var(--amberBg);border:1.5px solid var(--amber);border-radius:14px;padding:16px;z-index:600;box-shadow:0 8px 32px rgba(0,0,0,.2);';
  card.innerHTML = `
    <div style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--amber);margin-bottom:6px;"><i class="ph ph-sign-out"></i> Request Move-Out?</div>
    <div style="font-size:12px;color:var(--text2);margin-bottom:14px;">This sends a move-out request to your landlord. Your room won't be vacated until they confirm it.</div>
    <div style="display:flex;gap:8px;">
      <button onclick="submitMoveOutRequest()" style="flex:2;background:var(--amber);color:#fff;border:none;border-radius:8px;padding:10px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;cursor:pointer;">Yes, Request Move-Out</button>
      <button onclick="document.getElementById('moveout-confirm-card').remove()" style="flex:1;background:var(--warm);border:1px solid var(--border);border-radius:8px;padding:10px;font-family:'Nunito',sans-serif;font-size:13px;cursor:pointer;">Cancel</button>
    </div>`;
  document.body.appendChild(card);
}

function submitMoveOutRequest() {
  const card = document.getElementById('moveout-confirm-card');
  if (card) card.remove();
  if (!state.moveOutRequests) state.moveOutRequests = [];
  const tp = state.tenantProfile;
  if (!tp) return;
  state.moveOutRequests.push({
    id: state.nextId++,
    tenantName: tp.name,
    room: tp.room,
    houseId: tp.houseId,
    houseName: tp.houseName || state.houses.find(h=>h.id===tp.houseId)?.name || '—',
    requestedAt: Date.now(),
    status: 'pending',
  });
  adminLog(`Move-out requested by ${tp.name} (${tp.room})`);
  save();
  showToast('<i class="ph ph-sign-out"></i> Move-out request sent to your landlord.');
}

function confirmMoveOut(requestId) {
  if (!state.moveOutRequests) return;
  const req = state.moveOutRequests.find(r => r.id === requestId);
  if (!req) return;
  req.status = 'confirmed';
  // Vacate the room
  const h = state.houses.find(x => x.id === req.houseId);
  if (h) {
    const r = (h.rooms||[]).find(rm => rm.name === req.room);
    if (r) { r.status = 'empty'; r.tenant = null; }
  }
  // Remove from pendingTenants
  state.pendingTenants = state.pendingTenants.filter(t =>
    !(t.name === req.tenantName && t.houseId === req.houseId)
  );
  // Clear tenantProfile if it matches this tenant
  if (state.tenantProfile && state.tenantProfile.room === req.room && state.tenantProfile.houseId === req.houseId) {
    state.tenantProfile = null;
  }
  adminLog(`Move-out confirmed: ${req.tenantName} from ${req.room}`);
  save();
  renderLandlordHome();
  showToast(`<i class="ph ph-check-circle"></i> ${req.tenantName} moved out — ${req.room} is now vacant`);
}

function declineMoveOut(requestId) {
  if (!state.moveOutRequests) return;
  const req = state.moveOutRequests.find(r => r.id === requestId);
  if (req) { req.status = 'declined'; save(); renderLandlordHome(); showToast('Move-out request declined'); }
}

