  renderAdminListings();
}
function renderAdminListings() {
  ensureAdminFields();
  const list  = document.getElementById('a-listings-list');
  const badge = document.getElementById('a-listings-badge');
  if (!list) return;
  let houses = state.houses;
  if (_adminListingFilter==='pending')   houses = houses.filter(h=>h.adminStatus==='pending');
  if (_adminListingFilter==='active')    houses = houses.filter(h=>h.adminStatus==='active');
  if (_adminListingFilter==='suspended') houses = houses.filter(h=>h.adminStatus==='suspended');
  if (badge) badge.textContent = state.houses.filter(h=>h.adminStatus==='pending').length || state.houses.length;
  if (!houses.length) { list.innerHTML='<div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:13px;">No listings match this filter.</div>'; return; }
  list.innerHTML = houses.map(h => {
    const occ = (h.rooms||[]).filter(r=>r.status!=='empty').length;
    const inqCount = state.inquiries.filter(i=>i.houseId===h.id).length;
    const statusPill = h.adminStatus==='suspended'
      ? '<span class="a-pill a-pill-suspended">Suspended</span>'
      : h.adminStatus==='pending'
        ? '<span class="a-pill a-pill-pending">Pending Review</span>'
        : h.adminVerified
          ? '<span class="a-pill a-pill-verified"><i class="ph ph-seal-check"></i> Admin Verified</span>'
          : '<span class="a-pill a-pill-active">Active</span>';
    const actions = h.adminStatus==='suspended'
      ? `<button class="a-btn a-btn-restore" onclick="adminListingAction(${h.id},'restore')"><i class="ph ph-arrow-counter-clockwise"></i> Restore</button>`
      : `<button class="a-btn a-btn-verify"  onclick="adminListingAction(${h.id},'verify')"><i class="ph ph-seal-check"></i> Admin Verify</button>
         <button class="a-btn a-btn-suspend" onclick="adminListingAction(${h.id},'suspend')"><i class="ph ph-prohibit"></i> Suspend</button>`;
    return `<div class="a-row">
      <div class="a-row-top"><div><div class="a-row-name">${h.name}</div><div class="a-row-sub">${h.address}</div></div>${statusPill}</div>
      <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:8px;">
        <span style="font-size:11px;color:var(--muted);"><i class="ph ph-house"></i> ${occ}/${(h.rooms||[]).length} rooms</span>
        <span style="font-size:11px;color:var(--muted);"><i class="ph ph-chat-circle"></i> ${inqCount} inquiries</span>
        <span style="font-size:11px;color:var(--muted);"><i class="ph ph-money"></i> ₱${h.price.toLocaleString()}/mo</span>
        <span style="font-size:11px;color:var(--muted);"><i class="ph ph-clock"></i> ${h.lastActive||'—'}</span>
      </div>
      <div class="a-row-actions">${actions}<button class="a-btn a-btn-edit" onclick="adminEditListingPrice(${h.id})"><i class="ph ph-pencil-simple"></i> Edit Price</button></div>
    </div>`;
  }).join('');
}
function adminListingAction(id, action) {
  ensureAdminFields();
  const h = state.houses.find(x=>x.id===id);
  if (!h) return;
  if (action==='verify') {
    h.selfVerified=false; h.adminVerified=true;
    h.verified=new Date().toLocaleString('en-PH',{month:'long',year:'numeric'});
    h.adminStatus='active';
    adminLog(`Admin verified: ${h.name}`);
    showToast(`<i class="ph ph-seal-check"></i> ${h.name} — Admin Verified`);
  } else if (action==='suspend') {
    h.adminStatus='suspended'; adminLog(`Suspended: ${h.name}`);
    showToast(`<i class="ph ph-prohibit"></i> ${h.name} suspended`);
  } else if (action==='restore') {
    h.adminStatus='active'; adminLog(`Restored: ${h.name}`);
    showToast(`<i class="ph ph-arrow-counter-clockwise"></i> ${h.name} restored`);
  }
  save(); renderAdminListings();
}
function adminEditListingPrice(id) {
  const h = state.houses.find(x=>x.id===id);
  if (!h) return;
  const np = prompt(`Edit price for ${h.name}\nCurrent: ₱${h.price.toLocaleString()}\nEnter new price:`);
  if (np && !isNaN(parseInt(np))) { h.price=parseInt(np); save(); renderAdminListings(); showToast('Price updated to ₱'+h.price.toLocaleString()); }
}

