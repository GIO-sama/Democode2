function renderLandlordHome() {
  const h = state.houses[0];
  const paid = h.rooms.filter(r=>r.status==='paid').length;
  const pending = h.rooms.filter(r=>r.status==='pending').length;
  const empty = h.rooms.filter(r=>r.status==='empty').length;
  const total = h.rooms.reduce((s,r)=>s+(r.status!=='empty'?r.amount:0),0);
  const pendAmt = pending * h.price;

  document.getElementById('l-total-amt').innerHTML = `₱<span>${total.toLocaleString()}</span>`;
  document.getElementById('l-pending-amt').textContent = '₱'+pendAmt.toLocaleString();
