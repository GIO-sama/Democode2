function pickAvatar(el, type) {
  const grid = el.closest('.avatar-grid');
  if(grid) {
    grid.querySelectorAll('.avatar-opt').forEach(a=>a.classList.remove('selected'));
    el.classList.add('selected');
  }
  if(type==='s') profiles.seeker.avatar  = el.dataset.av;
