function renderSeekerProfile() {
  const p = profiles.seeker;
  const el = (id,v)=>{ const e=document.getElementById(id); if(e) e.textContent=v; };
  el('sp-name',     p.name||'—');
  el('sp-school',   (p.school||'—') + (p.course ? ' · '+p.course : ''));
  el('sp-budget',   p.budget ? '₱'+p.budget.toLocaleString() : '—');
  el('sp-school-pref', p.school||'—');
  el('sp-wifi',     p.wifi     ? 'Required'     : 'Not required');
