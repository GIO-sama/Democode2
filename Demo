  const hr = new Date().getHours();
  let greetFil, greetEn, emoji;
  if (hr < 12)      { greetFil = 'Magandang umaga';    greetEn = 'Good morning';   emoji = '☀️'; }
  else if (hr < 18) { greetFil = 'Magandang hapon';    greetEn = 'Good afternoon'; emoji = '🌤️'; }
  else              { greetFil = 'Magandang gabi';     greetEn = 'Good evening';   emoji = '🌙'; }
  const sg = document.getElementById('seeker-greeting');
  const lg = document.getElementById('landlord-greeting');
  if (sg) sg.textContent = greetFil + ' ' + emoji;
  if (lg) lg.textContent = greetEn + ' ' + emoji;
}

