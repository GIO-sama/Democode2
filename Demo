// Returns dot + text HTML for last active indicator
function lastActiveHtml(val) {
  if (!val) return '';
  const isToday  = val === 'Today' || val.includes('h ago') || val.includes('min ago');
  const isRecent = val.includes('day') && parseInt(val) <= 3;
  const dotClass = isToday ? 'today' : isRecent ? 'recent' : 'old';
  return `<span class="lcard-active"><span class="lcard-active-dot ${dotClass}"></span>Active ${val}</span>`;
}

// ════════════════════════════════════════
// MATCH SCORE ENGINE
// Algorithm: budget(30%) + proximity(30%) + amenity match(25%) + availability(15%)
// Returns { score:0-100, label, cssClass }
// ════════════════════════════════════════
function computeMatchScore(h) {
  const p = profiles.seeker;
  // No profile = no score
  if (!p || !p.budget) return null;

  let score = 0;

  // 1. Budget match (30 pts)
  if (h.price <= p.budget) {
    score += 30;
  } else if (h.price <= p.budget * 1.1) {
    score += 20; // within 10% over budget
  } else if (h.price <= p.budget * 1.25) {
    score += 10; // within 25% over
  }

  // 2. Proximity to preferred school (30 pts)
  const dist = (p.school === 'bcc') ? h.distanceBCC : h.distanceEVSU;
  if      (dist <= 5)  score += 30;
  else if (dist <= 8)  score += 22;
  else if (dist <= 12) score += 14;
  else if (dist <= 18) score += 6;

  // 3. Amenity/preference match (25 pts)
  let amenPts = 0;
  const maxAmen = 5;
  if (p.wifi     && h.rules?.wifi)     amenPts++;
  if (p.cooking  && h.rules?.cooking)  amenPts++;
  if (p.visitors && h.rules?.visitors) amenPts++;
  if (p.nocurfew && h.curfew === 'No curfew') amenPts++;
  if (p.laundry  && h.rules?.laundry)  amenPts++;
  score += Math.round((amenPts / maxAmen) * 25);

  // 4. Availability (15 pts)
  const avail = availableRooms(h);
  if      (avail >= 3) score += 15;
  else if (avail === 2) score += 10;
  else if (avail === 1) score += 5;
  // full = 0 pts

  // Clamp to 100
  score = Math.min(100, score);

  let label, cssClass, icon;
  if      (score >= 85) { label = `Great match ${score}%`;   cssClass = 'match-great';   icon = 'ph-star-four'; }
  else if (score >= 65) { label = `Good match ${score}%`;    cssClass = 'match-good';    icon = 'ph-thumbs-up'; }
  else if (score >= 45) { label = `Partial match ${score}%`; cssClass = 'match-partial'; icon = 'ph-equals'; }
  else                  { label = `${score}% match`;         cssClass = 'match-low';     icon = 'ph-minus'; }

  return { score, label, cssClass, icon };
}

function matchBadgeHtml(h) {
  const m = computeMatchScore(h);
  if (!m) return '';
  return `<span class="match-badge ${m.cssClass}"><i class="ph ${m.icon}"></i>${m.label}</span>`;
}

