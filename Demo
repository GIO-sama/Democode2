  // Highlight active pin
  document.querySelectorAll('.lf-pin').forEach(el => el.classList.remove('highlighted'));
  const pinEl = document.getElementById('lf-pin-' + id);
  if (pinEl) pinEl.classList.add('highlighted');

  // Pan map to pin
  if (bbMap && h.latlng) bbMap.panTo(h.latlng, { animate: true, duration: .4 });

  document.getElementById('map-overlay').classList.add('active');
}

