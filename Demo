let _adminMaintFilter = 'all';
function filterAdminMaint(f, btn) {
  _adminMaintFilter=f;
  document.querySelectorAll('#a-maintenance .a-btn').forEach(b=>{ b.style.background='var(--warm2)'; b.style.color='var(--navy)'; b.style.border='1px solid var(--border)'; });
  if (btn) { btn.style.background='rgba(255,107,107,.2)'; btn.style.color='#ff6b6b'; btn.style.border='1px solid rgba(255,107,107,.3)'; }
  renderAdminMaintenance();
}
function renderAdminMaintenance() {
  const list=document.getElementById('a-maint-list'), badge=document.getElementById('a-maint-badge');
  if (!list) return;
  let reqs=state.maintenanceRequests;
  if (_adminMaintFilter==='urgent')  reqs=reqs.filter(r=>r.urgency!=='normal');
  if (_adminMaintFilter==='pending') reqs=reqs.filter(r=>r.status==='pending');
  if (_adminMaintFilter==='done')    reqs=reqs.filter(r=>r.status==='done');
  if (badge) badge.textContent=reqs.filter(r=>r.status!=='done').length;
  if (!reqs.length) { list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;">No requests match.</div>'; return; }
  const sMap={pending:{bg:C.amberBg,tc:C.amber,lbl:'Pending'},in_progress:{bg:C.tealBg,tc:C.teal,lbl:'In Progress'},done:{bg:C.greenBg,tc:C.green,lbl:'Done'}};
  list.innerHTML=reqs.map(r=>{
    const s=sMap[r.status]||sMap.pending;
    return `<div class="a-row">
      <div class="a-row-top"><div><div class="a-row-name">${r.type.replace(/<[^>]+>/g,'').trim()}</div><div class="a-row-sub">${r.room} · ${r.tenantName} · ${r.time}</div></div><span class="tag" style="background:${s.bg};color:${s.tc};font-size:10px;">${s.lbl}</span></div>
      <div style="font-size:12px;color:var(--text2);margin-bottom:8px;">${r.desc}</div>
      ${r.urgency!=='normal'?`<span class="tag tr" style="font-size:10px;margin-bottom:8px;display:inline-block;">${r.urgency==='emergency'?'Emergency':'Urgent'}</span>`:''}
      <div class="a-row-actions">${r.status!=='done'?`<button class="a-btn a-btn-verify" onclick="adminResolveMaint(${r.id})"><i class="ph ph-check-circle"></i> Mark Resolved</button>`:''}</div>
    </div>`;
  }).join('');
}
function adminResolveMaint(id) {
  const r=state.maintenanceRequests.find(x=>x.id===id);
  if (r) {
    r.status='done';
    const mr=state.myMaintenanceRequests.find(x=>x.id===id);
    if (mr) mr.status='done';
    save(); renderAdminMaintenance(); showToast('<i class="ph ph-check-circle"></i> Marked resolved');
  }
}

