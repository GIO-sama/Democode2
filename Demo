function switchBhlTab(tab, btn) {
  document.querySelectorAll('.bhl-tab').forEach(b => b.classList.remove('on'));
  document.querySelectorAll('.bhl-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('on');
