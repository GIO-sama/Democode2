function addRoomPhoto(input) {
  const file = input.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const grid = document.getElementById('room-photo-grid');
    if (!grid) return;
    // Get current photos from existing img tags
    const imgs = grid.querySelectorAll('img[data-src]');
    const photos = Array.from(imgs).map(img => img.getAttribute('data-src'));
    // Find first empty slot
    const slotIdx = photos.length < 4 ? photos.length : 3;
    photos[slotIdx] = e.target.result;
    renderRoomPhotoGrid(photos.slice(0, 4));
  };
  reader.readAsDataURL(file);
  input.value = '';
}

function removeRoomPhoto(idx) {
  const grid = document.getElementById('room-photo-grid');
  if (!grid) return;
  const imgs = grid.querySelectorAll('img[data-src]');
  const photos = Array.from(imgs).map(img => img.getAttribute('data-src'));
  photos.splice(idx, 1);
  renderRoomPhotoGrid(photos);
}

function confirmLandlordPayment(roomId) {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  const r = (h.rooms||[]).find(x => x.id === roomId);
  if (!r) return;
  r.status = 'paid';
  // Sync tenantProfile if the room matches — don't gate on pendingTenants status
  const tp = state.tenantProfile;
  if (tp && tp.room === r.name && tp.houseId === h.id) {
    tp.paymentStatus = 'paid';
  }
  // Update paymentLog
  const log = state.paymentLog || [];
  const pending = log.find(p => p.status === 'self_reported' || p.status === 'pending');
  if (pending) { pending.status = 'paid'; }
  adminLog(`Payment confirmed for ${r.name} (${r.tenant || 'tenant'})`);
  save();
  renderLandlordHome();
  showToast(`<i class="ph ph-check-circle"></i> Payment confirmed for ${r.name}`);
}

