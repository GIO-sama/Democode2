// ID PHOTO UPLOAD
// ════════════════════════════════════════
function handlePhotoUpload(event, type) {
  const file = event.target.files[0];
  if(!file) return;
  // Track upload
  if (!state.uploadLog) state.uploadLog = [];
  const userName = type==='s' ? (profiles.seeker?.name||'Seeker')
                 : type==='l' ? (profiles.landlord?.name||'Landlord')
                 : (profiles.tenant?.name||'Tenant');
  state.uploadLog.unshift({ id:state.nextId++, type:'profile_photo', user:userName, house:'—', houseId:null, filename:file.name, size:(file.size/1024).toFixed(1)+'KB', ts:Date.now() });
  adminLog(`Profile photo uploaded by ${userName} (${(file.size/1024).toFixed(1)}KB)`);
  const reader = new FileReader();
  reader.onload = function(e) {
    const dataUrl = e.target.result;
    if(type==='s') {
      profiles.seeker.photo = dataUrl;
      const prev = document.getElementById('ss-photo-preview');
      const img  = document.getElementById('ss-photo-img');
      if(prev && img) { img.src = dataUrl; prev.classList.add('has-photo'); }
    }
    if(type==='l') {
      profiles.landlord.photo = dataUrl;
      const prev = document.getElementById('ls-photo-preview');
      const img  = document.getElementById('ls-photo-img');
      if(prev && img) { img.src = dataUrl; prev.classList.add('has-photo'); }
    }
    if(type==='t') {
      if(!profiles.tenant) profiles.tenant = {};
      profiles.tenant.photo = dataUrl;
      const prev = document.getElementById('tp-photo-preview');
      const img  = document.getElementById('tp-photo-img');
      if(prev && img) { img.src = dataUrl; prev.classList.add('has-photo'); }
    }
    saveProfiles();
  };
  reader.readAsDataURL(file);
}

function togglePhotoConsent() {
  const tog = document.getElementById('ss-show-photo');
  if (!tog) return;
  const on = tog.classList.toggle('on');
  profiles.seeker.showPhoto = on;
  saveProfiles();
}
function pickGender(el, type) {
  const pills = el.closest('.gender-pills');
  pills.querySelectorAll('.gender-pill').forEach(p=>p.classList.remove('selected'));
  el.classList.add('selected');
  const g = el.dataset.g;
  if(type==='s') profiles.seeker.gender   = g;
  if(type==='l') profiles.landlord.gender = g;
  if(type==='t') { if(!profiles.tenant) profiles.tenant={}; profiles.tenant.gender = g; }
}

