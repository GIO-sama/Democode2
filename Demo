function renderTenantMaint() {
  const el = document.getElementById('t-maint-list');
  const empty = document.getElementById('t-maint-empty');

  // Sync status from authoritative list — landlord updates state.maintenanceRequests,
  // so we must pull the latest status from there rather than the stale local copy
  state.myMaintenanceRequests.forEach(myR => {
    const source = state.maintenanceRequests.find(r => r.id === myR.id);
    if (source) myR.status = source.status;
  });

  const myReqs = state.myMaintenanceRequests;
  if(!myReqs.length) { el.innerHTML=''; empty.classList.remove('hidden'); return; }
  empty.classList.add('hidden');
  const sMap = {
    pending:    {bg:C.amberBg, tc:C.amber, label:'Pending'},
    in_progress:{bg:C.tealBg,  tc:C.teal,  label:'In Progress'},
    done:       {bg:C.greenBg, tc:C.green,  label:'Done ✓'}
  };
  el.innerHTML = myReqs.map(r=>{
    const s = sMap[r.status]||sMap.pending;
    return `<div class="mreq-item">
      <span class="mreq-ic">${r.type.split(' ')[0]}</span>
      <div class="mreq-body">
        <div class="mreq-title">${r.type.replace(/^\S+\s/,'')}</div>
        <div class="mreq-desc">${r.desc}</div>
        <div class="mreq-foot">
          <span class="tag" style="background:${s.bg};color:${s.tc}">${s.label}</span>
          <span class="mreq-time">${r.time}</span>
        </div>
      </div>
    </div>`;
  }).join('');
}

function submitMaintRequest() {
  const type = document.getElementById('mreq-type').value;
  const desc = document.getElementById('mreq-desc').value.trim();
  const urgency = document.getElementById('mreq-urgency').value;
  if(!desc) { showToast('Please describe the problem'); return; }
  const _tp = state.tenantProfile;
  const _tn = (_tp?.name) || profiles.tenant?.name || 'Tenant';
  const _tr = (_tp?.room) || 'Room 1';
  const req = {id:state.nextId++,room:_tr,type,desc,urgency,status:'pending',tenantName:_tn,time:'Just now'};
  state.maintenanceRequests.unshift(req);
  if (!state.myMaintenanceRequests) state.myMaintenanceRequests = [];
  state.myMaintenanceRequests.unshift({...req});
  save();
  closeMaintModal();
  document.getElementById('mreq-desc').value='';
