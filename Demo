function openInqDetail(id) {
  const inq = state.inquiries.find(i=>i.id===id);
  if(!inq) return;
  state.currentInqId = id;
  const h = state.houses.find(x=>x.id===inq.houseId);

  const statusLabels = {
    pending:'Pending', replied:'Replied', interested:'Interested',
    not_a_fit:'Not a Fit', visit_scheduled:'Visit Scheduled',
    offered:'Room Offered', declined:'Declined'
  };
  // Badge color per status
  const statusColors = {
    pending:   'rgba(255,255,255,.18)',
    replied:   'rgba(59,145,212,.6)',
    interested:'rgba(11,148,128,.6)',
    visit_scheduled:'rgba(91,33,182,.6)',
    offered:   'rgba(22,101,52,.6)',
    not_a_fit: 'rgba(107,114,128,.5)',
    declined:  'rgba(192,57,43,.5)'
  };

  const set = (elId, v) => { const e = document.getElementById(elId); if(e) e.textContent = v; };

  // Populate static IDs
  set('inq-h-avatar',  inq.avatar || '🎓');
  set('inq-h-name',    inq.name);
  set('inq-h-school',  (inq.school||'') + (inq.course ? ' · ' + inq.course : ''));
  set('inq-h-badge',   statusLabels[inq.status] || inq.status);
  set('inq-h-house',   h?.name || '—');
  set('inq-h-date',    inq.date ? 'Move-in ' + inq.date : 'Date TBD');
  set('inq-h-question', inq.q || '—');

  // Badge bg
  const badge = document.getElementById('inq-h-badge');
  if(badge) badge.style.background = statusColors[inq.status] || 'rgba(255,255,255,.18)';

  // Hero gradient — use house gradient for context
  const hero = document.getElementById('inq-hero-section');
  if(hero && h?.gradient) hero.style.background = h.gradient;

