      <div class="a-stat accent-red"><div class="a-stat-val">₱${totalExp.toLocaleString()}</div><div class="a-stat-lbl">Total Expenses</div></div>
      <div class="a-stat ${net>=0?'accent-green':'accent-red'}"><div class="a-stat-val" style="color:${net>=0?'var(--green)':'var(--red)'};">${net>=0?'+':''}₱${net.toLocaleString()}</div><div class="a-stat-lbl">Net (Rev − Exp)</div></div>
      <div class="a-stat accent-blue"><div class="a-stat-val">${occ}%</div><div class="a-stat-lbl">Platform Occupancy</div></div>
    </div>
    ${pendingTxs.length ? `<div style="background:rgba(180,83,9,.15);border:1px solid rgba(180,83,9,.3);border-radius:12px;padding:12px 14px;margin-bottom:14px;display:flex;align-items:center;gap:10px;">
      <i class="ph ph-clock" style="font-size:20px;color:#FCD34D;flex-shrink:0;"></i>
      <div style="flex:1;font-size:13px;color:rgba(255,255,255,.8);">${pendingTxs.length} payment${pendingTxs.length>1?'s':''} awaiting landlord confirmation</div>
      <button onclick="switchAdminFinTab('txns',document.getElementById('aft-txns'))" style="background:#ff6b6b;color:#fff;border:none;border-radius:8px;padding:6px 12px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;cursor:pointer;">View</button>
    </div>` : ''}
    <div class="card card-p" style="margin-bottom:14px;">
      <div class="slbl" style="margin-bottom:8px;">Confirmed Payments This Session</div>
      <div style="font-family:'Nunito',sans-serif;font-size:24px;font-weight:900;color:#fff;margin-bottom:4px;">₱${confirmedTotal.toLocaleString()}</div>
      <div style="font-size:12px;color:rgba(255,255,255,.4);">${confirmedTxs.length} transaction${confirmedTxs.length!==1?'s':''} confirmed</div>
    </div>
    <div class="card card-p" style="margin-bottom:14px;">
      <div class="slbl" style="margin-bottom:14px;">Revenue by House</div>
      ${houseRows.map(h=>`<div class="a-bar-row">
        <div class="a-bar-label"><span>${h.name.replace(/ Boarding House| Residence/,'')}</span><span style="font-family:'Nunito',sans-serif;font-weight:800;">₱${h.rev.toLocaleString()} <span style="font-weight:600;color:var(--muted);font-size:11px;">(${h.occ}/${h.total})</span></span></div>
        <div class="a-bar-track"><div class="a-bar-fill" style="width:${Math.round(h.rev/maxRev*100)}%;background:var(--teal);"></div></div>
