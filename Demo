  const sMap = {
    pending:   { bg:'var(--amberBg)', tc:'var(--amber)',  ic:'ph-clock',          lbl:'Pending' },
    confirmed: { bg:'var(--greenBg)', tc:'var(--green)',  ic:'ph-check-circle',   lbl:'Confirmed ✓' },
    cancelled: { bg:'var(--redBg)',   tc:'var(--red)',    ic:'ph-x-circle',       lbl:'Declined' },
  };
  list.innerHTML = myVisits.map(v => {
    const s = sMap[v.status] || sMap.pending;
    return `<div style="padding:10px 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;">
      <div style="width:36px;height:36px;background:${s.bg};border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
