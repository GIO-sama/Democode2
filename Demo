function showRegStep(n) {
  [1,2,3].forEach(i => {
    const el = document.getElementById('reg-step-'+i);
    if(el) el.classList.toggle('hidden', i !== n);
  });
}

function regStep1() {
  const name = document.getElementById('reg-name').value.trim();
  const phone = document.getElementById('reg-phone').value.trim();
  if(!name) { showToast('<i class="ph ph-warning"></i> Please enter your name'); return; }
  if(!phone || phone.length < 10) { showToast('<i class="ph ph-warning"></i> Mali ang phone number'); return; }
  state.regTempName = name;
  state.regTempPhone = phone;
  showRegStep(2);
  setTimeout(() => document.getElementById('otp0').focus(), 100);
}

function otpNext(i) {
  const el = document.getElementById('otp'+i);
  const v = el.value;
  if(v.length > 1) el.value = v.slice(-1);
  if(v && i < 5) document.getElementById('otp'+(i+1)).focus();
}

function getOtpValue() {
  return [0,1,2,3,4,5].map(i => document.getElementById('otp'+i).value).join('');
}

function regStep2() {
  const code = getOtpValue();
  if(code.length < 6) { showToast('<i class="ph ph-warning"></i> I-complete ang 6-digit code'); return; }
  // Find matching tenant
  const match = state.pendingTenants.find(t => t.code === code);
  if(!match) { showToast('<i class="ph ph-x-circle"></i> Wrong invite code. Please try again.'); return; }
  const house = state.houses.find(h => h.id === match.houseId);
  const room = house?.rooms.find(r => r.name === match.room);
  document.getElementById('reg-confirm-name').textContent = match.name;
  document.getElementById('reg-confirm-room').textContent = `${match.room} — ${house?.name || 'Boarding House'}`;
  state.currentInviteCode = code;
  showRegStep(3);
}

function completeRegistration() {
  const match = state.pendingTenants.find(t => t.code === state.currentInviteCode);
  if(!match) { showToast('<i class="ph ph-x-circle"></i> Something went wrong. Please try again.'); return; }
  match.status = 'active';
  match.moveInDate = new Date().toISOString().split('T')[0];
  const house = state.houses.find(h => h.id === match.houseId);
  const room = house?.rooms.find(r => r.name === match.room);
  state.tenantProfile = {
    name: match.name,
    phone: match.phone,
    room: match.room,
    roomLabel: match.room,
    rent: room?.amount || 1500,
    houseId: match.houseId,
    houseName: house?.name || 'Boarding House',
    houseAddr: house?.address || 'Burauen',
    paymentStatus: room?.status || 'pending',
  };
  save();
  showToast(' Welcome, ' + match.name + '!');
  setRole('tenant');
}

