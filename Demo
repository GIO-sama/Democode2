function renderExpenses() {
  const el    = document.getElementById('l-exp-list');
  const empty = document.getElementById('l-exp-empty');
  const breakdown = document.getElementById('l-exp-breakdown');
  const total = state.expenses.reduce((s,e)=>s+Number(e.amount),0);
  document.getElementById('l-exp-total').innerHTML = `₱<span>${total.toLocaleString()}</span>`;

  if(!state.expenses.length) {
    el.innerHTML='';
    empty.classList.remove('hidden');
    if(breakdown) breakdown.style.display='none';
    return;
  }
  empty.classList.add('hidden');

  // Build category totals
  if(breakdown) {
    const cats = {};
    state.expenses.forEach(e => {
      // Strip icon HTML to get clean category label
      const label = e.cat.replace(/<[^>]+>/g,'').trim();
      cats[label] = (cats[label]||0) + Number(e.amount);
    });
    const catEntries = Object.entries(cats).sort((a,b)=>b[1]-a[1]);
    const barMax = catEntries[0]?.[1] || 1;
    breakdown.style.display = '';
    breakdown.innerHTML = `
      <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--r-lg);padding:15px 16px;box-shadow:var(--sh-xs);">
        <div class="slbl" style="margin-bottom:12px">By Category</div>
        ${catEntries.map(([label, amt]) => `
          <div style="margin-bottom:10px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
              <span style="font-size:12px;font-weight:700;color:var(--text2);">${label}</span>
              <span style="font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);">₱${amt.toLocaleString()}</span>
            </div>
            <div style="height:6px;background:var(--warm2);border-radius:3px;overflow:hidden;">
              <div style="height:100%;width:${Math.round(amt/barMax*100)}%;background:var(--blue);border-radius:3px;transition:width .4s ease;"></div>
            </div>
          </div>`).join('')}
      </div>`;
  }

  el.innerHTML = state.expenses.map(e=>`
    <div class="exp-item" style="align-items:center">
      <div class="exp-left" style="flex:1">
        <div><div class="exp-name">${e.desc}</div><div class="exp-cat">${e.cat}</div><div class="exp-date">${e.date}</div></div>
      </div>
      <div style="display:flex;align-items:center;gap:10px">
        <div class="exp-amt">-₱${Number(e.amount).toLocaleString()}</div>
        <button onclick="deleteExpense(${e.id})" style="background:var(--redBg);border:none;border-radius:8px;padding:6px 8px;cursor:pointer;color:var(--red);font-size:13px;display:flex;align-items:center;">
          <i class="ph ph-trash"></i>
        </button>
      </div>
    </div>`).join('');
}

function deleteExpense(id) {
  state.expenses = state.expenses.filter(e=>e.id!==id);
  save(); renderExpenses(); showToast('Expense removed');
}

function addExpense() {
  const cat = document.getElementById('exp-cat').value;
  const desc = document.getElementById('exp-desc').value.trim();
  const amt = document.getElementById('exp-amt').value;
  const date = document.getElementById('exp-date').value;
  if(!desc||!amt) { showToast('Please fill in all fields'); return; }
  state.expenses.unshift({id:state.nextId++,cat,desc,amount:Number(amt),date});
  save();
  closeExpenseModal();
  renderExpenses();
  showToast('Expense logged ');
}

