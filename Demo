let _adminRegFilter = 'landlords';
function filterAdminRegistry(f, btn) {
  _adminRegFilter = f;
  document.querySelectorAll('#a-registry .a-btn').forEach(b=>{ b.style.background='var(--warm2)'; b.style.color='var(--navy)'; b.style.border='1px solid var(--border)'; });
  if (btn) { btn.style.background='rgba(255,107,107,.2)'; btn.style.color='#ff6b6b'; btn.style.border='1px solid rgba(255,107,107,.3)'; }
  renderAdminRegistry();
}
function renderAdminRegistry() {
  const list = document.getElementById('a-registry-list');
  if (!list) return;
  if (_adminRegFilter==='landlords') {
    list.innerHTML = state.houses.map(h => {
      const lp = h.id===1 ? profiles.landlord : {};
      const occ = h.rooms.filter(r=>r.status!=='empty').length;
      return `<div class="a-row">
        <div class="a-row-top"><div><div class="a-row-name">${lp.name||h.name.split(' ')[0]}</div><div class="a-row-sub">${h.name} · ${lp.phone||'—'}</div></div>
        <span class="a-pill ${h.adminStatus==='suspended'?'a-pill-suspended':'a-pill-active'}">${h.adminStatus==='suspended'?'Suspended':'Active'}</span></div>
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;">GCash: ${lp.gcash||'—'} · ${occ}/${h.rooms.length} rooms occupied</div>
        <div class="a-row-actions">
          <button class="a-btn a-btn-flag"    onclick="adminFlagUser('landlord',${h.id})"><i class="ph ph-flag"></i> Flag</button>
          <button class="a-btn a-btn-suspend" onclick="adminListingAction(${h.id},'suspend')"><i class="ph ph-prohibit"></i> Suspend</button>
        </div></div>`;
    }).join('');
  } else if (_adminRegFilter==='tenants') {
    const active = state.pendingTenants.filter(t=>t.status==='active');
    if (!active.length) { list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;">No active tenants yet.</div>'; return; }
    list.innerHTML = active.map(t => {
      const h = state.houses.find(x=>x.id===t.houseId);
      return `<div class="a-row">
        <div class="a-row-top"><div><div class="a-row-name">${t.name}</div><div class="a-row-sub">${t.room} · ${h?.name||'—'}</div></div><span class="a-pill a-pill-active">Active</span></div>
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;">Phone: ${t.phone||'—'}</div>
        <div class="a-row-actions">
          <button class="a-btn a-btn-flag"  onclick="adminFlagUser('tenant',${t.id})"><i class="ph ph-flag"></i> Flag</button>
          <button class="a-btn a-btn-reset" onclick="adminResetTenantCode(${t.id})"><i class="ph ph-arrow-counter-clockwise"></i> Reset Code</button>
        </div></div>`;
    }).join('');
  } else {
    const pending = state.pendingTenants.filter(t=>t.status==='pending');
    if (!pending.length) { list.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted);font-size:13px;">No pending codes.</div>'; return; }
    list.innerHTML = pending.map(t => {
      const h = state.houses.find(x=>x.id===t.houseId);
      return `<div class="a-row">
        <div class="a-row-top"><div><div class="a-row-name">${t.name}</div><div class="a-row-sub">${t.room} · ${h?.name||'—'}</div></div><span class="a-pill a-pill-pending">Pending</span></div>
        <div style="font-size:12px;color:var(--blue);font-family:'Nunito',sans-serif;font-weight:800;letter-spacing:2px;margin-bottom:8px;">${t.code}</div>
        <div class="a-row-actions">
          <button class="a-btn a-btn-reset"   onclick="adminResetTenantCode(${t.id})"><i class="ph ph-arrow-counter-clockwise"></i> Regenerate</button>
          <button class="a-btn a-btn-suspend" onclick="adminRevokeTenantCode(${t.id})"><i class="ph ph-x"></i> Revoke</button>
        </div></div>`;
    }).join('');
  }
}
function adminFlagUser(type,id) { adminLog(`Flagged ${type} ID:${id}`); showToast('<i class="ph ph-flag"></i> Flagged for review'); }
function adminResetTenantCode(id) {
  const t = state.pendingTenants.find(x=>x.id===id);
  if (!t) return;
  t.code=String(Math.floor(100000+Math.random()*900000)); t.status='pending';
  save(); renderAdminRegistry(); showToast(`New code for ${t.name}: ${t.code}`);
}
function adminRevokeTenantCode(id) {
  state.pendingTenants = state.pendingTenants.filter(x=>x.id!==id);
  save(); renderAdminRegistry(); showToast('Invite code revoked');
}

