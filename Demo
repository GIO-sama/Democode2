    threadEl.innerHTML = msgs.map(m => {
      const isSeeker = m.from === 'me';
      return `<div style="display:flex;flex-direction:column;align-items:${isSeeker ? 'flex-start' : 'flex-end'};">
        <div style="font-size:9px;font-family:'Nunito',sans-serif;font-weight:800;color:var(--muted);margin-bottom:3px;letter-spacing:.3px;text-transform:uppercase;">
