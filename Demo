// FIX 20: LOCALSTORAGE CORRUPTION RECOVERY
// Wrap load() with graceful fallback — corrupt state shows a recovery banner
// instead of a silent crash or blank screen
// ════════════════════════════════════════
function loadSafe() {
  try {
    const raw = localStorage.getItem('bb_state');
    if (!raw) return;
    const d = JSON.parse(raw);
    if (d.inquiries)       state.inquiries       = d.inquiries;
    if (d.announcements)   state.announcements   = d.announcements;
    if (d.maintenanceRequests) state.maintenanceRequests = d.maintenanceRequests;
    if (d.expenses)        state.expenses        = d.expenses;
    if (d.myInquiries)     state.myInquiries     = d.myInquiries;
    if (d.myMaintenanceRequests) state.myMaintenanceRequests = d.myMaintenanceRequests;
    if (d.nextId)          state.nextId          = d.nextId;
    if (d.houses) {
      d.houses.forEach(dh => {
        const sh = state.houses.find(h => h.id === dh.id);
        if (sh) {
          sh.rooms        = dh.rooms        || sh.rooms;
          sh.waitlist     = dh.waitlist     || sh.waitlist;
          // Restore listing-editor fields
          if (dh.name)        sh.name        = dh.name;
          if (dh.address)     sh.address     = dh.address;
          if (dh.price)       sh.price       = dh.price;
          if (dh.curfew)      sh.curfew      = dh.curfew;
          if (dh.gradient)    sh.gradient    = dh.gradient;
          if (dh.about)       sh.about       = dh.about;
          if (dh.snapshots)   sh.snapshots   = dh.snapshots;
          if (dh.customRules) sh.customRules = dh.customRules;
          if (dh.amenities)   sh.amenities   = dh.amenities;
          if (dh.distanceEVSU) sh.distanceEVSU = dh.distanceEVSU;
          if (dh.distanceBCC)  sh.distanceBCC  = dh.distanceBCC;
          if (dh.rules)       Object.assign(sh.rules, dh.rules);
        }
      });
    }
    if (d.visits)              state.visits              = d.visits;
    if (d.pendingTenants)      state.pendingTenants      = d.pendingTenants;
    if (d.tenantProfile)       state.tenantProfile       = d.tenantProfile;
    if (d.seekerProfile)       state.seekerProfile       = d.seekerProfile;
    if (d.visitSlots)          state.visitSlots          = d.visitSlots;
    if (d.paymentLog)          state.paymentLog          = d.paymentLog;
  if (d.paymentTransactions) state.paymentTransactions = d.paymentTransactions;
  if (d.uploadLog)           state.uploadLog           = d.uploadLog;
    if (d.savedHouses)         state.savedHouses         = d.savedHouses;
    if (d.moveOutRequests)     state.moveOutRequests     = d.moveOutRequests;
    if (d.platformAnnouncements) state.platformAnnouncements = d.platformAnnouncements;
    if (d.adminActivityLog !== undefined) state.adminActivityLog = d.adminActivityLog;
    if (d.maintenanceMode !== undefined) state.maintenanceMode = d.maintenanceMode;
    if (d.sort)                state.sort                = d.sort;
    if (d.referrals)           state.referrals           = d.referrals;
    // Restore adminStatus and adminVerified on houses from saved data
    if (d.houses) {
      d.houses.forEach(dh => {
        const sh = state.houses.find(h => h.id === dh.id);
        if (sh) {
          if (dh.adminStatus  !== undefined) sh.adminStatus  = dh.adminStatus;
          if (dh.adminVerified !== undefined) sh.adminVerified = dh.adminVerified;
          if (dh.adminNotes   !== undefined) sh.adminNotes   = dh.adminNotes;
        }
      });
    }
  } catch(e) {
    console.warn('[BB] localStorage parse failed — using defaults:', e.message);
    try { localStorage.setItem('bb_last_error', JSON.stringify({type:'parse', msg:e.message, ts:Date.now()})); } catch(_){}
    setTimeout(() => { showToast('Data restored from defaults — you can continue normally'); }, 800);
  }
}
