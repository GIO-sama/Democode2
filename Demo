function renderSeekerProfile() {
  const p = profiles.seeker;
  const el = (id,v)=>{ const e=document.getElementById(id); if(e) e.textContent=v; };
  el('sp-name',     p.name||'—');
  el('sp-school',   (p.school||'—') + (p.course ? ' · '+p.course : ''));
  el('sp-budget',   p.budget ? '₱'+p.budget.toLocaleString() : '—');
  el('sp-school-pref', p.school||'—');
  el('sp-wifi',     p.wifi     ? 'Required'     : 'Not required');
  el('sp-cooking',  p.cooking  ? 'Required'     : 'Not required');
  el('sp-visitors', p.visitors ? 'Required'     : 'Not required');
  el('sp-phone',    p.phone||'—');
  el('sp-course',   p.course||'—');
  el('sp-since',    p.created||'2025');
  el('sp-inq-count',   state.myInquiries ? state.myInquiries.length : 0);
  el('sp-visit-count', state.visits ? state.visits.filter(v => v.name === 'You').length : 0);
  // Count houses where seeker is on waitlist (check waitlist arrays for seeker's name)
  const seekerName = (p.name||'').toLowerCase();
  const wlCount = seekerName
    ? state.houses.reduce((n, h) => n + (h.waitlist||[]).filter(w => w.toLowerCase()===seekerName).length, 0)
    : 0;
  el('sp-wl-count', wlCount);
  // Photo or emoji
  setAvatarEl('sp-avatar-img','sp-avatar-emoji', p.photo, p.avatar||'<i class="ph ph-graduation-cap"></i>');
  // Optional fields
  const gRow = document.getElementById('sp-gender-row');
  if(gRow) { gRow.style.display = p.gender ? '' : 'none'; el('sp-gender', p.gender||''); }
  const bRow = document.getElementById('sp-bday-row');
  if(bRow) {
    bRow.style.display = p.birthday ? '' : 'none';
    if(p.birthday) {
      const d = new Date(p.birthday);
      el('sp-birthday', d.toLocaleDateString('en-PH',{year:'numeric',month:'long',day:'numeric'}));
    }
  }
  const bioRow = document.getElementById('sp-bio-row');
  if(bioRow) { bioRow.style.display = p.bio ? '' : 'none'; el('sp-bio', p.bio||''); }
  renderSeekerVisits();
}

