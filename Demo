function toggleSaved(id) {
  const idx = state.savedHouses.indexOf(id);
  if (idx === -1) {
    state.savedHouses.push(id);
    showToast('<i class="ph ph-heart-fill" style="color:#E11D48"></i> Saved to your shortlist');
  } else {
    state.savedHouses.splice(idx, 1);
    showToast('Removed from saved');
  }
  save();
  // Update heart icon in place without full re-render
  const btn = document.getElementById('heart-' + id);
  if (btn) {
    const saved = state.savedHouses.includes(id);
    btn.classList.toggle('saved', saved);
    btn.innerHTML = saved
      ? '<i class="ph ph-heart-fill"></i>'
      : '<i class="ph ph-heart"></i>';
  }
  // If we are on the saved screen, refresh it
  const cur = document.querySelector('.screen.active');
  if (cur && cur.id === 's-saved') renderSaved();
}

function renderSaved() {
  const list  = document.getElementById('saved-list');
  const empty = document.getElementById('saved-empty');
  if (!list) return;

  const saved = state.savedHouses.map(id => state.houses.find(h => h.id === id)).filter(Boolean);

