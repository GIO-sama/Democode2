function renderAnalytics() {
  const body = document.getElementById('l-analytics-body');
  if (!body) return;

  const h = state.houses.find(x => x.id === (state.currentHouseId || state.houses[0]?.id)) || state.houses[0];
  if (!h) { body.innerHTML = '<div style="text-align:center;padding:60px 20px;color:var(--muted);">No house found.</div>'; return; }

  const rooms        = h.rooms || [];
  const tenants      = state.pendingTenants.filter(t => t.houseId === h.id && t.status === 'active');
  const totalRooms   = rooms.length;
  const paidRooms    = rooms.filter(r => r.status === 'paid' || r.status === 'self_reported').length;
  const pendRooms    = rooms.filter(r => r.status === 'pending').length;
  const emptyRooms   = rooms.filter(r => r.status === 'empty').length;
  const occupancy    = totalRooms > 0 ? Math.round((paidRooms + pendRooms) / totalRooms * 100) : 0;
  const monthlyTarget= h.price * totalRooms;
  const collected    = h.price * paidRooms;
  const uncollected  = h.price * pendRooms;
  const vacancyCost  = h.price * emptyRooms;
  const riceBags     = Math.round(vacancyCost / 275); // ~55kg sack
  const expenses     = (state.expenses || []).filter(e => !e.houseId || e.houseId === h.id);
  const totalExp     = expenses.reduce((s,e) => s + (e.amount||0), 0);
  const netIncome    = collected - totalExp;
  const inquiries    = (state.inquiries || []).filter(i => i.houseId === h.id);
  const now          = new Date();
  const thisMonth    = now.getMonth();
  const thisYear     = now.getFullYear();
  const inqThisMo    = inquiries.filter(i => { const d=new Date(i.date||0); return d.getMonth()===thisMonth&&d.getFullYear()===thisYear; }).length;
  const waitCount    = (h.waitlist||[]).length;
  const collRate     = tenants.length > 0 ? Math.round(paidRooms / tenants.length * 100) : 100;

  const latePatterns = tenants.filter(t => {
    if (!t.moveInDate) return false;
    const r = rooms.find(rm => rm.name === t.room);
    if (!r || r.status !== 'pending') return false;
    return Math.round((Date.now() - new Date(t.moveInDate)) / (30*86400000)) >= 3;
  });

  const semEnds = [new Date(now.getFullYear(),5,30), new Date(now.getFullYear(),11,20)];
  const expiringTenants = tenants.filter(t => {
    if (!t.moveInDate) return false;
    return semEnds.some(end => { const d=Math.round((end-now)/86400000); return d>=0&&d<=45; });
  });

  const bccDate  = new Date(now.getFullYear()+(now.getMonth()>=5?1:0),4,1);
  const evsuDate = new Date(now.getFullYear()+(now.getMonth()>=8?1:0),7,1);
  const daysToBCC  = Math.max(0, Math.round((bccDate-now)/86400000));
  const daysToEVSU = Math.max(0, Math.round((evsuDate-now)/86400000));

  // ── Helpers ────────────────────────────────
  const big = (val, label, color='var(--navy)', sub='') => `
    <div style="text-align:center;padding:14px 8px;">
      <div style="font-family:'Nunito',sans-serif;font-size:28px;font-weight:900;color:${color};line-height:1;">${val}</div>
      <div style="font-size:12px;color:var(--muted);margin-top:4px;font-weight:600;">${label}</div>
      ${sub ? `<div style="font-size:11px;color:var(--muted2);margin-top:2px;">${sub}</div>` : ''}
    </div>`;

  const tipBar = (label, value, max, color, tip, action='') => {
    const pct = Math.min(100, Math.round(value/Math.max(max,1)*100));
    return `
    <div style="margin-bottom:16px;">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
        <span style="font-size:14px;font-weight:700;color:var(--text);">${label}</span>
        <span style="font-family:'Nunito',sans-serif;font-size:16px;font-weight:900;color:${color};">${value}</span>
      </div>
      <div style="height:8px;background:var(--border);border-radius:4px;overflow:hidden;margin-bottom:6px;">
        <div style="height:100%;width:${pct}%;background:${color};border-radius:4px;transition:width .6s ease;"></div>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:12px;color:var(--muted);">${tip}</span>
        ${action}
      </div>
    </div>`;
  };

  const sectionHdr = (icon, title) => `
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;">
      <div style="width:32px;height:32px;background:var(--blueLt);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="ph ${icon}" style="font-size:16px;color:var(--blue);"></i>
      </div>
      <span style="font-family:'Nunito',sans-serif;font-size:15px;font-weight:900;color:var(--navy);">${title}</span>
    </div>`;

  const card = (content, accent='var(--border)') => `
    <div style="background:var(--card);border:1.5px solid ${accent};border-radius:16px;padding:18px;margin-bottom:16px;">
      ${content}
    </div>`;

  const actionBtn = (label, onclick, color='var(--blue)') => `
    <button onclick="${onclick}" style="background:${color}18;color:${color};border:1.5px solid ${color}30;border-radius:8px;padding:6px 14px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;cursor:pointer;white-space:nowrap;">${label}</button>`;

  body.innerHTML = `

  <!-- ═══ 1. SNAPSHOT ═══ -->
  ${card(`
    ${sectionHdr('ph-lightning', 'Monthly Overview')}
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;border-top:1px solid var(--border);margin:-2px -2px 14px;">
      ${big('₱' + collected.toLocaleString(), 'Collected', 'var(--green)')}
      ${big('₱' + uncollected.toLocaleString(), 'Uncollected', uncollected > 0 ? 'var(--amber)' : 'var(--muted)')}
      ${big(paidRooms+pendRooms+'/'+totalRooms, 'Occupied', occupancy>=80?'var(--green)':occupancy>=50?'var(--amber)':'var(--red)')}
    </div>
    ${tipBar('Occupancy rate', occupancy+'%', 100,
      occupancy>=80?'var(--green)':occupancy>=50?'var(--amber)':'var(--red)',
      occupancy>=80 ? 'Great! Almost full.' : emptyRooms + ' room(s) vacant right now',
      emptyRooms > 0 ? actionBtn('View Rooms', "goTo('l-rooms')") : ''
    )}
    ${vacancyCost > 0 ? `<div style="background:var(--amberBg);border:1px solid var(--amber);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;">
      <i class="ph ph-piggy-bank" style="font-size:24px;color:var(--amber);flex-shrink:0;"></i>
      <div>
        <div style="font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--amber);">You're losing ₱${vacancyCost.toLocaleString()} per month</div>
        <div style="font-size:12px;color:var(--text2);margin-top:2px;">Equal to ${riceBags} sacks of rice. Try posting a vacancy now.</div>
      </div>
    </div>` : ''}
  `, vacancyCost > 0 ? 'var(--amber)' : 'var(--green)')}

  <!-- ═══ 2. PAYMENT HEALTH ═══ -->
  ${card(`
    ${sectionHdr('ph-coins', 'Tenant Payments')}
    ${tipBar('Collection rate', collRate+'%', 100,
      collRate>=80?'var(--green)':collRate>=50?'var(--amber)':'var(--red)',
      paidRooms + ' of ' + tenants.length + ' tenant(s) paid',
      pendRooms > 0 ? actionBtn('Send Reminder', "goTo('l-reminder')", 'var(--amber)') : ''
    )}
    ${pendRooms > 0 ? `
    <div style="border-top:1px solid var(--border);padding-top:12px;margin-top:4px;">
      <div style="font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;color:var(--muted);margin-bottom:8px;text-transform:uppercase;letter-spacing:.4px;">Pending Payment</div>
      ${rooms.filter(r=>r.status==='pending').map(r=>`
        <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);">
          <div>
            <span style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);">${r.tenant||r.name}</span>
            <span style="font-size:12px;color:var(--muted);margin-left:6px;">${r.name}</span>
          </div>
          <span style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--amber);">₱${(r.amount||h.price).toLocaleString()}</span>
        </div>`).join('')}
    </div>` : `<div style="padding:8px 0;font-size:13px;color:var(--green);font-weight:700;"><i class="ph ph-check-circle"></i> All tenants have paid!</div>`}
    ${latePatterns.length ? `<div style="background:var(--redBg);border:1px solid rgba(192,57,43,.2);border-radius:10px;padding:12px 14px;margin-top:10px;">
      <div style="font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;color:var(--red);margin-bottom:4px;"><i class="ph ph-warning"></i> Late payment pattern: ${latePatterns.map(t=>t.name.split(' ')[0]).join(', ')}</div>
      <div style="font-size:12px;color:var(--text2);">Has been overdue for multiple months. Follow up to avoid issues.</div>
    </div>` : ''}
  `)}

  <!-- ═══ 3. DEMAND ═══ -->
  ${card(`
    ${sectionHdr('ph-trend-up', 'Demand & Popularity')}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
      <div style="background:var(--blueLt);border-radius:12px;padding:14px;text-align:center;">
        <div style="font-family:'Nunito',sans-serif;font-size:28px;font-weight:900;color:var(--blue);">${inqThisMo}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:4px;">Inquiries this month</div>
      </div>
      <div style="background:${waitCount>0?'var(--greenBg)':'var(--warm2)'};border-radius:12px;padding:14px;text-align:center;" id="wl-count-tile">
        <div style="font-family:'Nunito',sans-serif;font-size:28px;font-weight:900;color:${waitCount>0?'var(--green)':'var(--muted)'};">${waitCount}</div>
        <div style="font-size:12px;color:var(--muted);margin-top:4px;">On waitlist</div>
        ${waitCount>0 ? '<button onclick="goTo(\'l-waitlist\')" style="margin-top:8px;background:var(--green);color:#fff;border:none;border-radius:8px;padding:5px 14px;font-family:\'Nunito\',sans-serif;font-size:12px;font-weight:800;cursor:pointer;">View</button>' : ''}
      </div>
    </div>
    ${waitCount > 0 ? `<div style="font-size:13px;color:var(--text2);padding:10px 12px;background:var(--greenBg);border-radius:10px;"><i class="ph ph-lightbulb" style="color:var(--green);"></i> There are ${waitCount} waiting. Consider raising price by ₱${Math.round(h.price*0.05/50)*50} on the next vacancy.</div>` : ''}
  `)}

  <!-- ═══ 4. FINANCES ═══ -->
  ${card(`
    ${sectionHdr('ph-chart-bar', 'Income & Expenses')}
    ${tipBar('Income this month', '₱' + collected.toLocaleString(), monthlyTarget,
      'var(--teal)',
      Math.round(collected/Math.max(monthlyTarget,1)*100) + '% ng potential na ₱' + monthlyTarget.toLocaleString(),
      ''
    )}
    ${tipBar('Expenses (logged)', '₱' + totalExp.toLocaleString(), collected||1,
      totalExp > collected*0.5 ? 'var(--red)' : 'var(--muted)',
      expenses.length + ' entries logged',
      actionBtn('Add Expense', "goTo('l-expense')", 'var(--muted)')
    )}
    <div style="border-top:1.5px solid var(--border);padding-top:14px;margin-top:4px;display:flex;justify-content:space-between;align-items:center;">
      <div>
        <div style="font-size:13px;color:var(--muted);">Net income</div>
        <div style="font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;color:${netIncome>=0?'var(--green)':'var(--red)'};">₱${netIncome.toLocaleString()}</div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:13px;color:var(--muted);">Projected / year</div>
        <div style="font-family:'Nunito',sans-serif;font-size:18px;font-weight:800;color:var(--navy);">₱${(netIncome*12).toLocaleString()}</div>
      </div>
    </div>
  `)}

  <!-- ═══ 5. TENANT TURNOVER ═══ -->
  ${card(`
    ${sectionHdr('ph-arrows-counter-clockwise', 'Tenants & Move-in Dates')}
    ${rooms.filter(r=>r.status!=='empty').map(r => {
      const t = tenants.find(tn => tn.room === r.name);
      const days = t?.moveInDate ? Math.round((Date.now()-new Date(t.moveInDate))/86400000) : 0;
      const pct  = Math.min(100, Math.round(days/365*100));
      return `
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;">
          <span style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--navy);">${r.name} — ${r.tenant||'Tenant'}</span>
          <span style="font-size:12px;color:var(--muted);">${days>0?days+' days':'New'}</span>
        </div>
        <div style="height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
          <div style="height:100%;width:${pct}%;background:var(--blue);border-radius:3px;"></div>
        </div>
        <div style="font-size:11px;color:var(--muted2);margin-top:3px;">${t?.moveInDate?'Move-in: '+new Date(t.moveInDate).toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'}):'Move-in date not recorded'}</div>
      </div>`;
    }).join('') || '<div style="font-size:13px;color:var(--muted);text-align:center;padding:12px;">No active tenants.</div>'}
  `)}

  <!-- ═══ 6. LEASE EXPIRY ═══ -->
  ${card(`
    ${sectionHdr('ph-calendar-x', 'Watch Out: Leaving Soon?')}
    ${expiringTenants.length ? `
      <div style="background:var(--amberBg);border:1px solid var(--amber);border-radius:10px;padding:14px;margin-bottom:12px;">
        <div style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--amber);margin-bottom:6px;"><i class="ph ph-warning"></i> ${expiringTenants.length} tenant ang maaaring umalis of 45 days</div>
        ${expiringTenants.map(t=>`<div style="font-size:13px;color:var(--text2);padding:4px 0;">${t.name} · ${t.room}</div>`).join('')}
        <div style="margin-top:8px;">${actionBtn('Post vacancy now', "goTo('l-listing')", 'var(--amber)')}</div>
      </div>` : `
      <div style="background:var(--greenBg);border:1px solid var(--green);border-radius:10px;padding:14px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--green);margin-bottom:12px;">
        <i class="ph ph-check-circle"></i> No tenants leaving within 45 days
      </div>`}
  `)}

  <!-- ═══ 7. ENROLLMENT SEASON ═══ -->
  ${card(`
    ${sectionHdr('ph-calendar-blank', 'Enrollment Season')}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
      <div style="background:${daysToBCC<=30?'linear-gradient(135deg,var(--amber),#D97706)':'var(--card)'};border:1.5px solid ${daysToBCC<=30?'var(--amber)':'var(--border)'};border-radius:14px;padding:16px;text-align:center;">
        <div style="font-size:11px;font-weight:800;color:${daysToBCC<=30?'#fff':'var(--muted)'};letter-spacing:.4px;text-transform:uppercase;margin-bottom:6px;">BCC</div>
        <div style="font-family:'Nunito',sans-serif;font-size:32px;font-weight:900;color:${daysToBCC<=30?'#fff':'var(--navy)'};">${daysToBCC}</div>
        <div style="font-size:12px;color:${daysToBCC<=30?'rgba(255,255,255,.8)':'var(--muted)'};margin-top:4px;">days away · May</div>
      </div>
      <div style="background:${daysToEVSU<=30?'linear-gradient(135deg,var(--blue),#1558CC)':'var(--card)'};border:1.5px solid ${daysToEVSU<=30?'var(--blue)':'var(--border)'};border-radius:14px;padding:16px;text-align:center;">
        <div style="font-size:11px;font-weight:800;color:${daysToEVSU<=30?'#fff':'var(--muted)'};letter-spacing:.4px;text-transform:uppercase;margin-bottom:6px;">EVSU</div>
        <div style="font-family:'Nunito',sans-serif;font-size:32px;font-weight:900;color:${daysToEVSU<=30?'#fff':'var(--navy)'};">${daysToEVSU}</div>
        <div style="font-size:12px;color:${daysToEVSU<=30?'rgba(255,255,255,.8)':'var(--muted)'};margin-top:4px;">days away · August</div>
      </div>
    </div>
    <div style="background:var(--blueLt);border-radius:10px;padding:13px 14px;font-size:13px;color:var(--text2);line-height:1.5;">
      <i class="ph ph-lightbulb" style="color:var(--blue);"></i>
      ${daysToBCC<=45||daysToEVSU<=45 ? ' Enrollment is coming! Update your listing and make sure it is verified.' : ' No enrollment season in the next 45 days. Good time to do repairs and update your listing photos.'}
    </div>
  `)}
  `;
}



// ════════════════════════════════════════
// ROLE SELECT — helpers
// ════════════════════════════════════════
function showTenantChoice() {
  const bg = document.createElement('div');
  bg.id = 'tenant-choice-bg';
  bg.style.cssText = 'position:absolute;inset:0;background:rgba(11,31,58,.65);z-index:500;display:flex;align-items:flex-end;backdrop-filter:blur(4px);';
  bg.innerHTML = `<div style="background:var(--warm);border-radius:22px 22px 0 0;padding:26px 20px 36px;width:100%;">
    <div style="width:34px;height:3px;background:var(--border2);border-radius:2px;margin:0 auto 20px;"></div>
    <div style="font-family:'Nunito',sans-serif;font-size:18px;font-weight:900;color:var(--text);margin-bottom:6px;">I'm a Tenant</div>
    <div style="font-size:13px;color:var(--muted);margin-bottom:20px;">Already registered, or joining for the first time?</div>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <button onclick="document.getElementById('tenant-choice-bg').remove();setRole('tenant')" style="background:var(--teal);color:#fff;border:none;border-radius:var(--r);padding:16px;font-family:'Nunito',sans-serif;font-size:15px;font-weight:800;cursor:pointer;touch-action:manipulation;"><i class="ph ph-house"></i> I'm already registered</button>
      <button onclick="document.getElementById('tenant-choice-bg').remove();goTo('t-register')" style="background:var(--card);color:var(--teal);border:2px solid var(--teal);border-radius:var(--r);padding:16px;font-family:'Nunito',sans-serif;font-size:15px;font-weight:800;cursor:pointer;touch-action:manipulation;"><i class="ph ph-key"></i> I have an invite code</button>
      <button onclick="document.getElementById('tenant-choice-bg').remove()" style="background:transparent;color:var(--muted);border:none;padding:12px;font-family:'Nunito',sans-serif;font-size:14px;cursor:pointer;">Cancel</button>
    </div>
  </div>`;
  document.querySelector('.phone').appendChild(bg);
}

let _logoTapCount = 0, _logoTapTimer = null;
function handleLogoTap() {
  _logoTapCount++;
  clearTimeout(_logoTapTimer);
  _logoTapTimer = setTimeout(() => { _logoTapCount = 0; }, 800);
  if (_logoTapCount >= 3) {
    _logoTapCount = 0;
    const card = document.getElementById('role-admin-card');
    if (card) { card.classList.toggle('hidden'); showToast(card.classList.contains('hidden') ? 'Admin hidden' : '🔐 Admin revealed'); }
  }
}

function goToSeekerEntry() {
  state.role = 'seeker';
  navStack.length = 0;
  if (!profiles.seeker || !profiles.seeker.name) {
    profiles.seeker = { name:'Ana Santos', phone:'09171234567', school:'EVSU Burauen Campus', course:'BSIT 2nd Year', budget:1500, wifiRequired:true, cookingRequired:false, visitorsRequired:true, noCurfew:false, laundryRequired:true, photo:DEMO_PHOTOS.avatar1, showPhoto:true };
    saveProfiles();
  }
  goTo('s-home');
}

function goToLandlordEntry() {
  state.role = 'landlord';
  navStack.length = 0;
  goTo('l-home');
}
</script>
