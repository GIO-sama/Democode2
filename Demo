    actEl.innerHTML = `<button class="btn btn-navy" onclick="openWaitlist(${h.id})" style="flex:1">⏳ Join Waitlist (${h.waitlist.length} ahead)</button>`;
  } else {
    actEl.innerHTML = `
      <button class="btn btn-navy" onclick="goTo('s-inquiry')" style="flex:2">📝 Ask a Question</button>
      <button class="btn btn-ghost" onclick="goTo('s-visit')" style="flex:1">📅 Visit</button>`;
  }
