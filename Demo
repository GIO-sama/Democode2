function setInqStatus(status) {
  const inq = state.inquiries.find(i=>i.id===state.currentInqId);
  if(!inq) return;
  inq.status = status;
  save();

  // BRIDGE: "Offer Room" → auto-generate invite code for this seeker
  if(status === 'offered') {
    closeInqModal();
    const h = state.houses.find(x => x.id === inq.houseId);
    // Find an empty room
    const emptyRoom = (h?.rooms || []).find(r => r.status === 'empty');
    // Generate 6-digit invite code
    const code = String(Math.floor(100000 + Math.random() * 900000));
    // Pre-populate the tenant in pendingTenants
    state.pendingTenants.push({
      id: state.nextId++,
      name: inq.name,
      phone: '',
      room: emptyRoom ? emptyRoom.name : 'TBD',
      houseId: inq.houseId,
      code: code,
      status: 'pending'
    });
    save();
    // Show the invite code modal pre-filled
    document.getElementById('ic-code-display').textContent = code;
    document.getElementById('ic-room-display').textContent =
      (emptyRoom ? emptyRoom.name : 'Room') + ' — ' + (h?.name || 'Boarding House');
    document.getElementById('ic-modal-sub').textContent =
      'Share this code with ' + inq.name + ' — via text, Viber, or in person.';
    // Copy button
    const copyBtn = document.getElementById('ic-copy-btn');
    if(copyBtn) copyBtn.onclick = () => {
      navigator.clipboard?.writeText(code).catch(()=>{});
      showToast('Code copied: ' + code);
    };
    document.getElementById('modal-invite-code').classList.remove('hidden');
    renderLandlordInbox();
    renderLandlordHome();
    return;
  }

  closeInqModal();
  renderLandlordInbox();
  renderLandlordHome();
  showToast('Status updated ');
}

function sendInqReply() {
  const txt = document.getElementById('inq-reply-txt')?.value.trim();
  if(!txt) { showToast('Type a reply first'); return; }
  const inq = state.inquiries.find(i=>i.id===state.currentInqId);
  if(!inq) return;

  // Append to messages thread
  if (!inq.messages) inq.messages = [{ from:'me', text: inq.q||'(No question)', time: inq.time||'Earlier' }];
  const msg = { from:'them', text: txt, time: 'Just now' };
  inq.messages.push(msg);

  inq.reply  = txt;
  inq.status = 'replied';

  // Sync to seeker's myInquiries
  const mi = state.myInquiries.find(m=>m.id===inq.id);
  if(mi) {
    mi.reply  = txt;
    mi.status = 'replied';
    mi.read   = false; // unread for seeker
    if (!mi.messages) mi.messages = [...inq.messages];
    else mi.messages.push(msg);
  }
  save();

  // Re-render thread inside modal so landlord sees their own reply immediately
  const threadEl = document.getElementById('inq-thread-history');
  if (threadEl) {
    const newBubble = document.createElement('div');
    newBubble.style.cssText = 'display:flex;flex-direction:column;align-items:flex-end;';
    newBubble.innerHTML = `
      <div style="font-size:9px;font-family:'Nunito',sans-serif;font-weight:800;color:var(--muted);margin-bottom:3px;letter-spacing:.3px;text-transform:uppercase;">You</div>
      <div style="max-width:85%;padding:9px 12px;border-radius:12px;border-top-right-radius:3px;font-size:13px;line-height:1.5;background:var(--navy);color:#fff;">${txt}</div>
      <div style="font-size:10px;color:var(--muted2);margin-top:2px;">Just now</div>`;
    threadEl.appendChild(newBubble);
    threadEl.scrollTop = threadEl.scrollHeight;
  }

  document.getElementById('inq-reply-txt').value = '';
  renderLandlordInbox();
  showToast('<i class="ph ph-paper-plane-tilt"></i> Reply sent');
}

