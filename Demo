// ILLUSTRATED MAP
// ════════════════════════════════════════
let activeMapHouseId = null;

function openMapCard(id) {
  const h = state.houses.find(x => x.id === id);
  if (!h) return;
  activeMapHouseId = id;

  const avail = h.rooms.filter(r => r.status === 'empty').length;
  const set = (elId, v) => { const e = document.getElementById(elId); if (e) e.textContent = v; };

  // Hero
  const hero = document.getElementById('msh-hero');
  if (hero) hero.style.background = h.gradient;
  set('msh-name',   h.name);
  set('msh-addr',   h.address);
  set('msh-price',  '₱' + h.price.toLocaleString() + '/mo');
  set('msh-avail-rooms', avail > 0 ? avail : 'Full');
  set('msh-curfew', h.curfew === 'No curfew' ? 'None' : h.curfew);
  set('msh-devsu',  h.distanceEVSU);
  set('msh-dbcc',   h.distanceBCC);

  const availEl = document.getElementById('msh-avail');
  if (availEl) {
    if (avail > 0) {
      availEl.textContent = avail + ' slot' + (avail > 1 ? 's' : '') + ' open';
      availEl.style.background = 'rgba(34,197,94,.4)';
      availEl.style.borderColor = 'rgba(34,197,94,.5)';
    } else {
      availEl.textContent = 'Full · Waitlist';
      availEl.style.background = 'rgba(239,68,68,.35)';
      availEl.style.borderColor = 'rgba(239,68,68,.4)';
    }
  }

  // Highlight the active pin
  document.querySelectorAll('.bh-pin-btn').forEach(el => el.classList.remove('highlighted'));
  const pin = document.getElementById('map-pin-' + id);
  if (pin) pin.classList.add('highlighted');

  // Open overlay
  document.getElementById('map-overlay').classList.add('active');
}

function closeMapCard() {
  document.getElementById('map-overlay').classList.remove('active');
  document.querySelectorAll('.bh-pin-btn').forEach(el => el.classList.remove('highlighted'));
  activeMapHouseId = null;
}

function handleOverlayClick(e) {
  // Close only if backdrop was clicked, not the sheet itself
  if (e.target === document.getElementById('map-overlay') ||
      e.target.classList.contains('map-sheet-backdrop')) {
    closeMapCard();
  }
}

function mapGoDetail() {
  if (!activeMapHouseId) return;
  state.currentHouseId = activeMapHouseId;
  closeMapCard();
  goTo('s-detail');
}

function mapGoInquiry() {
  if (!activeMapHouseId) return;
  state.currentHouseId = activeMapHouseId;
  closeMapCard();
  goTo('s-inquiry');
}

function mapHighlight(school, btn) {
  document.querySelectorAll('.map-spill').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');

  state.houses.forEach(h => {
    const pin = document.getElementById('map-pin-' + h.id);
    if (!pin) return;
    let show = true;
    if (school === 'evsu')     show = h.distanceEVSU <= 8;
    else if (school === 'bcc') show = h.distanceBCC  <= 8;
    pin.style.opacity    = show ? '1' : '0.28';
    pin.style.transition = 'opacity .25s';
  });

  closeMapCard();
}

// _activateScreen is used internally by goTo / goBack

