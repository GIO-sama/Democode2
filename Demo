// FIX 19: GLOBAL ERROR BOUNDARY
// Masterplan v2: "Any runtime exception produces a blank white screen.
// This is unacceptable for non-tech users who will interpret it as permanent damage."
// ════════════════════════════════════════
window.addEventListener('error', function(evt) {
  console.error('[BB Error]', evt.message, evt.filename, evt.lineno);
  const errBanner = document.getElementById('error-recovery-banner');
  if (errBanner) return; // already shown
  const banner = document.createElement('div');
  banner.id = 'error-recovery-banner';
  banner.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);width:calc(100% - 32px);max-width:398px;background:#FEF2F2;border:1px solid #FCA5A5;border-radius:14px;padding:14px 16px;z-index:500;box-shadow:0 4px 20px rgba(0,0,0,.12);display:flex;align-items:center;gap:12px;';
  banner.innerHTML = `
    <div style="width:36px;height:36px;background:#FEE2E2;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <i class="ph ph-warning" style="font-size:18px;color:#EF4444;"></i>
    </div>
    <div style="flex:1;">
      <div style="font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:#991B1B;">Something went wrong</div>
      <div style="font-size:12px;color:#7F1D1D;margin-top:2px;">Tap Refresh to continue normally.</div>
    </div>
    <div style="display:flex;flex-direction:column;gap:6px;">
      <button onclick="location.reload()" style="background:#EF4444;color:#fff;border:none;border-radius:8px;padding:7px 12px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;cursor:pointer;white-space:nowrap;">Refresh</button>
      <button onclick="this.closest('#error-recovery-banner').remove()" style="background:transparent;color:#9CA3AF;border:none;font-size:11px;cursor:pointer;">Dismiss</button>
    </div>`;
  document.body.appendChild(banner);
  setTimeout(() => { const b = document.getElementById('error-recovery-banner'); if(b) b.remove(); }, 8000);
});

// ════════════════════════════════════════
// FIX 20: LOCALSTORAGE CORRUPTION RECOVERY
// Wrap load() with graceful fallback — corrupt state shows a recovery banner
// instead of a silent crash or blank screen
// ════════════════════════════════════════
function loadSafe() {
  try {
    const raw = localStorage.getItem('bb_state');
    if (!raw) return; // no saved state — fresh start, fine
    const d = JSON.parse(raw); // can throw if corrupted
    if (d.inquiries)       state.inquiries       = d.inquiries;
    if (d.announcements)   state.announcements   = d.announcements;
    if (d.maintenanceRequests) state.maintenanceRequests = d.maintenanceRequests;
    if (d.expenses)        state.expenses        = d.expenses;
    if (d.myInquiries)     state.myInquiries     = d.myInquiries;
    if (d.myMaintenanceRequests) state.myMaintenanceRequests = d.myMaintenanceRequests;
    if (d.nextId)          state.nextId          = d.nextId;
    if (d.houses) {
      d.houses.forEach(dh => {
        const sh = state.houses.find(h => h.id === dh.id);
        if (sh) { sh.rooms = dh.rooms; sh.waitlist = dh.waitlist; }
      });
    }
    if (d.visits)          state.visits          = d.visits;
    if (d.pendingTenants)  state.pendingTenants  = d.pendingTenants;
    if (d.tenantProfile)   state.tenantProfile   = d.tenantProfile;
    if (d.seekerProfile)   state.seekerProfile   = d.seekerProfile;
    if (d.visitSlots)      state.visitSlots      = d.visitSlots;
  } catch(e) {
    console.warn('[BB] localStorage parse failed — using defaults:', e.message);
    // Log to error store for debugging
    try { localStorage.setItem('bb_last_error', JSON.stringify({type:'parse', msg:e.message, ts:Date.now()})); } catch(_){}
    // Show recovery notice after a short delay (so DOM is ready)
    setTimeout(() => {
      showToast('Data restored from defaults — you can continue normally');
    }, 800);
  }
}
// Replace the old load() call at startup
loadSafe();




