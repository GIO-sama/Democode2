function renderAdminFinOverview(body) {
  const totalRev  = state.houses.reduce((s,h)=>s+(h.rooms||[]).filter(r=>r.status!=='empty').reduce((rs,r)=>rs+r.amount,0),0);
  const totalExp  = state.expenses.reduce((s,e)=>s+Number(e.amount),0);
  const net       = totalRev-totalExp;
  const occ       = Math.round(state.houses.reduce((s,h)=>s+(h.rooms||[]).filter(r=>r.status!=='empty').length,0)/Math.max(1,state.houses.reduce((s,h)=>s+(h.rooms||[]).length,0))*100);
  const houseRows = state.houses.map(h=>({ name:h.name, rev:(h.rooms||[]).filter(r=>r.status!=='empty').reduce((s,r)=>s+r.amount,0), occ:(h.rooms||[]).filter(r=>r.status!=='empty').length, total:(h.rooms||[]).length })).sort((a,b)=>b.rev-a.rev);
  const maxRev    = houseRows[0]?.rev||1;
  const inqByHouse= state.houses.map(h=>({ name:h.name, count:state.inquiries.filter(i=>i.houseId===h.id).length })).sort((a,b)=>b.count-a.count);
  const maxInq    = inqByHouse[0]?.count||1;
  const confirmedTxs = (state.paymentTransactions||[]).filter(t=>t.status==='confirmed');
