function toggleAnnEdit(id) {
  const area = document.getElementById('ann-edit-' + id);
  if (!area) return;
  area.classList.toggle('open');
  // Focus title field when opening
  if (area.classList.contains('open')) {
    setTimeout(() => document.getElementById('ann-edit-t-' + id)?.focus(), 50);
  }
}

function saveAnnEdit(id) {
  const a = state.announcements.find(x => x.id === id);
  if (!a) return;
  const newTitle = document.getElementById('ann-edit-t-' + id)?.value.trim();
  const newBody  = document.getElementById('ann-edit-b-' + id)?.value.trim();
  if (!newTitle || !newBody) { showToast('Title and message cannot be empty'); return; }
  a.title = newTitle;
  a.body  = newBody;
  a.ts    = Date.now(); // refresh timestamp on edit
  a.isNew = true;       // re-notify tenants of the update
  save();
  renderAnnouncements();
  renderTenantHome();   // sync tenant view
  showToast('<i class="ph ph-pencil-simple"></i> Announcement updated');
}

function toggleAnnPin(id) {
  const a = state.announcements.find(x => x.id === id);
  if (!a) return;
  a.pinned = !a.pinned;
  save();
  renderAnnouncements();
  showToast(a.pinned ? '<i class="ph ph-push-pin"></i> Pinned' : 'Unpinned');
}

