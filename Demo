  const occupiedRooms = state.houses.reduce((s,h) => s+h.rooms.filter(r=>r.status!=='empty').length, 0);
  const totalInq      = state.inquiries.length;
  const pendingInq    = state.inquiries.filter(i=>i.status==='pending').length;
  const totalTenants  = state.pendingTenants.filter(t=>t.status==='active').length;
  const pendingVerif  = state.houses.filter(h=>h.adminStatus==='pending').length;
  const revenue       = state.houses.reduce((s,h) => s+h.rooms.filter(r=>r.status!=='empty').reduce((rs,r)=>rs+r.amount,0), 0);

  const grid = document.getElementById('a-stats-grid');
  if (grid) grid.innerHTML = `
    <div class="a-stat accent-blue"><div class="a-stat-val">${totalHouses}</div><div class="a-stat-lbl">Total Listings</div><div class="a-stat-sub">${activeHouses} active</div></div>
    <div class="a-stat accent-green"><div class="a-stat-val">${occupiedRooms}</div><div class="a-stat-lbl">Rooms Occupied</div><div class="a-stat-sub">of ${totalRooms} total</div></div>
    <div class="a-stat accent-amber"><div class="a-stat-val">${totalInq}</div><div class="a-stat-lbl">Total Inquiries</div><div class="a-stat-sub">${pendingInq} pending</div></div>
    <div class="a-stat accent-red"><div class="a-stat-val">${totalTenants}</div><div class="a-stat-lbl">Active Tenants</div><div class="a-stat-sub">${state.pendingTenants.filter(t=>t.status==='pending').length} pending reg.</div></div>`;

  const health = document.getElementById('a-health-card');
  const urgentMaint = state.maintenanceRequests.filter(r=>r.urgency==='urgent'&&r.status!=='done').length;
  const openMaint   = state.maintenanceRequests.filter(r=>r.status!=='done').length;
  const fullHouses  = state.houses.filter(h=>h.rooms.every(r=>r.status!=='empty')).length;
  if (health) health.innerHTML = `<div class="slbl" style="margin-bottom:12px;">Platform Health</div>
    ${pendingVerif>0?`<div class="a-activity-item"><i class="ph ph-seal-question" style="font-size:16px;color:var(--amber);flex-shrink:0;margin-top:1px;"></i><div class="a-activity-txt" style="color:var(--amber);">${pendingVerif} listing${pendingVerif!==1?'s':''} awaiting verification</div></div>`:''}
    ${urgentMaint>0?`<div class="a-activity-item"><i class="ph ph-siren" style="font-size:16px;color:var(--red);flex-shrink:0;margin-top:1px;"></i><div class="a-activity-txt" style="color:var(--red);">${urgentMaint} urgent maintenance request${urgentMaint!==1?'s':''}</div></div>`:''}
    <div class="a-activity-item"><i class="ph ph-wrench" style="font-size:16px;color:var(--amber);flex-shrink:0;margin-top:1px;"></i><div class="a-activity-txt">${openMaint} open maintenance issue${openMaint!==1?'s':''}</div></div>
    <div class="a-activity-item"><i class="ph ph-house" style="font-size:16px;color:var(--muted);flex-shrink:0;margin-top:1px;"></i><div class="a-activity-txt">${fullHouses} of ${totalHouses} houses full</div></div>`;

  const revEl = document.getElementById('a-revenue');
  const revSub = document.getElementById('a-revenue-sub');
  if (revEl)  revEl.textContent  = '₱' + revenue.toLocaleString();
  if (revSub) revSub.textContent = `across ${occupiedRooms} occupied rooms in ${activeHouses} active listings`;

  const feed = document.getElementById('a-activity-feed');
  const dotColors = {inquiry:'var(--blue)',tenant:'var(--teal)',maint:'var(--amber)'};
  const activities = [
    ...state.inquiries.slice(0,3).map(i=>({type:'inquiry',msg:`<strong>${i.name}</strong> inquired at ${state.houses.find(h=>h.id===i.houseId)?.name||'a house'}`,ts:Date.now()-7200000})),
    ...state.pendingTenants.filter(t=>t.status==='active').slice(0,2).map(t=>({type:'tenant',msg:`<strong>${t.name}</strong> registered as tenant`,ts:Date.now()-10800000})),
    ...state.maintenanceRequests.slice(0,2).map(r=>({type:'maint',msg:`<strong>${r.tenantName}</strong> reported: ${r.type.replace(/<[^>]+>/g,'')}`,ts:Date.now()-14400000})),
  ].sort((a,b)=>b.ts-a.ts).slice(0,8);
  if (feed) feed.innerHTML = activities.length
    ? activities.map(a=>`<div class="a-activity-item"><div class="a-activity-dot" style="background:${dotColors[a.type]||'var(--muted2)'}"></div><div class="a-activity-txt">${a.msg}</div><div class="a-activity-time">${relTime(a.ts)}</div></div>`).join('')
    : '<div style="text-align:center;padding:20px;color:var(--muted);font-size:13px;">No recent activity</div>';
}

