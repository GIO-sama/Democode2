  ].sort((a,b)=>b.ts-a.ts).slice(0,8);
  if (feed) feed.innerHTML = activities.length
    ? activities.map(a=>`<div class="a-activity-item"><div class="a-activity-dot" style="background:${dotColors[a.type]||'var(--muted2)'}"></div><div class="a-activity-txt">${a.msg}</div><div class="a-activity-time">${relTime(a.ts)}</div></div>`).join('')
