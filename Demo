function confirmReferral(seekerName, fromHouseId, idx, toHouseId) {
  document.getElementById('referral-picker')?.remove();
  const toHouse = state.houses.find(h => h.id === toHouseId);
  if (!toHouse) return;
  if (!state.referrals) state.referrals = [];
  const ref = {
    id: state.nextId++,
    seekerName,
    fromHouseId,
    toHouseId,
    toHouseName: toHouse.name,
    toHousePrice: toHouse.price,
    status: 'pending',
    createdAt: Date.now(),
  };
  if (!state.referrals) state.referrals = [];
  state.referrals.push(ref);
  // Add a notification in seeker's inquiry list
  state.myInquiries.push({
    id: state.nextId++,
    houseId: toHouseId,
    houseName: toHouse.name,
    status: 'referred',
    q: 'You were referred here by another landlord.',
    read: false,
    referralId: ref.id,
  });
  save();
  renderWaitlistManager();
  showToast(`<i class="ph ph-share-network"></i> ${seekerName} referred to ${toHouse.name}!`);
}

function promoteWaitlist(name, houseId, idx) {
  const h = state.houses.find(x => x.id === houseId);
  if (!h) return;
  const emptyRoom = (h.rooms||[]).find(r => r.status === 'empty');
  if (!emptyRoom) { showToast('No vacant rooms in this house'); return; }

  const code = String(Math.floor(100000 + Math.random() * 900000));
  state.pendingTenants.push({ id: state.nextId++, name, phone:'', room: emptyRoom.name, houseId, code, status:'pending' });
  h.waitlist.splice(idx, 1);
  save();

  const set = (id, v) => { const e = document.getElementById(id); if(e) e.textContent = v; };
  set('ic-code-display', code);
  set('ic-room-display', emptyRoom.name + ' — ' + h.name);
  set('ic-modal-sub', 'Share this code with ' + name + ' via text, Viber, or in person.');
  const copyBtn = document.getElementById('ic-copy-btn');
  if(copyBtn) copyBtn.onclick = () => {
    navigator.clipboard?.writeText(code).catch(()=>{});
    showToast('Code copied: ' + code);
  };
  document.getElementById('modal-invite-code').classList.remove('hidden');
  renderWaitlistManager();
}

function openRoomPhotoViewer(photos, roomName) {
  if (!photos || !photos.length) return;
  document.getElementById('room-photo-viewer')?.remove();

  let current = 0;
  const total = photos.length;

  const overlay = document.createElement('div');
  overlay.id = 'room-photo-viewer';
  overlay.style.cssText = 'position:fixed;inset:0;background:#000;z-index:800;display:flex;flex-direction:column;';

  const render = () => {
    overlay.innerHTML = `
      <div style="display:flex;align-items:center;justify-content:space-between;padding:14px 16px;flex-shrink:0;">
        <button onclick="document.getElementById('room-photo-viewer').remove()" style="background:rgba(255,255,255,.1);border:none;color:#fff;border-radius:8px;padding:8px 12px;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:6px;">
          <i class="ph ph-arrow-left"></i>
        </button>
        <div style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:#fff;">${roomName} — ${current+1} / ${total}</div>
        <div style="width:40px;"></div>
      </div>
      <div style="flex:1;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:0 12px;">
        <img src="${photos[current]}" style="max-width:100%;max-height:100%;object-fit:contain;border-radius:12px;">
      </div>
      <div style="display:flex;justify-content:center;gap:8px;padding:16px;flex-shrink:0;">
        ${photos.map((_, i) => `<div style="width:${i===current?'24px':'8px'};height:8px;border-radius:4px;background:${i===current?'#fff':'rgba(255,255,255,.3)'};transition:all .2s;cursor:pointer;" onclick="document.getElementById('room-photo-viewer').remove();openRoomPhotoViewerAt(${i})"></div>`).join('')}
      </div>
      ${total > 1 ? `
      <div style="display:flex;gap:12px;padding:0 16px 20px;flex-shrink:0;">
        <button onclick="rvPrev()" style="flex:1;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:#fff;border-radius:10px;padding:13px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;" ${current===0?'disabled style="opacity:.4"':''}>← Prev</button>
        <button onclick="rvNext()" style="flex:1;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);color:#fff;border-radius:10px;padding:13px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;cursor:pointer;" ${current===total-1?'disabled style="opacity:.4"':''}>Next →</button>
      </div>` : '<div style="height:20px;"></div>'}
    `;
  };

  window.rvNext = () => { if (current < total-1) { current++; render(); } };
  window.rvPrev = () => { if (current > 0) { current--; render(); } };
  window.openRoomPhotoViewerAt = (idx) => { current = idx; openRoomPhotoViewer(photos, roomName); };

  // Swipe support
  let touchStartX = 0;
  overlay.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  overlay.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (dx < -50) window.rvNext();
    else if (dx > 50) window.rvPrev();
  });

  document.body.appendChild(overlay);
  render();
}

function removeWaitlist(name, houseId, idx) {
  const h = state.houses.find(x => x.id === houseId);
  if (h) {
    h.waitlist.splice(idx, 1);
