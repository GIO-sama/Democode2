function renderTenantHome() {
  // Get tenant profile — use registered profile or default
  const profile = state.tenantProfile || {
    name: 'Ana Reyes', room: 'R1', roomLabel: 'Room 1',
    rent: 1500, houseId: 1, houseName: 'TIAH Boarding House',
    houseAddr: 'Poblacion VII, Burauen', paymentStatus: 'paid'
  };
  // Update header
  const nameEl = document.getElementById('t-tenant-name');
  if(nameEl) nameEl.textContent = profile.name;
  const houseNameEl = document.getElementById('t-house-name');
  if(houseNameEl) houseNameEl.textContent = profile.houseName;
  const houseAddrEl = document.getElementById('t-house-addr');
  if(houseAddrEl) houseAddrEl.textContent = `${profile.houseAddr} • ${profile.roomLabel || profile.room}`;
  // Room card
  const roomLbl = document.getElementById('t-room-label');
  if(roomLbl) roomLbl.textContent = profile.roomLabel || profile.room;
  const roomHouse = document.getElementById('t-room-house');
  if(roomHouse) roomHouse.textContent = profile.houseName;
  const roomRent = document.getElementById('t-room-rent');
  if(roomRent) roomRent.textContent = '₱' + (profile.rent||0).toLocaleString();
  const payStatus = document.getElementById('t-payment-status');
  const payPrompt = document.getElementById('t-pay-prompt');
  const isPaid = profile.paymentStatus === 'paid';
  const isSelfReported = profile.paymentStatus === 'self_reported';
  if(payStatus) {
    if (profile.paymentStatus === 'paid') {
      payStatus.innerHTML = '<i class="ph ph-check" style="font-size:11px"></i> Paid';
      payStatus.style.background = 'rgba(255,255,255,.2)';
    } else if (profile.paymentStatus === 'self_reported') {
      payStatus.innerHTML = '<i class="ph ph-clock" style="font-size:11px"></i> Awaiting confirmation';
      payStatus.style.background = 'rgba(255,200,0,.25)';
    } else {
      payStatus.innerHTML = '<i class="ph ph-warning" style="font-size:11px"></i> Not yet paid';
      payStatus.style.background = 'rgba(255,200,0,.25)';
    }
  }
  if (payPrompt) {
    if (isPaid) {
      payPrompt.style.display = 'none';
    } else if (isSelfReported) {
      payPrompt.style.display = 'flex';
      // Change prompt to waiting state
      const promptBtn = payPrompt.querySelector('button');
      if (promptBtn) {
        promptBtn.textContent = 'Sent ✓';
        promptBtn.disabled = true;
        promptBtn.style.background = 'var(--muted2)';
        promptBtn.style.cursor = 'default';
      }
      const promptTitle = payPrompt.querySelector('div div:first-child');
      if (promptTitle) promptTitle.textContent = 'Naghihintay ng kumpirmasyon';
    } else {
      payPrompt.style.display = 'flex';
    }
  }
  // Announcements
  const newCount = state.announcements.filter(a => a.isNew && !a.dismissed).length;
  const badge = document.getElementById('t-ann-badge');
  if(badge) badge.textContent = newCount > 0 ? newCount + ' new' : 'All';
  const list = document.getElementById('t-ann-list');
  const emptyEl = document.getElementById('t-ann-empty');
  const visible = state.announcements.filter(a => !a.dismissed);
  if(!visible.length) {
    if(list) list.innerHTML = '';
    if(emptyEl) emptyEl.classList.remove('hidden');
    return;
  }
  if(emptyEl) emptyEl.classList.add('hidden');
  const catMap = {
    reminder:  {ic:'<i class="ph ph-money"></i>',       bg:'var(--amberBg)', c:'var(--amber)', label:'Reminder'},
    info:      {ic:'<i class="ph ph-info"></i>',        bg:'var(--blueLt)',  c:'var(--blue)',  label:'Info'},
    emergency: {ic:'<i class="ph ph-siren"></i>',       bg:'var(--redBg)',   c:'var(--red)',   label:'Emergency'},
    activity:  {ic:'<i class="ph ph-calendar-check"></i>', bg:'var(--greenBg)', c:'var(--green)', label:'Activity'},
  };

  // Sort: pinned/emergency first, then newest
  const sorted = [...state.announcements]
    .filter(a => !a.dismissed)
    .sort((a, b) => {
      const aPin = a.pinned || a.cat === 'emergency';
      const bPin = b.pinned || b.cat === 'emergency';
      if (aPin !== bPin) return aPin ? -1 : 1;
      return (b.ts || 0) - (a.ts || 0);
    });

  if(list) list.innerHTML = sorted.map(a => {
    const cat = catMap[a.cat]||catMap.info;
    const isPinned = a.pinned || a.cat === 'emergency';
    return `<div class="ann-card${isPinned ? '" style="border:1.5px solid var(--red);' : '"'} onclick="markAnnRead(${a.id})">
      <div class="ann-hdr">
        <div class="ann-ic" style="background:${cat.bg};color:${cat.c};">${cat.ic}</div>
        <div style="flex:1;min-width:0;">
          <div class="ann-title">${isPinned?'<i class="ph ph-push-pin" style="font-size:11px;color:var(--red);margin-right:4px;"></i>':''}${a.title}</div>
          <div style="font-size:10px;font-family:'Nunito',sans-serif;font-weight:700;color:${cat.c};margin-top:2px;">${cat.label}</div>
        </div>
        ${a.isNew ? '<div class="new-dot"></div>' : ''}
      </div>
      <div class="ann-body">${a.body}</div>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:6px;">
        <div class="ann-time">${relTime(a.ts)}</div>
        <button onclick="event.stopPropagation();dismissAnn(${a.id})"
          style="background:none;border:none;font-family:'Nunito',sans-serif;font-size:11px;font-weight:700;color:var(--muted2);cursor:pointer;display:flex;align-items:center;gap:3px;padding:2px 0;">
          <i class="ph ph-x"></i> Dismiss
        </button>
      </div>
    </div>`;
  }).join('');
}

function markAnnRead(id) {
  const ann = state.announcements.find(a=>a.id===id);
  if(ann) { ann.isNew = false; save(); renderTenantHome(); }
}

function dismissAnn(id) {
  const ann = state.announcements.find(a=>a.id===id);
  if(ann) { ann.dismissed = true; ann.isNew = false; save(); renderTenantHome(); }
}

