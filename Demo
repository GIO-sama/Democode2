function toggleRejectReason() {
  const rw = document.getElementById('pconf-reject-wrap');
  const rb = document.getElementById('pconf-reject-btn');
  if (!rw) return;
  const showing = rw.style.display !== 'none';
  if (showing) {
    rw.style.display = 'none';
    rb.innerHTML = '<i class="ph ph-x-circle"></i> Reject';
  } else {
    rw.style.display = '';
    document.getElementById('pconf-reject-reason').value = '';
    rb.innerHTML = '<i class="ph ph-arrow-u-up-left"></i> Cancel Rejection';
    // If reject reason visible, clicking confirm-btn means reject
    rb.onclick = () => rejectLandlordPayment();
  }
}

function confirmLandlordPayment() {
  const tx = (state.paymentTransactions||[]).find(t=>t.id===_pconfTxId);
  if (!tx) return;
  tx.status      = 'confirmed';
  tx.resolvedAt  = Date.now();
  tx.resolvedBy  = 'Landlord';

  // Update tenant profile status
  if (state.tenantProfile && state.tenantProfile.pendingTxId === tx.id) {
    state.tenantProfile.paymentStatus = 'paid';
    state.tenantProfile.pendingTxId   = null;
  }
  // Update room status
  const h = state.houses.find(x=>x.id===tx.houseId);
  if (h) { const r=(h.rooms||[]).find(x=>x.name===tx.room); if(r) r.status='paid'; }
  // Update paymentLog
  const log = state.paymentLog||[];
  const sr  = log.find(p=>p.status==='self_reported');
  if (sr) { sr.status='paid'; sr.method='GCash'; }

  adminLog(`Payment confirmed: ${tx.tenantName} ₱${tx.amount.toLocaleString()} ref ${tx.ref}`);
  save();
  closePconfModal();
  renderLandlordHome();
  renderPaymentHistory();
  showToast('<i class="ph ph-check-circle"></i> Payment confirmed for ' + tx.tenantName);
}

function rejectLandlordPayment() {
  const tx = (state.paymentTransactions||[]).find(t=>t.id===_pconfTxId);
  if (!tx) return;
  const reason = document.getElementById('pconf-reject-reason')?.value.trim() || 'Could not verify';
  tx.status       = 'rejected';
  tx.resolvedAt   = Date.now();
  tx.resolvedBy   = 'Landlord';
  tx.rejectReason = reason;

  // Revert tenant profile back to pending
  if (state.tenantProfile && state.tenantProfile.pendingTxId === tx.id) {
    state.tenantProfile.paymentStatus = 'pending';
    state.tenantProfile.pendingTxId   = null;
  }
  const h = state.houses.find(x=>x.id===tx.houseId);
  if (h) { const r=(h.rooms||[]).find(x=>x.name===tx.room); if(r&&r.status==='self_reported') r.status='pending'; }

  adminLog(`Payment rejected: ${tx.tenantName} ₱${tx.amount.toLocaleString()} — ${reason}`);
  save();
  closePconfModal();
  renderLandlordHome();
  showToast('<i class="ph ph-x-circle"></i> Payment rejected. Tenant will be notified.');
}

