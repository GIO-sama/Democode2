function shareHouse() {
  const h = state.houses.find(x => x.id === state.currentHouseId);
  if (!h) return;
  const base = window.location.origin + window.location.pathname;
  const link = `${base}?house=${h.id}`;
  const text = `${h.name} — ₱${h.price.toLocaleString()}/mo · ${h.address} · Buhay Boarding`;
  navigator.clipboard.writeText(link)
    .then(() => showToast('<i class="ph ph-copy"></i> Link copied! Share it with a classmate.'))
    .catch(() => {
      // Fallback: copy the text description
      navigator.clipboard.writeText(text)
        .then(() => showToast('<i class="ph ph-copy"></i> House details copied!'))
        .catch(() => showToast('Share: ' + text));
    });
}

