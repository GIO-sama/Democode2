  set('inq-h-house',   h?.name || '—');
  set('inq-h-date',    inq.date ? 'Move-in ' + inq.date : 'Date TBD');

  // Render thread history — shows full conversation including first question
  const threadEl = document.getElementById('inq-thread-history');
  if (threadEl) {
    const msgs = inq.messages && inq.messages.length
      ? inq.messages
