        ${r.status==='pending'?`<button class="btn-green-sm" style="font-size:11px;padding:5px 10px" onclick="updateMaint(${r.id},'in_progress')">Mark In Progress</button>`:''}
        ${r.status==='in_progress'?`<button class="btn-green-sm" style="font-size:11px;padding:5px 10px" onclick="updateMaint(${r.id},'done')">Mark Done </button>`:''}
      </div>
    </div>`;
  }).join('');
}

function updateMaint(id, status) {
