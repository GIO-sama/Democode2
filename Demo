function handlePaymentScreenshot(event) {
  const file = event.target.files[0];
  if (!file) return;
  // Log upload
  if (!state.uploadLog) state.uploadLog = [];
  const tp = state.tenantProfile || {};
  state.uploadLog.unshift({
    id: state.nextId++, type: 'payment_screenshot',
    user: tp.name || 'Tenant', room: tp.room || '—',
    houseId: tp.houseId || 1,
    filename: file.name, size: (file.size/1024).toFixed(1)+'KB', ts: Date.now()
  });
  const reader = new FileReader();
  reader.onload = e => {
    const img = document.getElementById('pr-photo-img');
    const ic  = document.getElementById('pr-photo-ic');
    const lbl = document.getElementById('pr-photo-lbl');
    if (img) { img.src = e.target.result; img.style.display='block'; }
    if (ic)  ic.style.display='none';
    if (lbl) lbl.style.display='none';
    img._data = e.target.result;
  };
  reader.readAsDataURL(file);
}

function submitPaymentReport() {
  const ref    = document.getElementById('pr-ref').value.trim();
  const amount = parseFloat(document.getElementById('pr-amount').value);
  const note   = document.getElementById('pr-note').value.trim();
  const img    = document.getElementById('pr-photo-img');
  const screenshot = (img && img.style.display !== 'none') ? img.src : null;

  if (!ref)           { showToast('Please enter your GCash reference number'); return; }
  if (!amount || isNaN(amount)) { showToast('Please enter the amount you sent'); return; }

  if (!state.paymentTransactions) state.paymentTransactions = [];
  const tp   = state.tenantProfile || {};
  const now  = new Date();
  const mon  = now.toLocaleString('en-PH', { month:'long', year:'numeric' });

  const tx = {
    id: state.nextId++,
    tenantName: tp.name || 'Tenant',
    room: tp.room || '—',
    houseId: tp.houseId || 1,
    amount, ref, note: note || '—',
    screenshot,
    status: 'pending_confirmation',
    submittedAt: Date.now(),
    month: mon,
    resolvedAt: null, resolvedBy: null, rejectReason: null
  };
  state.paymentTransactions.push(tx);

  // Mark tenant profile
  if (state.tenantProfile) {
    state.tenantProfile.paymentStatus = 'self_reported';
    state.tenantProfile.pendingTxId   = tx.id;
  }

  // Mark room
  const h = state.houses.find(x => x.id === tp.houseId);
  if (h) { const r = (h.rooms||[]).find(x => x.name === tp.room); if (r && r.status==='pending') r.status='self_reported'; }

  // Update paymentLog
  const log = state.paymentLog || [];
  const pending = log.find(p => p.status==='pending');
  if (pending) { pending.status='self_reported'; pending.method='GCash'; pending.date=now.toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'}); }

  adminLog(`Payment reported: ${tp.name||'Tenant'} — ₱${amount.toLocaleString()} (Ref: ${ref})`);
  save();
  closePaymentReportModal();
  renderTenantHome();
  showToast('<i class="ph ph-check-circle"></i> Payment reported! Waiting for landlord confirmation.');
}

