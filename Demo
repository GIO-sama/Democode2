    case 'a-inquiries':     renderAdminInquiries();   break;
    case 'a-maintenance':   renderAdminMaintenance(); break;
    case 'a-financials':    renderAdminFinancials();  break;
    case 'a-announcements': renderPlatformAnns();     break;
    case 'a-logs':          renderAuditLog();         break;
    case 'a-settings':      renderAdminSettings();    break;
    case 't-register': showRegStep(1); break;
    case 't-houseinfo': renderTenantHouseInfo(); break;
    case 's-profile': renderSeekerProfile(); break;
    case 'l-profile': renderLandlordProfile(); break;
    case 's-setup':
      if(typeof seekerSetupStep!=='undefined'){
        showSeekerSetupStep(1);
        // Pre-fill seeker fields
        const sp = profiles.seeker;
        const _sv = (id,v)=>{ const e=document.getElementById(id); if(e&&v!==undefined) e.value=v||''; };
        _sv('ss-name', sp.name); _sv('ss-phone', sp.phone);
        _sv('ss-school', sp.school); _sv('ss-course', sp.course);
        _sv('ss-birthday', sp.birthday||''); _sv('ss-bio', sp.bio||'');
        // restore photo preview
        if(sp.photo) {
          const prev=document.getElementById('ss-photo-preview');
          const img=document.getElementById('ss-photo-img');
          if(prev&&img){img.src=sp.photo;prev.classList.add('has-photo');}
        }
        // restore photo consent toggle
        const consentTog = document.getElementById('ss-show-photo');
        if(consentTog) consentTog.classList.toggle('on', !!sp.showPhoto);
        // restore gender pill
        if(sp.gender) {
          document.querySelectorAll('#ss-gender-pills .gender-pill').forEach(p=>{
            p.classList.toggle('selected', p.dataset.g===sp.gender);
          });
        }
      }
      break;
    case 'l-onboard': if(typeof loStep!=='undefined'){showLoStep(1);} break;
    case 'l-listing': renderBhlListing(); break;
    case 's-saved': renderSaved(); break;
    case 's-detail': updateDetailSaveBtn(); break;
    case 's-inquiry': {
      const _sp = profiles.seeker;
      const _ni = document.getElementById('inq-name');
      const _si = document.getElementById('inq-school');
      const _ci = document.getElementById('inq-course');
      if (_ni && _sp.name  && !_ni.value) { _ni.value = _sp.name;   _ni.readOnly = true; _ni.style.background='var(--warm)'; _ni.style.color='var(--muted)'; }
      if (_si && _sp.school && !_si.value) { _si.value = _sp.school; }
      if (_ci && _sp.course && !_ci.value) { _ci.value = _sp.course; _ci.readOnly = true; _ci.style.background='var(--warm)'; _ci.style.color='var(--muted)'; }
      break;
    }
    case 's-map':
      // Wait for Leaflet JS (deferred) to finish loading, then init.
      // Uses a poll loop — fires once L is confirmed defined.
      (function tryInitMap(attempts) {
        if (typeof L === 'undefined') {
          if (attempts < 40) setTimeout(() => tryInitMap(attempts + 1), 100);
          return;
        }
        // Give the browser 200ms after screen becomes visible to finish layout.
        // requestAnimationFrame alone isn't enough — flex layout takes >1 frame
        // to resolve when transitioning from display:none to display:flex.
        setTimeout(() => {
          initLeafletMap();
          closeMapCard && closeMapCard();
        }, 200);
      })(0);
      break;
    case 'l-setup':
      {
        // Pre-fill landlord setup
        const lp = profiles.landlord;
        const _lv = (id,v)=>{ const e=document.getElementById(id); if(e&&v!==undefined) e.value=v||''; };
        _lv('ls-name', lp.name); _lv('ls-phone', lp.phone);
        _lv('ls-bh-name', lp.bhName); _lv('ls-address', lp.address);
        _lv('ls-gcash', lp.gcash); _lv('ls-birthday', lp.birthday||'');
        if(lp.photo){const prev=document.getElementById('ls-photo-preview');const img=document.getElementById('ls-photo-img');if(prev&&img){img.src=lp.photo;prev.classList.add('has-photo');}}
        if(lp.gender){document.querySelectorAll('#ls-gender-pills .gender-pill').forEach(p=>{p.classList.toggle('selected',p.dataset.g===lp.gender);});}
      }
      break;
  }
}

