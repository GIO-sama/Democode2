function updateClock() {
  const now = new Date();
  const h = now.getHours().toString().padStart(2,'0');
  const m = now.getMinutes().toString().padStart(2,'0');
  document.getElementById('clock').textContent = h+':'+m;
  updateGreetings();
}

function updateGreetings() {
  const hr = new Date().getHours();
  let greetFil, greetEn, icon;
  if (hr < 12)      { greetFil = 'Good morning';  greetEn = 'Good morning';   icon = '<i class="ph ph-sun"></i>'; }
  else if (hr < 18) { greetFil = 'Good afternoon';  greetEn = 'Good afternoon'; icon = '<i class="ph ph-cloud-sun"></i>'; }
  else              { greetFil = 'Good evening';   greetEn = 'Good evening';   icon = '<i class="ph ph-moon"></i>'; }
  const sg = document.getElementById('seeker-greeting');
  const lg = document.getElementById('landlord-greeting');
  if (sg) sg.innerHTML = greetEn + ' ' + icon;
  if (lg) lg.innerHTML = greetEn  + ' ' + icon;
}

