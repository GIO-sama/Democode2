      <div style="font-family:'Nunito',sans-serif;font-size:14px;font-weight:700;">No transactions yet</div>
      <div style="font-size:12px;margin-top:4px;">Payment reports from tenants will appear here.</div>
    </div>`; return;
  }

  const total = txs.filter(t=>t.status==='confirmed').reduce((s,t)=>s+t.amount,0);
