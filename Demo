}

/* SVG wrapper — scrollable */
.map-svg-wrap {
  flex: 1;
  overflow: auto;
  position: relative;
  -webkit-overflow-scrolling: touch;
}
.map-svg-wrap::-webkit-scrollbar { display: none; }
.map-svg-wrap svg {
  display: block;
  width: 100%;
  height: auto;
  min-width: 100%;
}

/* House pin button */
.bh-pin-btn {
  cursor: pointer;
  transition: transform .15s;
  transform-origin: center bottom;
}
.bh-pin-btn:active { transform: scale(.93); }
.bh-pin-btn.highlighted .pin-bubble { filter: drop-shadow(0 4px 10px rgba(11,31,58,.4)); }

/* ── MAP BOTTOM SHEET ── */
.map-sheet-overlay {
  position: absolute;
  inset: 0;
  z-index: 50;
  pointer-events: none;
}
.map-sheet-overlay.active { pointer-events: all; }
.map-sheet-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(11,31,58,.18);
  opacity: 0;
  transition: opacity .25s;
}
.map-sheet-overlay.active .map-sheet-backdrop { opacity: 1; }
.map-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: var(--card);
  border-radius: 20px 20px 0 0;
  box-shadow: 0 -6px 32px rgba(11,31,58,.18);
  transform: translateY(100%);
  transition: transform .3s cubic-bezier(.32,0,.2,1);
  overflow: hidden;
}
.map-sheet-overlay.active .map-sheet {
  transform: translateY(0);
}
.map-sheet-handle {
  width: 36px; height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 12px auto 0;
}
.map-sheet-hero {
  margin: 14px 14px 0;
  border-radius: 14px;
  padding: 16px 16px 14px;
  position: relative;
  overflow: hidden;
}
.map-sheet-name {
  font-family: 'Nunito', sans-serif;
  font-size: 17px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 3px;
}
.map-sheet-addr {
  font-size: 12px;
  color: rgba(255,255,255,.7);
  display: flex;
  align-items: center;
  gap: 4px;
}
.map-sheet-avail {
  position: absolute;
  top: 12px; right: 12px;
  background: rgba(255,255,255,.22);
  border: 1px solid rgba(255,255,255,.35);
  border-radius: 20px;
  padding: 4px 10px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: #fff;
}
.map-sheet-stats {
  display: flex;
  margin: 12px 14px 0;
  background: var(--warm);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.map-sheet-stat {
  flex: 1;
  padding: 11px 8px;
  text-align: center;
  border-right: 1px solid var(--border);
}
.map-sheet-stat:last-child { border-right: none; }
.map-sstat-v {
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 900;
  color: var(--navy);
}
.map-sstat-l {
  font-size: 10px;
  color: var(--muted);
  margin-top: 2px;
  font-weight: 600;
}
.map-sheet-dist {
  display: flex;
  gap: 8px;
  margin: 10px 14px 0;
}
.map-dist-pill {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.12);
  border-radius: 10px;
  padding: 9px 10px;
}
.map-dist-pill.teal {
  background: #F0FDFA;
  border-color: rgba(11,122,106,.12);
}
.map-dist-ic {
  font-size: 18px;
  flex-shrink: 0;
}
.map-dist-v {
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 900;
  color: var(--navy);
}
.map-dist-l {
  font-size: 10px;
  color: var(--muted);
  margin-top: 1px;
}
.map-sheet-actions {
  display: flex;
  gap: 10px;
  margin: 12px 14px 20px;
}

/* ── ENTRY PILL on Discover ── */
.map-entry-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.22);
  border-radius: 20px;
  padding: 5px 11px 5px 9px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: rgba(255,255,255,.8);
  cursor: pointer;
  transition: background .15s;
  letter-spacing: .1px;
  flex-shrink: 0;
}
.map-entry-pill:active { background: rgba(255,255,255,.22); }
.map-entry-pill i { font-size: 13px; }

/* ════════════════════════════════════════════════════
   INQUIRY DETAIL BOTTOM SHEET
════════════════════════════════════════════════════ */
.inq-sheet-overlay {
  position: absolute;
  inset: 0;
  z-index: 200;
  background: rgba(11,31,58,.52);
  backdrop-filter: blur(5px);
  display: flex;
  align-items: flex-end;
}
.inq-sheet-overlay.hidden { display: none !important; }
.inq-sheet {
  width: 100%;
  background: var(--warm);
  border-radius: 24px 24px 0 0;
  padding: 0 0 32px;
  box-shadow: 0 -8px 40px rgba(11,31,58,.22);
  max-height: 90%;
  overflow-y: auto;
  animation: sheetUp .28s cubic-bezier(.32,0,.2,1);
}
@keyframes sheetUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.inq-sheet-handle {
  width: 36px; height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 14px auto 0;
}

/* Hero */
.inq-hero {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px 18px 0;
  background: linear-gradient(135deg, var(--navy) 0%, #1558CC 100%);
  border-radius: 16px;
  padding: 16px 16px 16px 16px;
  position: relative;
  overflow: hidden;
}
.inq-hero::before {
  content: '';
  position: absolute;
  inset: 0;
