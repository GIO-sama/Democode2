// SEEKER SETUP — 3-STEP FLOW
// ════════════════════════════════════════
let seekerSetupStep = 1;
function seekerSetupNext() {
  if(seekerSetupStep === 1) {
    const name = document.getElementById('ss-name').value.trim();
    const phone = document.getElementById('ss-phone').value.trim();
    const school = document.getElementById('ss-school').value;
    const course = document.getElementById('ss-course').value.trim();
    if(!name){ showToast('Please enter your name'); return; }
    if(!school){ showToast('Please select your school'); return; }
    profiles.seeker.name = name;
    profiles.seeker.phone = phone;
    profiles.seeker.school = school;
    profiles.seeker.course = course;
    seekerSetupStep = 2;
    showSeekerSetupStep(2);
  } else if(seekerSetupStep === 2) {
    profiles.seeker.budget = parseInt(document.getElementById('ss-budget').value);
    profiles.seeker.wifi    = document.getElementById('ss-wifi').classList.contains('on');
    profiles.seeker.cooking = document.getElementById('ss-cooking').classList.contains('on');
    profiles.seeker.visitors= document.getElementById('ss-visitors').classList.contains('on');
    profiles.seeker.nocurfew= document.getElementById('ss-nocurfew').classList.contains('on');
    // Update review
    const rvName = document.getElementById('ss-review-name');
    const rvSch  = document.getElementById('ss-review-school');
    const rvBud  = document.getElementById('ss-review-budget');
    if(rvName) rvName.textContent = profiles.seeker.name||'—';
    if(rvSch)  rvSch.textContent  = profiles.seeker.school||'—';
    if(rvBud)  rvBud.textContent  = '₱' + (profiles.seeker.budget||0).toLocaleString();
    seekerSetupStep = 3;
    showSeekerSetupStep(3);
  } else if(seekerSetupStep === 3) {
    profiles.seeker.created = new Date().toLocaleDateString('en-PH',{month:'long',year:'numeric'});
    saveProfiles();
    renderSeekerProfile();
    state.role = 'seeker';
    showToast('Profile created! Welcome to Buhay Boarding ');
    goTo('s-home');
  }
}
function seekerSetupBack() {
  if(seekerSetupStep > 1) { seekerSetupStep--; showSeekerSetupStep(seekerSetupStep); }
  else goTo('s-role');
}
function showSeekerSetupStep(n) {
  document.querySelectorAll('#s-setup .onboard-step').forEach((el,i)=>{
    el.classList.toggle('active', i+1===n);
  });
  document.querySelectorAll('.sdot-step').forEach((el,i)=>{
    el.classList.toggle('on', i+1===n);
  });
  document.getElementById('ss-back-btn').style.display = n>1 ? '' : 'none';
  const titles = ['Create Your Profile','Your Preferences','Almost Done!'];
  const subs = ['Tell us about yourself so landlords can respond faster.',
                'Filter listings by what matters most to you.',
                'Add a photo and a few more details — all optional.'];
  document.getElementById('ss-title').textContent = titles[n-1];
  document.getElementById('ss-sub').textContent   = subs[n-1];
  document.getElementById('lo-next-btn') && null; // no-op guard
  if(n===3) document.getElementById('ss-next-btn').textContent = 'Create Profile ';
  else document.getElementById('ss-next-btn').textContent = 'Next →';
  seekerSetupStep = n;
}

