        <div style="font-size:12px;color:var(--muted);margin-top:1px;">${v.date} at ${v.time}</div>
      </div>
      <span style="font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;color:${s.tc};background:${s.bg};padding:3px 8px;border-radius:20px;">${s.lbl}</span>
    </div>`;
  }).join('');
}

