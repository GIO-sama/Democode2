// layer marker refs
const lmMarkers = {};   // cat → [L.marker, ...]
const lmVisible = { schools: true, food: true, stores: true, health: true, gov: true };

function makeLmIcon(lm) {
  return L.divIcon({
    className: '',
    iconAnchor: [13, 13],
    html: `<div style="
      width:26px;height:26px;border-radius:50%;
      background:${lm.bg};border:2px solid ${lm.color};
      display:flex;align-items:center;justify-content:center;
      font-size:12px;box-shadow:0 2px 8px rgba(0,0,0,.18);
      cursor:pointer;transition:transform .15s;
    ">${lm.emoji}</div>`,
  });
}

function toggleLayer(cat, btn) {
  lmVisible[cat] = !lmVisible[cat];
  btn.classList.toggle('on', lmVisible[cat]);
  (lmMarkers[cat] || []).forEach(m => {
    if (lmVisible[cat]) m.addTo(bbMap);
    else bbMap.removeLayer(m);
  });
}

function initLeafletMap() {
  if (bbMap) {
    // Already initialized — just recalculate size in case container shifted
    bbMap.invalidateSize();
    return;
  }

  // Lazy-inject Leaflet CSS only when map is first opened.
  if (!document.getElementById('leaflet-css')) {
    const lnk = document.createElement('link');
    lnk.id   = 'leaflet-css';
    lnk.rel  = 'stylesheet';
    lnk.href = 'https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.min.css';
    lnk.crossOrigin = 'anonymous';
    document.head.appendChild(lnk);
  }

  // Center: Burauen Poblacion town center (between plaza & market).
  // Zoom 15 fits both EVSU (NE) and BCC (NW) plus all boarding house pins
  // without clipping. Zoom 16 cut off EVSU at the northeast edge.
  bbMap = L.map('burauen-map', {
    center: [10.8755, 124.9390],
    zoom: 15,
    zoomControl: true,
    attributionControl: true,
  });

  // CartoDB Voyager — clean streets, readable labels, no noise
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CartoDB',
    subdomains: 'abcd',
    maxZoom: 19,
  }).addTo(bbMap);

  // ── Landmark markers ──
  LANDMARKS.forEach(lm => {
    if (!lmMarkers[lm.cat]) lmMarkers[lm.cat] = [];
    const m = L.marker(lm.latlng, { icon: makeLmIcon(lm), riseOnHover: true })
      .bindTooltip(`<b>${lm.label}</b><br><span style="font-weight:400;opacity:.85">${lm.note}</span>`, {
        className: 'lm-tooltip',
        direction: 'top',
        offset: [0, -14],
        permanent: false,
      })
      .addTo(bbMap);
    lmMarkers[lm.cat].push(m);
  });

  // ── Boarding house pins (on top) ──
  state.houses.forEach(h => {
    const icon = L.divIcon({
      className: '',
      iconSize:   [1, 1],
      iconAnchor: [50, 54],
      html: buildPinHTML(h),
    });
    const marker = L.marker(h.latlng, { icon, riseOnHover: true, zIndexOffset: 500 }).addTo(bbMap);
    marker.on('click', () => openMapCard(h.id));
    bbMarkers[h.id] = marker;
  });

  // Critical: container was display:none when Leaflet first measured it.
  // Two calls — first at 150ms catches most cases, second at 600ms
  // catches slow devices or cases where flex layout settles late.
  setTimeout(() => bbMap.invalidateSize(), 150);
  setTimeout(() => bbMap.invalidateSize(), 600);
}

function openMapCard(id) {
  const h = state.houses.find(x => x.id === id);
  if (!h) return;
  activeMapHouseId = id;

  const avail = h.rooms.filter(r => r.status === 'empty').length;
  const set = (elId, v) => { const e = document.getElementById(elId); if (e) e.textContent = v; };

  const hero = document.getElementById('msh-hero');
  if (hero) hero.style.background = h.gradient;
  set('msh-name',   h.name);
  set('msh-addr',   h.address);
  set('msh-price',  '₱' + h.price.toLocaleString() + '/mo');
  set('msh-avail-rooms', avail > 0 ? avail : 'Full');
  set('msh-curfew', h.curfew === 'No curfew' ? 'None' : h.curfew);
  set('msh-devsu',  h.distanceEVSU);
  set('msh-dbcc',   h.distanceBCC);

  const availEl = document.getElementById('msh-avail');
  if (availEl) {
    if (avail > 0) {
      availEl.textContent = avail + ' slot' + (avail > 1 ? 's' : '') + ' open';
      availEl.style.background = 'rgba(34,197,94,.4)';
      availEl.style.borderColor = 'rgba(34,197,94,.5)';
    } else {
      availEl.textContent = 'Full · Waitlist';
      availEl.style.background = 'rgba(239,68,68,.35)';
      availEl.style.borderColor = 'rgba(239,68,68,.4)';
    }
  }

  // Highlight active pin
  document.querySelectorAll('.lf-pin').forEach(el => el.classList.remove('highlighted'));
  const pinEl = document.getElementById('lf-pin-' + id);
  if (pinEl) pinEl.classList.add('highlighted');

  // Pan map to pin
  if (bbMap && h.latlng) bbMap.panTo(h.latlng, { animate: true, duration: .4 });

  document.getElementById('map-overlay').classList.add('active');
}

function closeMapCard() {
  document.getElementById('map-overlay').classList.remove('active');
  document.querySelectorAll('.lf-pin').forEach(el => el.classList.remove('highlighted'));
  activeMapHouseId = null;
}

function handleOverlayClick(e) {
  if (e.target === document.getElementById('map-overlay') ||
      e.target.classList.contains('map-sheet-backdrop')) {
    closeMapCard();
  }
}

function mapGoDetail() {
  if (!activeMapHouseId) return;
  state.currentHouseId = activeMapHouseId;
  closeMapCard();
  goTo('s-detail');
}

function mapGoInquiry() {
  if (!activeMapHouseId) return;
  state.currentHouseId = activeMapHouseId;
  closeMapCard();
  goTo('s-inquiry');
}

function mapHighlight(school, btn) {
  document.querySelectorAll('.map-spill').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  currentSchoolFilter = school;

  state.houses.forEach(h => {
    const marker = bbMarkers[h.id];
    if (!marker) return;
    let show = true;
    if (school === 'evsu')     show = h.distanceEVSU <= 8;
    else if (school === 'bcc') show = h.distanceBCC  <= 8;
    const el = marker.getElement();
    if (el) el.style.opacity = show ? '1' : '0.28';
  });

  closeMapCard();
}

// ════════════════════════════════════════
// TENANT — PROFILE SCREEN
// ════════════════════════════════════════
function renderTenantProfile() {
  const profile = state.tenantProfile || { name:'', room:'R1', houseId:1, rent:1500, paymentStatus:'paid' };
  const h  = state.houses.find(x => x.id === (profile.houseId || 1)) || state.houses[0];
  const room = (h?.rooms || []).find(r => r.name === profile.room) || h?.rooms?.[0];
  const tp = profiles.tenant || {};
  const sp = profiles.seeker || {};

  const el = (id,v) => { const e=document.getElementById(id); if(e) e.textContent = v||'—'; };
  const displayName = tp.name || sp.name || profile.name || 'Tenant';

  el('tp-disp-name',    displayName);
  el('tp-disp-school',  tp.school || sp.school || '—');
  el('tp-disp-room',    room?.name || 'R1');
  el('tp-disp-rent',    '₱' + (room?.amount || profile.rent || 1500).toLocaleString());

  const statusEl = document.getElementById('tp-disp-status');
  if(statusEl) {
    statusEl.textContent  = profile.paymentStatus === 'paid' ? 'Paid' : 'Pending';
    statusEl.style.color  = profile.paymentStatus === 'paid' ? '#4ADE80' : '#FCD34D';
  }

  el('tp-disp-fullname', tp.name || sp.name || '—');
  el('tp-disp-phone',    tp.phone || sp.phone || '—');
  el('tp-disp-course',   tp.course || sp.course || '—');
  el('tp-disp-gender',   tp.gender || sp.gender || '—');
  el('tp-disp-emname',   tp.emergencyName  || '—');
  el('tp-disp-emphone',  tp.emergencyPhone || '—');

  // Show uploaded photo if available
  const tPhoto = tp.photo || sp.photo || null;
  setAvatarEl('tp-avatar-img', 'tp-avatar-emoji', tPhoto, '<i class="ph ph-user-circle" style="font-size:32px;color:rgba(255,255,255,.8);"></i>');
}

// ════════════════════════════════════════
// TENANT — PAYMENT HISTORY
// ════════════════════════════════════════
if (!state.paymentLog) {
  // Generate the pending entry for the actual current month so the demo never shows stale dates
  const _now    = new Date();
  const _curMon = _now.toLocaleString('en-PH', { month: 'long', year: 'numeric' });
  const _dueStr = 'Due ' + _now.toLocaleString('en-PH', { month: 'short' }) + ' 1';
  state.paymentLog = [
    { id:1,  month:'June 2025',      amount:1500, status:'paid',    method:'GCash', date:'Jun 1, 2025'  },
    { id:2,  month:'July 2025',      amount:1500, status:'paid',    method:'GCash', date:'Jul 1, 2025'  },
    { id:3,  month:'August 2025',    amount:1500, status:'paid',    method:'GCash', date:'Aug 2, 2025'  },
    { id:4,  month:'September 2025', amount:1500, status:'paid',    method:'Cash',  date:'Sep 3, 2025'  },
    { id:5,  month:'October 2025',   amount:1500, status:'paid',    method:'GCash', date:'Oct 1, 2025'  },
    { id:6,  month:'November 2025',  amount:1500, status:'paid',    method:'GCash', date:'Nov 1, 2025'  },
    { id:7,  month:'December 2025',  amount:1500, status:'paid',    method:'GCash', date:'Dec 2, 2025'  },
    { id:8,  month:'January 2026',   amount:1500, status:'paid',    method:'GCash', date:'Jan 3, 2026'  },
    { id:9,  month:'February 2026',  amount:1500, status:'paid',    method:'GCash', date:'Feb 1, 2026'  },
    { id:10, month:_curMon,          amount:1500, status:'pending', method:'—',     date:_dueStr        },
  ];
}

function renderPaymentHistory() {
  const list  = document.getElementById('tpay-list');
  const empty = document.getElementById('tpay-empty');
  const total = document.getElementById('tpay-total');
  const sumEl = document.getElementById('tpay-summary');
  if (!list) return;

  const log  = state.paymentLog || [];
  const paid = log.filter(p => p.status === 'paid');
  const paidTotal = paid.reduce((s, p) => s + p.amount, 0);

  if (total) total.textContent = '₱' + paidTotal.toLocaleString();
  if (sumEl)  sumEl.textContent = paid.length + ' payment' + (paid.length !== 1 ? 's' : '') + ' on record';

  if (!log.length) { list.innerHTML = ''; if(empty) empty.style.display = ''; return; }
  if (empty) empty.style.display = 'none';

  list.innerHTML = log.map(p => {
    const isSelfReported = p.status === 'self_reported';
    const isPaid  = p.status === 'paid';
    const amtColor  = isPaid ? 'var(--green)' : isSelfReported ? 'var(--blue)' : 'var(--amber)';
    const statusLbl = isPaid ? 'Paid' : isSelfReported ? 'Awaiting confirmation' : 'Pending';
    return `<div class="card card-p" style="margin-bottom:8px;display:flex;justify-content:space-between;align-items:center;">
      <div>
        <div class="vc-name">${p.month}</div>
        <div class="rc-sub2">${p.date} · ${p.method}</div>
      </div>
      <div style="text-align:right;">
        <div style="font-family:'Nunito',sans-serif;font-size:15px;font-weight:900;color:${amtColor};">₱${p.amount.toLocaleString()}</div>
        <div style="font-size:11px;font-family:'Nunito',sans-serif;font-weight:700;color:${amtColor};">${statusLbl}</div>
      </div>
    </div>`;
  }).join('');
}

// ════════════════════════════════════════
// LANDLORD — WAITLIST MANAGER
// ════════════════════════════════════════
function renderWaitlistManager() {
  const el    = document.getElementById('wl-manager-list');
  const empty = document.getElementById('wl-manager-empty');
  if (!el) return;

  // Flatten all house waitlists
  const allEntries = [];
  state.houses.forEach(h => {
    (h.waitlist || []).forEach((name, idx) => {
      allEntries.push({ name, houseId: h.id, houseName: h.name, idx });
    });
  });

  if (!allEntries.length) {
    el.innerHTML = '';
    if (empty) empty.style.display = '';
    return;
  }
  if (empty) empty.style.display = 'none';

  el.innerHTML = allEntries.map((entry, pos) => `
    <div class="card card-p" style="margin-bottom:10px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:var(--warm2);border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="ph ph-user" style="font-size:20px;color:var(--muted);"></i>
          </div>
          <div>
            <div class="vc-name">${entry.name}</div>
            <div class="rc-sub2">${entry.houseName} · #${pos + 1} in line</div>
          </div>
        </div>
        <span class="tag ta2">Waiting</span>
      </div>
      <div style="display:flex;gap:8px;">
        <button onclick="promoteWaitlist('${entry.name}', ${entry.houseId}, ${entry.idx})" class="btn btn-teal" style="flex:2;justify-content:center;">
          <i class="ph ph-arrow-up-right"></i> Offer Room
        </button>
        <button onclick="removeWaitlist('${entry.name}', ${entry.houseId}, ${entry.idx})" class="btn-danger-sm" style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;">
          <i class="ph ph-x"></i> Remove
        </button>
      </div>
    </div>`).join('');
}

function promoteWaitlist(name, houseId, idx) {
  const h = state.houses.find(x => x.id === houseId);
  if (!h) return;
  const emptyRoom = h.rooms.find(r => r.status === 'empty');
  if (!emptyRoom) { showToast('No vacant rooms in this house'); return; }

  const code = String(Math.floor(100000 + Math.random() * 900000));
  state.pendingTenants.push({ id: state.nextId++, name, phone:'', room: emptyRoom.name, houseId, code, status:'pending' });
  h.waitlist.splice(idx, 1);
  save();

  // Populate and show invite-code modal
  const set = (id, v) => { const e = document.getElementById(id); if(e) e.textContent = v; };
  set('ic-code-display', code);
  set('ic-room-display', emptyRoom.name + ' — ' + h.name);
  set('ic-modal-sub', 'Share this code with ' + name + ' via text, Viber, or in person.');
  const copyBtn = document.getElementById('ic-copy-btn');
  if(copyBtn) copyBtn.onclick = () => {
    navigator.clipboard?.writeText(code).catch(()=>{});
    showToast('Code copied: ' + code);
  };
  document.getElementById('modal-invite-code').classList.remove('hidden');
  renderWaitlistManager();
}

function removeWaitlist(name, houseId, idx) {
  const h = state.houses.find(x => x.id === houseId);
  if (h) {
    h.waitlist.splice(idx, 1);
    save();
    renderWaitlistManager();
    showToast(name + ' removed from waitlist');
  }
}

