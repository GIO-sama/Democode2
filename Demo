<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Buhay Boarding</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>
<style>
/* ─── DESIGN TOKENS ─────────────────────────────── */
:root {
  --navy:      #0B1F3A;
  --navy2:     #112847;
  --blue:      #1558CC;
  --blue2:     #1A6AE8;
  --sky:       #3B91D4;
  --teal:      #0B7A6A;
  --teal2:     #0D9480;
  --warm:      #F5F3EF;
  --warm2:     #EDE9E3;
  --card:      #FFFFFF;
  --border:    #E4DDD5;
  --border2:   #D5CEC6;
  --text:      #111827;
  --text2:     #374151;
  --muted:     #6B7280;
  --muted2:    #9CA3AF;
  --red:       #C0392B;
  --redBg:     #FEF0EE;
  --amber:     #B45309;
  --amberBg:   #FEF3DC;
  --green:     #166534;
  --greenBg:   #DCFCE7;
  --purple:    #5B21B6;
  --purpleBg:  #EDE9FE;
  --blueLt:    #EFF6FF;
  --sh-xs:     0 1px 3px rgba(11,31,58,.06), 0 1px 2px rgba(11,31,58,.04);
  --sh-sm:     0 2px 8px rgba(11,31,58,.08), 0 1px 3px rgba(11,31,58,.05);
  --sh-md:     0 4px 16px rgba(11,31,58,.10), 0 2px 6px rgba(11,31,58,.06);
  --sh-lg:     0 8px 32px rgba(11,31,58,.14), 0 4px 12px rgba(11,31,58,.08);
  --sh-xl:     0 16px 48px rgba(11,31,58,.18), 0 6px 16px rgba(11,31,58,.10);
  --r-sm:      8px;
  --r:         12px;
  --r-lg:      16px;
  --r-xl:      20px;
}

/* ─── RESET & BASE ───────────────────────────────── */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
html, body { height:100%; }
body {
  font-family:'Nunito Sans', sans-serif;
  font-size:15px;
  color:var(--text);
  display:flex;
  justify-content:center;
  align-items:center;
  min-height:100vh;
  background: #0B1F3A;
  background-image:
    radial-gradient(ellipse 80% 50% at 20% 0%, rgba(21,88,204,.35) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 80% 100%, rgba(11,122,106,.2) 0%, transparent 60%);
}

/* ─── PHONE SHELL ────────────────────────────────── */
.phone {
  width:100%;
  max-width:420px;
  height:100vh;
  max-height:860px;
  background:var(--warm);
  overflow:hidden;
  position:relative;
  display:flex;
  flex-direction:column;
  box-shadow: var(--sh-xl), 0 0 0 1px rgba(255,255,255,.06);
}
@media(min-width:440px) {
  .phone { border-radius:40px; height:860px; }
}

/* ─── STATUS BAR ─────────────────────────────────── */
.sb {
  background:var(--navy);
  color:rgba(255,255,255,.75);
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:11px 22px 9px;
  font-family:'Nunito', sans-serif;
  font-size:12px;
  font-weight:700;
  flex-shrink:0;
  letter-spacing:.2px;
}
.sb-icons { display:flex; gap:5px; align-items:center; }

/* ─── SCREENS ────────────────────────────────────── */
.screen { display:none; flex-direction:column; flex:1; overflow:hidden; animation:screenIn .22s cubic-bezier(.4,0,.2,1); }
.screen.active { display:flex; }
@keyframes screenIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

/* ─── SCROLL ─────────────────────────────────────── */
.scroll { flex:1; overflow-y:auto; -webkit-overflow-scrolling:touch; }
.scroll::-webkit-scrollbar { display:none; }

/* ─── BOTTOM NAV ─────────────────────────────────── */
.bnav {
  position:absolute;
  bottom:0; left:0; right:0;
  background:rgba(255,255,255,.97);
  backdrop-filter:blur(16px);
  border-top:1px solid var(--border);
  display:flex;
  padding:6px 0 env(safe-area-inset-bottom,14px);
  z-index:100;
}
.ni {
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:3px;
  padding:5px 0;
  cursor:pointer;
  transition:opacity .15s;
  position:relative;
}
.ni:active { opacity:.6; }
.ni-ic { font-size:22px; line-height:1; color:var(--muted2); transition:color .2s; }
.ni-lb { font-family:'Nunito', sans-serif; font-size:10px; font-weight:700; color:var(--muted2); letter-spacing:.2px; transition:color .2s; }
.ni.on .ni-ic { color:var(--blue); }
.ni.on .ni-lb { color:var(--blue); }
.ni.on::after {
  content:'';
  position:absolute;
  top:0; left:50%;
  transform:translateX(-50%);
  width:20px; height:2px;
  background:var(--blue);
  border-radius:0 0 2px 2px;
}

/* ─── TYPOGRAPHY ─────────────────────────────────── */
.f-nun { font-family:'Nunito', sans-serif; }
.title-xl { font-family:'Nunito', sans-serif; font-size:22px; font-weight:900; color:var(--text); line-height:1.2; }
.title-lg { font-family:'Nunito', sans-serif; font-size:18px; font-weight:800; color:var(--text); }
.title-md { font-family:'Nunito', sans-serif; font-size:15px; font-weight:800; color:var(--text); }
.slbl { font-family:'Nunito', sans-serif; font-size:11px; font-weight:800; color:var(--muted); letter-spacing:.7px; text-transform:uppercase; }
.body-sm { font-size:13px; color:var(--muted); line-height:1.5; }

/* ─── BUTTONS ────────────────────────────────────── */
.btn { display:flex; align-items:center; justify-content:center; gap:7px; border:none; cursor:pointer; transition:all .18s; font-family:'Nunito', sans-serif; font-weight:800; border-radius:var(--r); }
.btn:active { transform:scale(.97); }

.btn-primary {
  background:var(--blue);
  color:#fff;
  padding:14px 20px;
  font-size:15px;
  width:100%;
  box-shadow:0 4px 14px rgba(21,88,204,.3);
}
.btn-primary:hover { background:var(--blue2); }

.btn-secondary {
  background:var(--warm2);
  color:var(--navy);
  border:1.5px solid var(--border);
  padding:14px 20px;
  font-size:15px;
  width:100%;
}
.btn-secondary:hover { background:var(--border); }

.btn-teal {
  background:var(--teal);
  color:#fff;
  padding:10px 16px;
  font-size:13px;
  box-shadow:0 3px 10px rgba(11,122,106,.25);
}

.btn-sm {
  padding:8px 14px;
  font-size:12px;
  border-radius:var(--r-sm);
}

.btn-danger-sm {
  background:var(--redBg);
  color:var(--red);
  padding:7px 12px;
  font-size:12px;
  border:none;
  cursor:pointer;
  border-radius:var(--r-sm);
  font-family:'Nunito', sans-serif;
  font-weight:800;
  transition:all .15s;
}
.btn-success-sm {
  background:var(--greenBg);
  color:var(--green);
  padding:7px 12px;
  font-size:12px;
  border:none;
  cursor:pointer;
  border-radius:var(--r-sm);
  font-family:'Nunito', sans-serif;
  font-weight:800;
  transition:all .15s;
}
.btn-ghost-sm {
  background:transparent;
  color:var(--navy);
  border:1.5px solid var(--border);
  padding:7px 12px;
  font-size:12px;
  border-radius:var(--r-sm);
  font-family:'Nunito', sans-serif;
  font-weight:700;
  cursor:pointer;
  transition:all .15s;
}

/* ─── CARDS ──────────────────────────────────────── */
.card {
  background:var(--card);
  border-radius:var(--r-lg);
  border:1px solid var(--border);
  box-shadow:var(--sh-sm);
}
.card-p { padding:16px; }

/* ─── FORM ELEMENTS ──────────────────────────────── */
.lbl {
  display:block;
  font-family:'Nunito', sans-serif;
  font-size:11px;
  font-weight:800;
  color:var(--navy);
  letter-spacing:.6px;
  text-transform:uppercase;
  margin-bottom:7px;
}
.inp, .sel, .ta {
  width:100%;
  background:var(--card);
  border:1.5px solid var(--border);
  border-radius:var(--r);
  padding:12px 15px;
  font-family:'Nunito Sans', sans-serif;
  font-size:15px;
  color:var(--text);
  outline:none;
  transition:border-color .2s, box-shadow .2s;
  -webkit-appearance:none;
}
.inp:focus, .sel:focus, .ta:focus {
  border-color:var(--blue);
  box-shadow:0 0 0 3px rgba(21,88,204,.1);
}
.ta { resize:none; height:88px; line-height:1.5; }
.hint { font-size:11px; color:var(--muted); margin-top:5px; line-height:1.4; }
.fg { margin-bottom:16px; }

/* ─── CHIPS ──────────────────────────────────────── */
.chip {
  background:var(--card);
  border:1.5px solid var(--border);
  border-radius:20px;
  padding:6px 14px;
  font-family:'Nunito', sans-serif;
  font-size:12px;
  font-weight:700;
  color:var(--muted);
  white-space:nowrap;
  cursor:pointer;
  flex-shrink:0;
  transition:all .18s;
}
.chip.on { background:var(--navy); border-color:var(--navy); color:#fff; }

/* ─── STATUS TAGS ────────────────────────────────── */
.tag {
  display:inline-flex;
  align-items:center;
  gap:4px;
  font-family:'Nunito', sans-serif;
  font-size:11px;
  font-weight:700;
  padding:4px 9px;
  border-radius:6px;
  letter-spacing:.1px;
}
.tg  { background:var(--greenBg); color:var(--green); }
.tr  { background:var(--redBg); color:var(--red); }
.ta2 { background:var(--amberBg); color:var(--amber); }
.tn  { background:rgba(11,31,58,.07); color:var(--navy); }
.tp  { background:var(--purpleBg); color:var(--purple); }
.tgn { background:var(--greenBg); color:var(--green); }

/* ─── TOP BAR ────────────────────────────────────── */
.topbar {
  background:var(--navy);
  padding:13px 18px 14px;
  display:flex;
  align-items:center;
  gap:12px;
  flex-shrink:0;
}
.topbar-title {
  font-family:'Nunito', sans-serif;
  font-size:16px;
  font-weight:800;
  color:#fff;
  flex:1;
  letter-spacing:-.1px;
}
.back {
  color:rgba(255,255,255,.75);
  font-size:20px;
  cursor:pointer;
  padding:4px;
  line-height:1;
  display:flex;
  align-items:center;
}

/* ─── CALLOUT ────────────────────────────────────── */
.callout {
  border-radius:var(--r);
  padding:13px 15px;
  display:flex;
  gap:11px;
  align-items:flex-start;
}
.callout-ic { font-size:18px; flex-shrink:0; margin-top:1px; }
.callout-txt { font-size:13px; line-height:1.5; }
.callout-txt strong { font-family:'Nunito', sans-serif; font-weight:800; }
.cl-warn    { background:var(--amberBg); color:var(--amber); }
.cl-info    { background:var(--blueLt); color:var(--blue); }
.cl-red     { background:var(--redBg); color:var(--red); }
.cl-green   { background:var(--greenBg); color:var(--green); }
.cl-purple  { background:var(--purpleBg); color:var(--purple); }

/* ─── TOAST ──────────────────────────────────────── */
.toast {
  position:absolute;
  bottom:96px; left:50%;
  transform:translateX(-50%) translateY(4px);
  background:var(--navy);
  color:#fff;
  font-family:'Nunito', sans-serif;
  font-size:13px;
  font-weight:700;
  padding:11px 22px;
  border-radius:24px;
  white-space:nowrap;
  z-index:999;
  opacity:0;
  transition:opacity .25s, transform .25s;
  pointer-events:none;
  box-shadow:var(--sh-lg);
  letter-spacing:.1px;
}
.toast.show { opacity:1; transform:translateX(-50%) translateY(0); }

/* ─── MODAL ──────────────────────────────────────── */
.modal-bg {
  position:absolute;
  inset:0;
  background:rgba(11,31,58,.6);
  z-index:200;
  display:flex;
  align-items:flex-end;
  backdrop-filter:blur(4px);
}
.modal {
  background:var(--warm);
  border-radius:22px 22px 0 0;
  padding:26px 20px 30px;
  width:100%;
  max-height:88%;
  overflow-y:auto;
  box-shadow:var(--sh-xl);
}
.modal-handle { width:34px; height:3px; background:var(--border2); border-radius:2px; margin:0 auto 20px; }
.modal-title { font-family:'Nunito', sans-serif; font-size:19px; font-weight:900; color:var(--text); margin-bottom:4px; }
.modal-sub { font-size:13px; color:var(--muted); margin-bottom:20px; line-height:1.45; }
.hidden { display:none!important; }

/* ═══════════════════════════════════════════════════
   ROLE SELECT
═══════════════════════════════════════════════════ */
#s-role {
  background:var(--navy);
  background-image:
    radial-gradient(ellipse 100% 60% at 50% -10%, rgba(21,88,204,.5) 0%, transparent 70%),
    radial-gradient(ellipse 60% 40% at 100% 100%, rgba(11,122,106,.2) 0%, transparent 60%);
}
.role-wrap {
  flex:1;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  padding:32px 24px;
}
.role-logo {
  font-family:'Nunito', sans-serif;
  font-size:30px;
  font-weight:900;
  color:#fff;
  margin-bottom:4px;
  letter-spacing:-.5px;
}
.role-logo span { color:#7CC8FA; }
.role-tagline {
  font-size:14px;
  color:rgba(255,255,255,.55);
  margin-bottom:36px;
  text-align:center;
  line-height:1.65;
  max-width:280px;
}
.role-cards { width:100%; display:flex; flex-direction:column; gap:10px; }
.role-card {
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.12);
  border-radius:var(--r-lg);
  padding:16px 18px;
  cursor:pointer;
  transition:all .2s;
  display:flex;
  align-items:center;
  gap:14px;
  backdrop-filter:blur(8px);
}
.role-card:active { transform:scale(.98); background:rgba(255,255,255,.13); }
.role-ic {
  width:44px; height:44px;
  background:rgba(255,255,255,.1);
  border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  font-size:22px;
  flex-shrink:0;
  border:1px solid rgba(255,255,255,.1);
}
.role-name { font-family:'Nunito', sans-serif; font-size:15px; font-weight:800; color:#fff; margin-bottom:2px; }
.role-desc { font-size:12px; color:rgba(255,255,255,.5); line-height:1.4; }
.role-arrow { margin-left:auto; color:rgba(255,255,255,.35); font-size:20px; flex-shrink:0; display:flex; align-items:center; }

/* ═══════════════════════════════════════════════════
   SEEKER — HOME
═══════════════════════════════════════════════════ */
.shdr {
  background:var(--navy);
  background-image:radial-gradient(ellipse 100% 100% at 50% -20%, rgba(21,88,204,.45) 0%, transparent 70%);
  padding:16px 18px 22px;
  flex-shrink:0;
}
.shdr-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px; }
.shdr-greet { color:rgba(255,255,255,.55); font-size:12px; font-weight:600; margin-bottom:3px; letter-spacing:.2px; }
.shdr-title { font-family:'Nunito', sans-serif; font-size:22px; font-weight:900; color:#fff; letter-spacing:-.3px; }
.shdr-title span { color:#7CC8FA; }
.av-btn {
  width:38px; height:38px;
  background:rgba(255,255,255,.1);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:18px;
  cursor:pointer;
  border:1px solid rgba(255,255,255,.16);
  transition:background .2s;
}
.av-btn:active { background:rgba(255,255,255,.18); }

.sc-toggle {
  display:flex;
  background:rgba(255,255,255,.1);
  border-radius:24px;
  padding:3px;
  gap:2px;
  margin-bottom:12px;
}
.sc-btn {
  flex:1;
  padding:7px 8px;
  border-radius:20px;
  border:none;
  background:transparent;
  color:rgba(255,255,255,.6);
  font-family:'Nunito', sans-serif;
  font-size:12px;
  font-weight:700;
  cursor:pointer;
  transition:all .2s;
  text-align:center;
}
.sc-btn.on { background:#fff; color:var(--navy); }

.srch {
  background:rgba(255,255,255,.97);
  border-radius:12px;
  display:flex;
  align-items:center;
  padding:9px 13px;
  gap:9px;
  box-shadow:0 2px 12px rgba(0,0,0,.15);
}
.srch input {
  flex:1; border:none; outline:none;
  font-family:'Nunito Sans', sans-serif;
  font-size:14px;
  color:var(--text);
  background:transparent;
}
.srch input::placeholder { color:var(--muted2); }
.srch-ic { color:var(--muted); font-size:18px; display:flex; align-items:center; }
.fil-btn {
  background:var(--navy);
  color:#fff;
  border:none;
  border-radius:8px;
  padding:6px 10px;
  font-size:12px;
  cursor:pointer;
  display:flex;
  align-items:center;
}

.filter-row {
  display:flex;
  gap:7px;
  padding:12px 16px 4px;
  overflow-x:auto;
  flex-shrink:0;
}
.filter-row::-webkit-scrollbar { display:none; }

/* Listing cards */
.cards-list { padding:0 14px; display:flex; flex-direction:column; gap:12px; }
.lcard {
  background:var(--card);
  border-radius:var(--r-xl);
  overflow:hidden;
  box-shadow:var(--sh-sm);
  cursor:pointer;
  transition:transform .15s, box-shadow .15s;
  border:1px solid var(--border);
}
.lcard:active { transform:scale(.985); box-shadow:var(--sh-xs); }
.lcard-img { height:140px; position:relative; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.lcard-img-ph { font-size:48px; opacity:.2; }
.lcard-badge {
  position:absolute; top:10px; left:10px;
  color:#fff;
  font-family:'Nunito', sans-serif;
  font-size:10px; font-weight:800;
  padding:4px 10px;
  border-radius:20px;
  letter-spacing:.3px;
  text-transform:uppercase;
  backdrop-filter:blur(8px);
}
.lcard-rooms {
  position:absolute; bottom:10px; right:10px;
  background:rgba(255,255,255,.92);
  color:var(--navy);
  font-family:'Nunito', sans-serif;
  font-size:11px; font-weight:700;
  padding:4px 10px;
  border-radius:20px;
  backdrop-filter:blur(4px);
}
.lcard-body { padding:14px 15px 15px; }
.lcard-name { font-family:'Nunito', sans-serif; font-size:15px; font-weight:800; color:var(--text); margin-bottom:3px; }
.lcard-loc { font-size:12px; color:var(--muted); margin-bottom:9px; display:flex; align-items:center; gap:4px; }
.lcard-tags { display:flex; flex-wrap:wrap; gap:5px; margin-bottom:11px; }
.lcard-foot { display:flex; justify-content:space-between; align-items:center; padding-top:10px; border-top:1px solid var(--border); }
.lcard-price { font-family:'Nunito', sans-serif; font-weight:900; font-size:18px; color:var(--navy); }
.lcard-price span { font-size:12px; font-weight:600; color:var(--muted); }

/* ═══════════════════════════════════════════════════
   SEEKER — DETAIL
═══════════════════════════════════════════════════ */
.dhero { height:196px; position:relative; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.dhero-ph { font-size:64px; opacity:.18; }
.dhero-vbadge {
  position:absolute; bottom:14px; left:14px;
  background:var(--teal);
  color:#fff;
  font-family:'Nunito', sans-serif; font-size:10px; font-weight:800;
  padding:5px 11px; border-radius:20px;
  letter-spacing:.3px;
}
.dhero-photos {
  position:absolute; bottom:14px; right:14px;
  background:rgba(0,0,0,.42);
  color:#fff;
  font-family:'Nunito', sans-serif; font-size:11px; font-weight:700;
  padding:5px 11px; border-radius:20px;
  backdrop-filter:blur(4px);
}
.dbody { padding:18px 16px 0; }
.dname { font-family:'Nunito', sans-serif; font-size:22px; font-weight:900; color:var(--text); margin-bottom:4px; line-height:1.2; }
.dloc { font-size:13px; color:var(--muted); margin-bottom:16px; display:flex; align-items:center; gap:5px; }

.snap { background:var(--card); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:12px; box-shadow:var(--sh-xs); }
.snap-title { font-family:'Nunito', sans-serif; font-size:10px; font-weight:800; color:var(--muted); letter-spacing:.8px; text-transform:uppercase; margin-bottom:14px; }
.snap-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.snap-itm { display:flex; flex-direction:column; gap:3px; }
.snap-lbl { font-size:11px; color:var(--muted); font-weight:600; }
.snap-val { font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; color:var(--text); }
.snap-val.g { color:var(--green); } .snap-val.r { color:var(--red); } .snap-val.a { color:var(--amber); }

.rules-box { background:var(--card); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:12px; }
.rule-row { display:flex; justify-content:space-between; align-items:center; padding:9px 0; border-bottom:1px solid var(--border); }
.rule-row:last-child { border-bottom:none; }
.rule-nm { font-size:13px; font-weight:600; color:var(--text); display:flex; align-items:center; gap:8px; }
.rstatus { font-family:'Nunito', sans-serif; font-size:11px; font-weight:800; padding:4px 9px; border-radius:6px; }
.ryes { background:var(--greenBg); color:var(--green); }
.rno  { background:var(--redBg); color:var(--red); }
.rpartial { background:var(--amberBg); color:var(--amber); }

.dactions {
  display:flex; gap:10px; padding:14px 16px;
  flex-shrink:0; background:var(--warm);
  border-top:1px solid var(--border);
}

/* ═══════════════════════════════════════════════════
   FORMS (Inquiry, Visit, Waitlist)
═══════════════════════════════════════════════════ */
.fscroll { flex:1; overflow-y:auto; padding:18px 16px 100px; }
.fintro {
  background:var(--card);
  border-radius:var(--r-lg);
  padding:14px 15px;
  border:1px solid var(--border);
  margin-bottom:20px;
  display:flex;
  gap:12px;
  align-items:flex-start;
  box-shadow:var(--sh-xs);
}
.fintro-ic { font-size:20px; flex-shrink:0; margin-top:1px; }
.fintro-txt { font-size:13px; color:var(--muted); line-height:1.55; }
.fintro-txt strong { color:var(--text); font-weight:700; }
.ffoot {
  position:sticky; bottom:0;
  background:var(--warm);
  padding:12px 16px 80px;
  border-top:1px solid var(--border);
}

/* Visit scheduler */
.cal-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:18px; }
.slot {
  background:var(--card);
  border:1.5px solid var(--border);
  border-radius:var(--r);
  padding:12px 8px;
  text-align:center;
  cursor:pointer;
  transition:all .2s;
}
.slot:active, .slot.on { background:var(--navy); border-color:var(--navy); }
.slot.on .slot-date, .slot.on .slot-time { color:#fff; }
.slot.taken { background:var(--warm2); cursor:default; opacity:.5; }
.slot-date { font-family:'Nunito', sans-serif; font-size:11px; font-weight:800; color:var(--text); margin-bottom:3px; }
.slot-time { font-size:11px; color:var(--muted); }

/* My Inquiries */
.inq-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:14px 15px;
  margin-bottom:9px;
  cursor:pointer;
  box-shadow:var(--sh-xs);
  transition:box-shadow .15s;
}
.inq-item:active { box-shadow:none; }
.inq-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:7px; }
.inq-house { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); }
.inq-time { font-size:11px; color:var(--muted2); }
.inq-status { display:flex; align-items:center; gap:6px; margin-bottom:5px; }
.sdot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
@keyframes pulse-dot {
  0%,100% { opacity:1; transform:scale(1); }
  50% { opacity:.4; transform:scale(.65); }
}
.sdot-pulse { animation:pulse-dot 1.5s ease-in-out infinite; }
.inq-q { font-size:13px; color:var(--muted); line-height:1.4; }

/* ═══════════════════════════════════════════════════
   TENANT — HOME
═══════════════════════════════════════════════════ */
.thdr {
  background:var(--teal);
  background-image:radial-gradient(ellipse 100% 80% at 50% -20%, rgba(13,148,128,.5) 0%, transparent 70%);
  padding:16px 18px 22px;
  flex-shrink:0;
}
.thdr-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:14px; }
.thdr-greet { color:rgba(255,255,255,.6); font-size:12px; font-weight:600; margin-bottom:3px; }
.thdr-title { font-family:'Nunito', sans-serif; font-size:20px; font-weight:900; color:#fff; letter-spacing:-.2px; }
.house-pill {
  background:rgba(255,255,255,.14);
  border-radius:12px;
  padding:11px 14px;
  display:flex;
  align-items:center;
  gap:11px;
  border:1px solid rgba(255,255,255,.12);
}
.hp-ic { font-size:20px; }
.hp-name { font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; color:#fff; }
.hp-addr { font-size:11px; color:rgba(255,255,255,.6); margin-top:1px; }

.ann-card {
  background:var(--card);
  border-radius:var(--r-lg);
  border:1px solid var(--border);
  padding:14px 15px;
  margin-bottom:9px;
  cursor:pointer;
  transition:box-shadow .15s;
  box-shadow:var(--sh-xs);
}
.ann-card:active { box-shadow:none; background:var(--warm2); }
.ann-hdr { display:flex; gap:11px; align-items:flex-start; margin-bottom:7px; }
.new-dot { width:8px; height:8px; background:var(--blue); border-radius:50%; margin-top:5px; flex-shrink:0; margin-left:auto; }
.ann-ic { font-size:20px; flex-shrink:0; }
.ann-title { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); margin-bottom:3px; flex:1; }
.ann-body { font-size:13px; color:var(--muted); line-height:1.45; }
.ann-time { font-size:11px; color:var(--muted2); margin-top:6px; }

/* ═══════════════════════════════════════════════════
   TENANT — HOUSE INFO
═══════════════════════════════════════════════════ */
.info-section { background:var(--card); border-radius:var(--r-lg); border:1px solid var(--border); padding:16px; margin-bottom:12px; box-shadow:var(--sh-xs); }
.info-sec-title { font-family:'Nunito', sans-serif; font-size:10px; font-weight:800; color:var(--muted); letter-spacing:.8px; text-transform:uppercase; margin-bottom:12px; }
.info-row { display:flex; justify-content:space-between; align-items:center; padding:9px 0; border-bottom:1px solid var(--border); }
.info-row:last-child { border-bottom:none; }
.info-lbl { font-size:13px; color:var(--muted); }
.info-val { font-family:'Nunito', sans-serif; font-size:13px; font-weight:700; color:var(--text); text-align:right; }
.info-val.link { color:var(--blue); }

/* ═══════════════════════════════════════════════════
   TENANT — MAINTENANCE
═══════════════════════════════════════════════════ */
.mreq-item {
  background:var(--card);
  border-radius:var(--r-lg);
  border:1px solid var(--border);
  padding:14px 15px;
  margin-bottom:9px;
  display:flex;
  gap:11px;
  align-items:flex-start;
  box-shadow:var(--sh-xs);
}
.mreq-ic { font-size:20px; flex-shrink:0; margin-top:1px; }
.mreq-title { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); margin-bottom:3px; }
.mreq-desc { font-size:12px; color:var(--muted); margin-bottom:6px; }
.mreq-foot { display:flex; gap:6px; align-items:center; }

/* ═══════════════════════════════════════════════════
   LANDLORD — DASHBOARD
═══════════════════════════════════════════════════ */
.lhdr {
  background:var(--navy);
  background-image:radial-gradient(ellipse 120% 80% at 60% -20%, rgba(21,88,204,.4) 0%, transparent 65%);
  padding:16px 18px 20px;
  flex-shrink:0;
}
.lhdr-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px; }
.lhdr-greet { color:rgba(255,255,255,.55); font-size:12px; font-weight:600; margin-bottom:3px; letter-spacing:.1px; }
.lhdr-name { font-family:'Nunito', sans-serif; font-size:20px; font-weight:900; color:#fff; letter-spacing:-.2px; }

.income-card {
  background:rgba(255,255,255,.08);
  border-radius:var(--r-lg);
  padding:15px;
  border:1px solid rgba(255,255,255,.1);
}
.ic-lbl { font-family:'Nunito', sans-serif; font-size:10px; font-weight:800; color:rgba(255,255,255,.45); letter-spacing:.9px; text-transform:uppercase; margin-bottom:4px; }
.ic-amt { font-family:'Nunito', sans-serif; font-size:28px; font-weight:900; color:#fff; margin-bottom:12px; letter-spacing:-.5px; }
.ic-amt span { font-size:16px; font-weight:600; opacity:.65; }
.ic-row { display:flex; gap:8px; }
.ic-pill { background:rgba(255,255,255,.08); border-radius:10px; padding:8px 10px; flex:1; text-align:center; border:1px solid rgba(255,255,255,.07); }
.ic-pill-v { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:#fff; display:block; }
.ic-pill-l { font-size:10px; color:rgba(255,255,255,.45); font-weight:600; }

/* Room grid */
.rg { display:grid; grid-template-columns:repeat(4,1fr); gap:7px; margin-bottom:14px; }
.rt {
  background:var(--card);
  border-radius:10px;
  padding:9px 7px;
  text-align:center;
  border:1px solid var(--border);
  cursor:pointer;
  transition:all .15s;
  box-shadow:var(--sh-xs);
}
.rt:active { transform:scale(.95); }
.rt-num { font-family:'Nunito', sans-serif; font-size:11px; font-weight:800; color:var(--muted); margin-bottom:4px; }
.rt-st { font-family:'Nunito', sans-serif; font-size:10px; font-weight:800; padding:2px 4px; border-radius:4px; }
.st-paid  { color:var(--green); }
.st-pend  { color:var(--amber); background:var(--amberBg); border-radius:4px; padding:2px 5px; }
.st-empty { background:var(--warm2); color:var(--muted); border-radius:4px; padding:2px 5px; }

/* Quick actions */
.qa-grid { display:flex; gap:8px; overflow-x:auto; padding-bottom:2px; }
.qa-grid::-webkit-scrollbar { display:none; }
.qa-btn {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:12px 14px;
  text-align:center;
  cursor:pointer;
  flex-shrink:0;
  transition:all .15s;
  min-width:78px;
  box-shadow:var(--sh-xs);
}
.qa-btn:active { background:var(--warm2); }
.qa-ic { font-size:20px; margin-bottom:4px; color:var(--navy); }
.qa-lbl { font-family:'Nunito', sans-serif; font-size:10px; font-weight:800; color:var(--navy); line-height:1.2; }

/* Vacancy alert */
.vac-alert {
  background:var(--redBg);
  border:1px solid rgba(192,57,43,.15);
  border-radius:var(--r-lg);
  padding:13px 15px;
  display:flex;
  gap:10px;
  align-items:flex-start;
}
.vac-txt { font-size:13px; color:var(--red); line-height:1.4; }
.vac-txt strong { font-family:'Nunito', sans-serif; font-weight:800; }

/* Inbox */
.inbox-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:14px;
  padding:14px 14px 14px 16px;
  margin-bottom:9px;
  cursor:pointer;
  display:flex;
  gap:12px;
  align-items:center;
  transition:all .15s;
  box-shadow: 0 1px 4px rgba(11,31,58,.07);
  position: relative;
  overflow: hidden;
}
.inbox-item::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  background: var(--blue);
  border-radius: 14px 0 0 14px;
  opacity: 0;
  transition: opacity .15s;
}
.inbox-item[data-pending="true"]::before { opacity: 1; }
.inbox-item:active { transform:scale(.99); box-shadow:none; background: var(--warm); }
.iav {
  width:44px; height:44px;
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:22px;
  flex-shrink:0;
  background: linear-gradient(135deg, var(--blueLt), rgba(59,145,212,.15));
  border: 1.5px solid rgba(21,88,204,.12);
}
.icontent { flex:1; min-width:0; }
.iname { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); margin-bottom:2px; }
.imeta { font-size:11px; color:var(--muted); margin-bottom:5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.iq { font-size:12px; color:var(--text2); line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
.itime { font-size:10px; color:var(--muted2); white-space:nowrap; flex-shrink:0; }
.ndot { width:8px; height:8px; background:var(--blue); border-radius:50%; flex-shrink:0; box-shadow:0 0 0 3px rgba(21,88,204,.18); }

/* Expense */
.exp-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:13px 15px;
  margin-bottom:8px;
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  box-shadow:var(--sh-xs);
}
.exp-left { display:flex; gap:10px; align-items:flex-start; }
.exp-ic { font-size:20px; flex-shrink:0; }
.exp-name { font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; color:var(--text); margin-bottom:2px; }
.exp-cat { font-size:11px; color:var(--muted); }
.exp-amt { font-family:'Nunito', sans-serif; font-size:15px; font-weight:900; color:var(--red); }
.exp-date { font-size:11px; color:var(--muted2); text-align:right; }

/* Maintenance tracker landlord */
.mt-item {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:13px 15px;
  margin-bottom:8px;
  box-shadow:var(--sh-xs);
}
.mt-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:5px; }
.mt-title { font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; color:var(--text); }
.mt-room { font-size:11px; color:var(--muted); margin-bottom:5px; }
.mt-desc { font-size:12px; color:var(--muted); line-height:1.4; margin-bottom:9px; }
.mt-foot { display:flex; gap:7px; align-items:center; }

/* Section wrapper */
.sec { padding:14px 14px 0; }
.sec-hdr { display:flex; justify-content:space-between; align-items:center; margin-bottom:11px; }

/* Primary actions (Landlord) */
.primary-actions { display:flex; flex-direction:column; gap:9px; padding:14px 14px 0; }
.pa-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:15px 16px;
  display:flex;
  align-items:center;
  gap:14px;
  cursor:pointer;
  transition:all .15s;
  box-shadow:var(--sh-xs);
}
.pa-card:active { transform:scale(.98); background:var(--warm2); }
.pa-card.primary { background:var(--navy); border-color:var(--navy); box-shadow:var(--sh-sm); }
.pa-card.primary .pa-title { color:#fff; }
.pa-card.primary .pa-sub { color:rgba(255,255,255,.55); }
.pa-ic-wrap { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.pa-ic-wrap.navy { background:rgba(255,255,255,.1); }
.pa-ic-wrap.blue { background:var(--blueLt); }
.pa-ic-wrap.teal { background:var(--greenBg); }
.pa-ic-wrap.amber { background:var(--amberBg); }
.pa-title { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); }
.pa-sub { font-size:12px; color:var(--muted); margin-top:2px; }
.pa-badge {
  margin-left:auto;
  background:var(--red);
  color:#fff;
  font-family:'Nunito', sans-serif;
  font-size:11px; font-weight:800;
  padding:3px 9px;
  border-radius:20px;
  flex-shrink:0;
}
.pa-arrow { margin-left:auto; color:var(--muted2); font-size:18px; flex-shrink:0; display:flex; align-items:center; }

/* Room info card (tenant) */
.room-info-card {
  background:linear-gradient(135deg,var(--teal),#0B6357);
  border-radius:var(--r-xl);
  padding:18px;
  margin-bottom:14px;
  color:#fff;
  display:flex;
  justify-content:space-between;
  align-items:center;
  box-shadow:0 6px 20px rgba(11,122,106,.25);
}
.ric-room { font-family:'Nunito', sans-serif; font-size:20px; font-weight:900; margin-bottom:2px; }
.ric-house { font-size:12px; opacity:.75; }
.ric-paid {
  display:inline-flex;
  align-items:center;
  gap:4px;
  background:rgba(255,255,255,.18);
  border-radius:20px;
  padding:4px 11px;
  font-size:11px;
  font-weight:700;
  margin-top:6px;
}
.ric-rent { font-family:'Nunito', sans-serif; font-size:22px; font-weight:900; }
.ric-due { font-size:11px; opacity:.7; margin-top:2px; }

/* Report button */
.report-btn {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:14px 16px;
  display:flex;
  align-items:center;
  gap:13px;
  cursor:pointer;
  margin-bottom:14px;
  transition:all .15s;
  box-shadow:var(--sh-xs);
}
.report-btn:active { background:var(--warm2); }
.report-ic { width:42px; height:42px; background:var(--redBg); border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.report-text { flex:1; }
.report-title { font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; color:var(--text); }
.report-sub { font-size:12px; color:var(--muted); margin-top:1px; }
.report-arrow { color:var(--muted2); font-size:18px; display:flex; align-items:center; }

/* Empty states */
.empty-fil { text-align:center; padding:36px 20px; color:var(--muted); }
.empty-fil-ic { font-size:40px; margin-bottom:12px; }
.empty-fil-title { font-family:'Nunito', sans-serif; font-size:16px; font-weight:800; color:var(--text); margin-bottom:6px; }
.empty-fil-sub { font-size:13px; line-height:1.5; }

/* Tenant Registration */
.reg-wrap { display:flex; flex-direction:column; height:100%; background:var(--warm); }
.reg-hero {
  background:linear-gradient(140deg,var(--teal),#0B6357);
  padding:32px 24px 28px;
  color:#fff;
}
.reg-hero-title { font-family:'Nunito', sans-serif; font-size:22px; font-weight:900; margin-bottom:6px; letter-spacing:-.2px; }
.reg-hero-sub { font-size:13px; opacity:.8; line-height:1.5; }
.reg-body { padding:24px 20px; flex:1; }
.reg-step { font-size:11px; font-weight:700; color:var(--teal); text-transform:uppercase; letter-spacing:.5px; margin-bottom:16px; }

.otp-row { display:flex; gap:8px; margin-top:4px; }
.otp-inp {
  flex:1; height:50px;
  border:1.5px solid var(--border);
  border-radius:var(--r);
  font-family:'Nunito', sans-serif;
  font-size:22px; font-weight:800;
  text-align:center;
  color:var(--navy);
  background:#fff;
  outline:none;
  transition:border .2s, box-shadow .2s;
}
.otp-inp:focus { border-color:var(--teal); box-shadow:0 0 0 3px rgba(11,122,106,.1); }

.reg-code-box {
  background:linear-gradient(135deg,var(--navy),var(--blue));
  border-radius:var(--r-lg);
  padding:18px 20px;
  margin-bottom:18px;
  color:#fff;
  text-align:center;
}
.reg-code-lbl { font-size:12px; opacity:.65; margin-bottom:6px; }
.reg-code-val { font-family:'Nunito', sans-serif; font-size:32px; font-weight:900; letter-spacing:6px; }

/* Tenant Management */
.tenant-card {
  background:var(--card);
  border:1px solid var(--border);
  border-radius:var(--r-lg);
  padding:15px;
  margin-bottom:9px;
  box-shadow:var(--sh-xs);
}
.tc-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:8px; }
.tc-name { font-family:'Nunito', sans-serif; font-size:14px; font-weight:800; color:var(--text); }
.tc-room { font-size:11px; color:var(--muted); margin-top:2px; }
.tc-status-active { display:inline-flex; align-items:center; gap:4px; background:var(--greenBg); color:var(--green); font-size:11px; font-weight:700; padding:4px 10px; border-radius:20px; }
.tc-status-pending { display:inline-flex; align-items:center; gap:4px; background:var(--amberBg); color:var(--amber); font-size:11px; font-weight:700; padding:4px 10px; border-radius:20px; }
.tc-code { display:flex; align-items:center; gap:9px; background:var(--warm); border-radius:9px; padding:9px 12px; margin-top:6px; border:1px solid var(--border); }
.tc-code-lbl { font-size:11px; color:var(--muted); flex:1; }
.tc-code-val { font-family:'Nunito', sans-serif; font-size:16px; font-weight:900; color:var(--navy); letter-spacing:3px; }
.tc-code-copy { font-size:11px; color:var(--blue); font-weight:700; cursor:pointer; }

/* QR Code */
.qr-wrap { display:flex; flex-direction:column; align-items:center; padding:28px 24px; text-align:center; }
.qr-title { font-family:'Nunito', sans-serif; font-size:18px; font-weight:900; color:var(--navy); margin-bottom:6px; }
.qr-sub { font-size:13px; color:var(--muted); margin-bottom:24px; line-height:1.5; }
.qr-box { background:#fff; border-radius:var(--r-xl); padding:22px; box-shadow:var(--sh-lg); margin-bottom:20px; border:1px solid var(--border); }
.qr-house { background:var(--navy); color:#fff; border-radius:10px; padding:10px 18px; font-family:'Nunito', sans-serif; font-size:13px; font-weight:800; margin-bottom:18px; display:inline-block; }
.qr-instruction { background:var(--blueLt); border-radius:var(--r-lg); padding:15px 17px; text-align:left; width:100%; border:1px solid rgba(21,88,204,.1); }
.qr-step { display:flex; gap:10px; align-items:flex-start; margin-bottom:11px; font-size:13px; color:var(--text); line-height:1.4; }
.qr-step:last-child { margin-bottom:0; }
.qr-step-num { background:var(--blue); color:#fff; border-radius:50%; width:20px; height:20px; display:flex; align-items:center; justify-content:center; font-family:'Nunito', sans-serif; font-size:11px; font-weight:800; flex-shrink:0; margin-top:1px; }

/* Success screen */
.success-wrap { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px 24px; text-align:center; background:var(--warm); }
.success-icon-wrap { width:80px; height:80px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:20px; font-size:36px; }

/* Invite code display */
.invite-display { background:linear-gradient(135deg,var(--navy),var(--blue)); border-radius:var(--r-xl); padding:22px; text-align:center; margin:12px 0; box-shadow:var(--sh-md); }
.invite-lbl { font-size:12px; color:rgba(255,255,255,.65); margin-bottom:8px; letter-spacing:.3px; }
.invite-code { font-family:'Nunito', sans-serif; font-size:36px; font-weight:900; color:#fff; letter-spacing:8px; }
.invite-room { font-size:12px; color:rgba(255,255,255,.6); margin-top:6px; }
.invite-hint { font-size:12px; color:var(--muted); text-align:center; margin-top:10px; line-height:1.5; }
/* ══════════════════════════════════════════════
   PROFILE CREATION & LANDLORD ONBOARDING STYLES
══════════════════════════════════════════════ */

/* ── Setup / Profile Creation shared ── */
.setup-wrap{display:flex;flex-direction:column;height:100%;}
.setup-hero{padding:28px 22px 24px;flex-shrink:0;position:relative;}
.setup-hero.seeker-grad{background:linear-gradient(160deg,#0B1F3A 0%,#0D2B45 50%,#1558CC 100%);}
.setup-hero.landlord-grad{background:linear-gradient(160deg,#0B1F3A 0%,#142840 50%,#0B5E4A 100%);}
.setup-hero.newlandlord-grad{background:linear-gradient(160deg,#1A0533 0%,#2D1065 50%,#4C1D95 100%);}
.setup-step-dots{display:flex;gap:6px;margin-bottom:20px;}
.sdot-step{width:6px;height:6px;border-radius:3px;background:rgba(255,255,255,.25);transition:all .3s;}
.sdot-step.on{width:20px;background:#fff;}
.setup-hero-icon{width:52px;height:52px;background:rgba(255,255,255,.15);border-radius:15px;display:flex;align-items:center;justify-content:center;margin-bottom:14px;border:1px solid rgba(255,255,255,.2);}
.setup-hero-title{font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;color:#fff;margin-bottom:4px;}
.setup-hero-sub{font-size:13px;color:rgba(255,255,255,.7);line-height:1.5;}
.setup-body{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:22px 18px 100px;}
.setup-body::-webkit-scrollbar{display:none;}
.setup-section{background:var(--card);border-radius:var(--r-lg);border:1px solid var(--border);padding:18px;margin-bottom:14px;box-shadow:var(--sh-sm);}
.setup-section-title{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:16px;}
.setup-row{margin-bottom:14px;}
.setup-row:last-child{margin-bottom:0;}
.setup-foot{position:sticky;bottom:0;background:var(--warm);padding:12px 18px 20px;border-top:1px solid var(--border);display:flex;flex-direction:column;gap:8px;flex-shrink:0;}

/* ── Avatar picker ── */
.avatar-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-top:4px;}
.avatar-opt{width:100%;aspect-ratio:1;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;border:2px solid var(--border);cursor:pointer;transition:all .2s;background:var(--warm);}
.avatar-opt.selected{border-color:var(--blue);background:var(--blueLt);box-shadow:0 0 0 3px rgba(21,88,204,.15);}

/* ─── UNIVERSAL BACK BUTTON ──────────────────── */
#univ-back {
  position:absolute;
  bottom:80px;
  left:16px;
  z-index:999;
  width:44px;
  height:44px;
  background:var(--card);
  border:1.5px solid var(--border2);
  border-radius:50%;
  display:none;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  box-shadow:var(--sh-md);
  transition:all .18s;
  color:var(--navy);
  font-size:19px;
}
#univ-back:active { transform:scale(.93); background:var(--warm); }
#univ-back.visible { display:flex; }

/* ─── ID PHOTO UPLOAD ─────────────────────────── */
.id-photo-upload-wrap {
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:12px;
  padding:16px 0 8px;
}
.id-photo-preview {
  width:96px;
  height:96px;
  border-radius:50%;
  border:2.5px solid var(--border);
  background:var(--warm2);
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
  cursor:pointer;
  position:relative;
  transition:border-color .18s;
}
.id-photo-preview:hover { border-color:var(--blue); }
.id-photo-preview img {
  width:100%;
  height:100%;
  object-fit:cover;
  position:absolute;
  top:0; left:0;
  display:none;
}
.id-photo-preview.has-photo img { display:block; }
.id-photo-preview.has-photo .id-photo-icon { display:none; }
.id-photo-preview .id-photo-icon {
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:4px;
  color:var(--muted);
  font-size:11px;
  text-align:center;
  font-family:'Nunito',sans-serif;
  font-weight:600;
  pointer-events:none;
}
.id-photo-preview .id-photo-icon i { font-size:28px; color:var(--muted2); }
.id-photo-upload-btn {
  font-size:12px;
  color:var(--blue);
  font-family:'Nunito',sans-serif;
  font-weight:700;
  cursor:pointer;
  padding:6px 14px;
  border:1.5px solid var(--blue);
  border-radius:20px;
  background:var(--blueLt);
  transition:all .15s;
}
.id-photo-upload-btn:active { background:rgba(21,88,204,.15); }
.sprofile-av img, .lprofile-av img {
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:50%;
}

/* ─── GENDER SELECT PILLS ─────────────────────── */
.gender-pills { display:flex; gap:8px; flex-wrap:wrap; margin-top:6px; }
.gender-pill {
  padding:7px 16px;
  border-radius:20px;
  border:1.5px solid var(--border);
  font-family:'Nunito',sans-serif;
  font-size:13px;
  font-weight:700;
  cursor:pointer;
  transition:all .15s;
  background:var(--warm);
  color:var(--text2);
}
.gender-pill.selected { border-color:var(--blue); background:var(--blueLt); color:var(--blue); }
.gender-pill.teal-sel.selected { border-color:var(--teal); background:#F0FDFA; color:var(--teal); }
.opt-badge {
  display:inline-block;
  font-size:10px;
  font-family:'Nunito',sans-serif;
  font-weight:700;
  color:var(--muted);
  background:var(--warm2);
  border:1px solid var(--border);
  border-radius:10px;
  padding:1px 7px;
  margin-left:6px;
  vertical-align:middle;
}

/* ── Budget slider row ── */
.budget-display{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;color:var(--navy);margin-bottom:10px;}
.range-inp{width:100%;-webkit-appearance:none;height:5px;border-radius:3px;background:var(--border);outline:none;}
.range-inp::-webkit-slider-thumb{-webkit-appearance:none;width:22px;height:22px;border-radius:50%;background:var(--blue);cursor:pointer;border:3px solid #fff;box-shadow:0 2px 8px rgba(21,88,204,.3);}

/* ── Toggle row ── */
.tog-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);}
.tog-row:last-child{border-bottom:none;padding-bottom:0;}
.tog-info{flex:1;}
.tog-lbl{font-size:14px;font-weight:600;color:var(--text);}
.tog-sub{font-size:12px;color:var(--muted);margin-top:1px;}
.tog{width:44px;height:26px;background:var(--border);border-radius:13px;position:relative;cursor:pointer;transition:background .25s;flex-shrink:0;}
.tog.on{background:var(--blue);}
.tog-dot{position:absolute;width:20px;height:20px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left .25s;box-shadow:0 1px 4px rgba(0,0,0,.18);}
.tog.on .tog-dot{left:21px;}

/* ── Seeker Profile Screen ── */
.sprofile-hdr{background:linear-gradient(160deg,#0B1F3A 0%,#0D2B45 50%,#1558CC 100%);padding:24px 18px 30px;flex-shrink:0;}
.sprofile-av-row{display:flex;align-items:center;gap:14px;margin-bottom:16px;}
.sprofile-av{width:62px;height:62px;background:rgba(255,255,255,.18);border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:28px;border:2px solid rgba(255,255,255,.25);flex-shrink:0;}
.sprofile-name{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;color:#fff;}
.sprofile-school{font-size:13px;color:rgba(255,255,255,.7);margin-top:2px;}
.sprofile-stats{display:flex;gap:0;background:rgba(255,255,255,.1);border-radius:12px;border:1px solid rgba(255,255,255,.15);}
.pstat{flex:1;text-align:center;padding:11px 8px;}
.pstat:not(:last-child){border-right:1px solid rgba(255,255,255,.15);}
.pstat-v{font-family:'Nunito',sans-serif;font-size:17px;font-weight:900;color:#fff;}
.pstat-l{font-size:10px;color:rgba(255,255,255,.55);margin-top:1px;}
.sprofile-body{padding:16px 16px 100px;overflow-y:auto;-webkit-overflow-scrolling:touch;flex:1;}
.sprofile-body::-webkit-scrollbar{display:none;}
.pcard{background:var(--card);border-radius:var(--r-lg);border:1px solid var(--border);padding:16px;margin-bottom:12px;box-shadow:var(--sh-sm);}
.pcard-title{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:14px;}
.prow{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border);}
.prow:last-child{border-bottom:none;padding-bottom:0;}
.prow-lbl{font-size:14px;font-weight:600;color:var(--text);}
.prow-val{font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;color:var(--blue);text-align:right;max-width:55%;}

/* ── Landlord Profile Screen ── */
.lprofile-hdr{background:linear-gradient(160deg,#0B1F3A 0%,#142840 50%,#0B5E4A 100%);padding:24px 18px 28px;flex-shrink:0;}
.lprofile-av-row{display:flex;align-items:center;gap:14px;margin-bottom:14px;}
.lprofile-av{width:62px;height:62px;background:rgba(255,255,255,.18);border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:28px;border:2px solid rgba(255,255,255,.25);flex-shrink:0;}
.lprofile-name{font-family:'Nunito',sans-serif;font-size:19px;font-weight:900;color:#fff;}
.lprofile-sub{font-size:12px;color:rgba(255,255,255,.65);margin-top:3px;}
.lprofile-stats{display:flex;gap:0;background:rgba(255,255,255,.1);border-radius:12px;border:1px solid rgba(255,255,255,.15);}

/* ── New Landlord Onboarding ── */
.onboard-progress{height:4px;background:rgba(255,255,255,.2);border-radius:2px;margin-bottom:20px;overflow:hidden;}
.onboard-progress-fill{height:100%;background:#fff;border-radius:2px;transition:width .4s ease;}
.onboard-step{display:none;}
.onboard-step.active{display:block;}
.verify-pending-card{background:rgba(255,255,255,.12);border-radius:16px;padding:20px;border:1px solid rgba(255,255,255,.2);text-align:center;margin:20px 0;}
.verify-ic-wrap{width:64px;height:64px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;}
.checklist-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--border);}
.checklist-item:last-child{border-bottom:none;}
.check-ic{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.check-ic.done{background:var(--greenBg);}
.check-ic.pending{background:var(--amberBg);}
.check-ic.todo{background:var(--border);}
.room-count-ctrl{display:flex;align-items:center;gap:0;border:1.5px solid var(--border);border-radius:10px;overflow:hidden;width:fit-content;}
.rcc-btn{width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:var(--warm);border:none;cursor:pointer;font-size:20px;color:var(--navy);font-weight:700;}
.rcc-btn:active{background:var(--border);}
.rcc-val{width:48px;text-align:center;font-family:'Nunito',sans-serif;font-size:18px;font-weight:900;color:var(--navy);border:none;outline:none;background:transparent;}
.rule-toggle-grid{display:flex;flex-direction:column;gap:2px;}

/* ── New Landlord role card accent ── */
.role-card.new-landlord{background:linear-gradient(135deg,rgba(91,33,182,.3),rgba(76,29,149,.2));border-color:rgba(139,92,246,.5);}
.role-card.new-landlord .role-name{color:#C4B5FD;}
.role-card.new-landlord .role-ic{background:rgba(139,92,246,.2);border-color:rgba(139,92,246,.3);}


/* ── Tenant Profile Setup ── */
#t-profile-setup .setup-hero{background:linear-gradient(160deg,var(--teal) 0%,#0B5E4A 100%);}



#map-fab:active { transform:scale(.95); box-shadow:var(--sh-sm); }
#map-fab i { font-size:17px; }
#map-fab.visible { display:flex; }

/* ═══════════════════════════════════════
   MAP SCREEN
═══════════════════════════════════════ */
#s-map {
  background: #F0EDE8;
}
.map-topbar {
  background: var(--navy);
  padding: 12px 18px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}
.map-topbar-title {
  font-family: 'Nunito', sans-serif;
  font-size: 16px;
  font-weight: 800;
  color: #fff;
  flex: 1;
}
.map-school-pills {
  display: flex;
  gap: 6px;
}
.map-spill {
  padding: 5px 11px;
  border-radius: 20px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  cursor: pointer;
  border: 1.5px solid rgba(255,255,255,.25);
  background: transparent;
  color: rgba(255,255,255,.55);
  transition: all .18s;
  letter-spacing: .2px;
}
.map-spill.on {
  background: #fff;
  color: var(--navy);
