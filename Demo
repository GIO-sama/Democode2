  }).join('');
}

function confirmVisitL(id) {
  const v = state.visits.find(x => x.id === id);
  if (!v) return;
  v.status = 'confirmed';
  // Push visit confirmation message into the related inquiry thread
  const relatedInq = state.inquiries.find(i => i.name === v.name && i.houseId === (state.houses.find(h=>h.name===v.house)?.id));
  if (relatedInq) {
    if (!relatedInq.messages) relatedInq.messages = [];
    relatedInq.messages.push({ from:'them', text:`Visit confirmed for ${v.date} at ${v.time}. See you then!`, time:'Just now' });
    relatedInq.status = 'visit_scheduled';
    const mi = state.myInquiries.find(m => m.id === relatedInq.id);
    if (mi) { mi.status = 'visit_scheduled'; mi.read = false; }
  }
  save();
  renderVisits();
  showToast('<i class="ph ph-check-circle"></i> Visit confirmed');
}

function cancelVisit(id) {
  const v = state.visits.find(x => x.id === id);
  if (!v) return;
  v.status = 'cancelled';
  // Notify seeker via inquiry thread
  const relatedInq = state.inquiries.find(i => i.name === v.name && i.houseId === (state.houses.find(h=>h.name===v.house)?.id));
  if (relatedInq) {
    if (!relatedInq.messages) relatedInq.messages = [];
    relatedInq.messages.push({ from:'them', text:`Sorry, we can't accommodate the visit on ${v.date}. Please request a new schedule.`, time:'Just now' });
    const mi = state.myInquiries.find(m => m.id === relatedInq.id);
    if (mi) { mi.read = false; }
  }
  save();
  renderVisits();
  showToast('Visit declined');
}
function cancelVisit(id) {
  state.visits = state.visits.filter(x=>x.id!==id);
  save(); renderVisits(); showToast('Visit cancelled');
}

