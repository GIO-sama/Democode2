    const s = sMap[r.status]||sMap.pending;
    const urgMap = {normal:'',urgent:' Urgent',emergency:'<i class="ph ph-siren"></i> Emergency'};
    return `<div class="mt-item">
      <div class="mt-top">
        <div><div class="mt-title">${r.type}</div><div class="mt-room">${r.room} • ${r.tenantName} • ${r.time}</div></div>
        <span class="tag" style="background:${s.bg};color:${s.tc};font-size:10px">${s.label}</span>
      </div>
      <div class="mt-desc">${r.desc}</div>
      <div class="mt-foot">
