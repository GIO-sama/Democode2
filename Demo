<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Buhay Boarding</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,600&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<style>
:root {
  --navy:     #0D2B45;
  --blue:     #1462A8;
  --sky:      #3B92D4;
  --teal:     #0D8A78;
  --tealBg:   #E3F5F2;
  --warm:     #F6F2ED;
  --card:     #FFFFFF;
  --border:   #E5DDD4;
  --text:     #181820;
  --muted:    #7A7A8C;
  --red:      #BC3A2B;
  --redBg:    #FDECEA;
  --amber:    #C97D0A;
  --amberBg:  #FEF3DC;
  --green:    #1A7A48;
  --greenBg:  #E4F5EC;
  --purple:   #5B2F8A;
  --purpleBg: #F0E8FA;
  --sh:       0 2px 12px rgba(13,43,69,.09);
  --shLg:     0 8px 32px rgba(13,43,69,.15);
  --r:        14px;
  --rSm:      8px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:#0D2B45;}
body{font-family:'Nunito Sans',sans-serif;font-size:15px;color:var(--text);display:flex;justify-content:center;align-items:center;min-height:100vh;background:linear-gradient(150deg,#0D2B45 0%,#163D65 60%,#0D2B45 100%);}

/* ── Phone Shell ── */
.phone{width:100%;max-width:420px;height:100vh;max-height:860px;background:var(--warm);overflow:hidden;position:relative;display:flex;flex-direction:column;box-shadow:0 0 80px rgba(0,0,0,.55);}
@media(min-width:440px){.phone{border-radius:36px;height:860px;}}

/* ── Status bar ── */
.sb{background:var(--navy);color:#fff;display:flex;justify-content:space-between;align-items:center;padding:10px 20px 8px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;flex-shrink:0;}

/* ── Screens ── */
.screen{display:none;flex-direction:column;flex:1;overflow:hidden;animation:fadeIn .2s ease;}
.screen.active{display:flex;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* ── Scroll ── */
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;}
.scroll::-webkit-scrollbar{display:none;}

/* ── Bottom nav ── */
.bnav{position:absolute;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);display:flex;padding:8px 0 env(safe-area-inset-bottom,14px);z-index:100;}
.ni{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:4px 0;cursor:pointer;}
.ni:active{opacity:.6;}
.ni-ic{font-size:20px;line-height:1;}
.ni-lb{font-family:'Nunito',sans-serif;font-size:10px;font-weight:700;color:var(--muted);}
.ni.on .ni-lb{color:var(--blue);}
.ni.on .ni-ic{filter:drop-shadow(0 0 4px rgba(20,98,168,.4));}

/* ── Typography helpers ── */
.f-nun{font-family:'Nunito',sans-serif;}
h-title{font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;color:var(--text);}

/* ── Buttons ── */
.btn{display:flex;align-items:center;justify-content:center;border:none;cursor:pointer;transition:opacity .15s;font-family:'Nunito',sans-serif;font-weight:800;}
.btn:active{opacity:.8;}
.btn-navy{background:var(--navy);color:#fff;border-radius:12px;padding:14px;font-size:15px;width:100%;}
.btn-blue{background:var(--blue);color:#fff;border-radius:10px;padding:10px 16px;font-size:13px;}
.btn-teal{background:var(--teal);color:#fff;border-radius:10px;padding:10px 16px;font-size:13px;}
.btn-ghost{background:var(--card);color:var(--navy);border:1.5px solid var(--border);border-radius:12px;padding:14px;font-size:15px;width:100%;}
.btn-ghost-sm{background:transparent;color:var(--navy);border:1.5px solid var(--border);border-radius:8px;padding:8px 12px;font-size:13px;}
.btn-red-sm{background:var(--redBg);color:var(--red);border-radius:8px;padding:8px 12px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:800;border:none;cursor:pointer;}
.btn-green-sm{background:var(--greenBg);color:var(--green);border-radius:8px;padding:8px 12px;font-size:13px;font-family:'Nunito',sans-serif;font-weight:800;border:none;cursor:pointer;}

/* ── Cards ── */
.card{background:var(--card);border-radius:var(--r);border:1.5px solid var(--border);box-shadow:var(--sh);}
.card-p{padding:14px;}

/* ── Form elements ── */
.lbl{display:block;font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--navy);letter-spacing:.5px;text-transform:uppercase;margin-bottom:6px;}
.inp,.sel,.ta{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:10px;padding:12px 14px;font-family:'Nunito Sans',sans-serif;font-size:15px;color:var(--text);outline:none;transition:border-color .2s;-webkit-appearance:none;}
.inp:focus,.sel:focus,.ta:focus{border-color:var(--blue);}
.ta{resize:none;height:88px;line-height:1.5;}
.hint{font-size:11px;color:var(--muted);margin-top:4px;}

/* ── Chips ── */
.chip{background:var(--card);border:1.5px solid var(--border);border-radius:20px;padding:6px 13px;font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;color:var(--muted);white-space:nowrap;cursor:pointer;flex-shrink:0;}
.chip.on{background:var(--navy);border-color:var(--navy);color:#fff;}

/* ── Tags ── */
.tag{display:inline-flex;align-items:center;font-family:'Nunito',sans-serif;font-size:11px;font-weight:700;padding:3px 8px;border-radius:6px;}
.tg{background:var(--tealBg);color:var(--teal);}
.tr{background:var(--redBg);color:var(--red);}
.ta2{background:var(--amberBg);color:var(--amber);}
.tn{background:rgba(13,43,69,.08);color:var(--navy);}
.tp{background:var(--purpleBg);color:var(--purple);}
.tgn{background:var(--greenBg);color:var(--green);}

/* ── Section label ── */
.slbl{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;}

/* ── Top bar ── */
.topbar{background:var(--navy);padding:14px 18px 16px;display:flex;align-items:center;gap:12px;flex-shrink:0;}
.topbar-title{font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;color:#fff;flex:1;}
.back{color:#fff;font-size:22px;cursor:pointer;padding:4px;line-height:1;}

/* ── Callout box ── */
.callout{border-radius:12px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;}
.callout-ic{font-size:20px;flex-shrink:0;margin-top:1px;}
.callout-txt{font-size:13px;line-height:1.5;}
.callout-txt strong{font-family:'Nunito',sans-serif;font-weight:800;}
.cl-warn{background:var(--amberBg);color:var(--amber);}
.cl-info{background:var(--tealBg);color:var(--teal);}
.cl-red{background:var(--redBg);color:var(--red);}
.cl-green{background:var(--greenBg);color:var(--green);}
.cl-purple{background:var(--purpleBg);color:var(--purple);}

/* ── Toast ── */
.toast{position:absolute;bottom:90px;left:50%;transform:translateX(-50%);background:var(--navy);color:#fff;font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;padding:10px 20px;border-radius:24px;white-space:nowrap;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none;}
.toast.show{opacity:1;}

/* ── Modal ── */
.modal-bg{position:absolute;inset:0;background:rgba(13,43,69,.55);z-index:200;display:flex;align-items:flex-end;backdrop-filter:blur(2px);}
.modal{background:var(--warm);border-radius:20px 20px 0 0;padding:24px 20px;width:100%;max-height:85%;overflow-y:auto;}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 18px;}
.modal-title{font-family:'Nunito',sans-serif;font-size:18px;font-weight:900;color:var(--text);margin-bottom:4px;}
.modal-sub{font-size:13px;color:var(--muted);margin-bottom:18px;}
.hidden{display:none!important;}

/* ════════════════════════════════
   ROLE SELECT
════════════════════════════════ */
#s-role{background:linear-gradient(160deg,var(--navy) 0%,#1462A8 100%);}
.role-wrap{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 28px;}
.role-logo{font-family:'Nunito',sans-serif;font-size:32px;font-weight:900;color:#fff;margin-bottom:4px;}
.role-logo span{color:#7ECFFC;}
.role-tagline{font-size:14px;color:rgba(255,255,255,.65);margin-bottom:40px;text-align:center;line-height:1.6;}
.role-cards{width:100%;display:flex;flex-direction:column;gap:12px;}
.role-card{background:rgba(255,255,255,.1);border:1.5px solid rgba(255,255,255,.18);border-radius:16px;padding:18px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:14px;}
.role-card:active{transform:scale(.98);background:rgba(255,255,255,.18);}
.role-ic{font-size:28px;width:48px;height:48px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.12);border-radius:12px;flex-shrink:0;}
.role-info{}
.role-name{font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;color:#fff;margin-bottom:2px;}
.role-desc{font-size:12px;color:rgba(255,255,255,.6);line-height:1.4;}
.role-arrow{margin-left:auto;color:rgba(255,255,255,.4);font-size:18px;}

/* ════════════════════════════════
   SEEKER — HOME
════════════════════════════════ */
.shdr{background:linear-gradient(160deg,var(--navy) 0%,#1462A8 100%);padding:18px 18px 24px;flex-shrink:0;}
.shdr-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
.shdr-greet{color:rgba(255,255,255,.65);font-size:12px;font-weight:600;margin-bottom:2px;}
.shdr-title{font-family:'Nunito',sans-serif;font-size:21px;font-weight:900;color:#fff;}
.shdr-title span{color:#7ECFFC;}
.av-btn{width:38px;height:38px;background:rgba(255,255,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;border:2px solid rgba(255,255,255,.22);}
.sc-toggle{display:flex;background:rgba(255,255,255,.12);border-radius:24px;padding:3px;gap:2px;margin-bottom:12px;}
.sc-btn{flex:1;padding:7px 8px;border-radius:20px;border:none;background:transparent;color:rgba(255,255,255,.65);font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .2s;text-align:center;}
.sc-btn.on{background:#fff;color:var(--navy);}
.srch{background:#fff;border-radius:11px;display:flex;align-items:center;padding:9px 13px;gap:9px;}
.srch input{flex:1;border:none;outline:none;font-family:'Nunito Sans',sans-serif;font-size:14px;color:var(--text);background:transparent;}
.srch input::placeholder{color:var(--muted);}
.fil-btn{background:var(--navy);color:#fff;border:none;border-radius:8px;padding:6px 10px;font-size:12px;cursor:pointer;}
.filter-row{display:flex;gap:8px;padding:12px 16px 4px;overflow-x:auto;flex-shrink:0;}
.filter-row::-webkit-scrollbar{display:none;}

/* listing cards */
.cards-list{padding:0 14px;display:flex;flex-direction:column;gap:12px;}
.lcard{background:var(--card);border-radius:var(--r);overflow:hidden;box-shadow:var(--sh);cursor:pointer;transition:transform .15s;border:1px solid var(--border);}
.lcard:active{transform:scale(.98);}
.lcard-img{height:136px;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;}
.lcard-img-ph{font-size:44px;opacity:.28;}
.lcard-badge{position:absolute;top:9px;left:9px;color:#fff;font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;padding:4px 8px;border-radius:6px;letter-spacing:.4px;text-transform:uppercase;}
.lcard-rooms{position:absolute;bottom:9px;right:9px;background:rgba(0,0,0,.52);color:#fff;font-family:'Nunito',sans-serif;font-size:11px;font-weight:700;padding:4px 8px;border-radius:6px;backdrop-filter:blur(4px);}
.lcard-body{padding:12px 13px 13px;}
.lcard-name{font-family:'Nunito',sans-serif;font-size:15px;font-weight:800;color:var(--text);margin-bottom:3px;}
.lcard-loc{font-size:12px;color:var(--muted);margin-bottom:8px;display:flex;align-items:center;gap:3px;}
.lcard-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px;}
.lcard-foot{display:flex;justify-content:space-between;align-items:center;padding-top:9px;border-top:1px solid var(--border);}
.lcard-price{font-family:'Nunito',sans-serif;font-weight:900;font-size:17px;color:var(--navy);}
.lcard-price span{font-size:12px;font-weight:600;color:var(--muted);}

/* ════════════════════════════════
   SEEKER — DETAIL
════════════════════════════════ */
.dhero{height:188px;position:relative;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.dhero-ph{font-size:64px;opacity:.22;}
.dhero-vbadge{position:absolute;bottom:12px;left:12px;background:var(--teal);color:#fff;font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;padding:4px 10px;border-radius:7px;}
.dhero-photos{position:absolute;bottom:12px;right:12px;background:rgba(0,0,0,.48);color:#fff;font-family:'Nunito',sans-serif;font-size:11px;font-weight:700;padding:4px 10px;border-radius:7px;}
.dbody{padding:16px 16px 0;}
.dname{font-family:'Nunito',sans-serif;font-size:21px;font-weight:900;color:var(--text);margin-bottom:3px;}
.dloc{font-size:13px;color:var(--muted);margin-bottom:14px;display:flex;align-items:center;gap:4px;}
.snap{background:var(--card);border-radius:var(--r);border:1.5px solid var(--border);padding:14px;margin-bottom:12px;box-shadow:var(--sh);}
.snap-title{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:12px;}
.snap-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.snap-itm{display:flex;flex-direction:column;gap:2px;}
.snap-lbl{font-size:11px;color:var(--muted);font-weight:600;}
.snap-val{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);}
.snap-val.g{color:var(--green);} .snap-val.r{color:var(--red);} .snap-val.a{color:var(--amber);}
.rules-box{background:var(--card);border-radius:var(--r);border:1.5px solid var(--border);padding:14px;margin-bottom:12px;}
.rule-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);}
.rule-row:last-child{border-bottom:none;}
.rule-nm{font-size:13px;font-weight:600;color:var(--text);display:flex;align-items:center;gap:7px;}
.rstatus{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;padding:3px 8px;border-radius:6px;}
.ryes{background:var(--greenBg);color:var(--green);}
.rno{background:var(--redBg);color:var(--red);}
.rpartial{background:var(--amberBg);color:var(--amber);}
.dactions{display:flex;gap:9px;padding:12px 16px;flex-shrink:0;background:var(--warm);border-top:1px solid var(--border);}
.dactions-stack{display:flex;flex-direction:column;gap:9px;padding:12px 16px;flex-shrink:0;background:var(--warm);border-top:1px solid var(--border);}

/* ════════════════════════════════
   SEEKER — INQUIRY FORM
════════════════════════════════ */
.fscroll{flex:1;overflow-y:auto;padding:18px 16px 100px;}
.fintro{background:var(--card);border-radius:var(--r);padding:13px;border:1.5px solid var(--border);margin-bottom:18px;display:flex;gap:11px;align-items:flex-start;}
.fintro-ic{font-size:22px;flex-shrink:0;margin-top:1px;}
.fintro-txt{font-size:13px;color:var(--muted);line-height:1.5;}
.fintro-txt strong{color:var(--text);font-weight:700;}
.fg{margin-bottom:15px;}
.ffoot{position:sticky;bottom:0;background:var(--warm);padding:10px 16px 80px;border-top:1px solid var(--border);}

/* ════════════════════════════════
   SEEKER — VISIT SCHEDULER
════════════════════════════════ */
.cal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:16px;}
.slot{background:var(--card);border:1.5px solid var(--border);border-radius:10px;padding:11px 8px;text-align:center;cursor:pointer;transition:all .2s;}
.slot:active,.slot.on{background:var(--navy);border-color:var(--navy);}
.slot.on .slot-date,.slot.on .slot-time{color:#fff;}
.slot.taken{background:var(--border);cursor:default;opacity:.5;}
.slot-date{font-family:'Nunito',sans-serif;font-size:12px;font-weight:800;color:var(--text);margin-bottom:2px;}
.slot-time{font-size:11px;color:var(--muted);}

/* ════════════════════════════════
   SEEKER — MY INQUIRIES
════════════════════════════════ */
.inq-item{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:13px;margin-bottom:9px;cursor:pointer;}
.inq-item:active{opacity:.8;}
.inq-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;}
.inq-house{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);}
.inq-time{font-size:11px;color:var(--muted);}
.inq-status{display:flex;align-items:center;gap:6px;margin-bottom:5px;}
.sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.inq-q{font-size:13px;color:var(--muted);line-height:1.4;}

/* ════════════════════════════════
   TENANT — HOME
════════════════════════════════ */
.thdr{background:linear-gradient(160deg,var(--teal) 0%,#0D6B5A 100%);padding:18px 18px 22px;flex-shrink:0;}
.thdr-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
.thdr-greet{color:rgba(255,255,255,.65);font-size:12px;font-weight:600;margin-bottom:2px;}
.thdr-title{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;color:#fff;}
.house-pill{background:rgba(255,255,255,.15);border-radius:10px;padding:10px 14px;display:flex;align-items:center;gap:10px;}
.hp-ic{font-size:20px;}
.hp-name{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:#fff;}
.hp-addr{font-size:11px;color:rgba(255,255,255,.6);}
.ann-item{background:var(--card);border-radius:12px;border:1.5px solid var(--border);padding:13px;margin-bottom:9px;display:flex;gap:11px;align-items:flex-start;}
.ann-card{background:var(--card);border-radius:12px;border:1.5px solid var(--border);padding:13px;margin-bottom:9px;cursor:pointer;transition:all .15s;}
.ann-card:active{background:var(--warm);}
.ann-hdr{display:flex;gap:10px;align-items:flex-start;margin-bottom:6px;}
.new-dot{width:8px;height:8px;background:var(--blue);border-radius:50%;margin-top:4px;flex-shrink:0;margin-left:auto;}
.ann-ic{font-size:22px;flex-shrink:0;}
.ann-cat{font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;padding:2px 7px;border-radius:5px;margin-bottom:4px;display:inline-block;}
.ann-title{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);margin-bottom:3px;}
.ann-body{font-size:13px;color:var(--muted);line-height:1.45;}
.ann-time{font-size:11px;color:var(--muted);margin-top:5px;}
.ann-new{width:8px;height:8px;background:var(--blue);border-radius:50%;margin-top:4px;flex-shrink:0;}

/* ════════════════════════════════
   TENANT — HOUSE INFO
════════════════════════════════ */
.info-section{background:var(--card);border-radius:var(--r);border:1.5px solid var(--border);padding:14px;margin-bottom:12px;}
.info-sec-title{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);letter-spacing:.8px;text-transform:uppercase;margin-bottom:11px;}
.info-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border);}
.info-row:last-child{border-bottom:none;}
.info-lbl{font-size:13px;color:var(--muted);}
.info-val{font-family:'Nunito',sans-serif;font-size:13px;font-weight:700;color:var(--text);text-align:right;}
.info-val.link{color:var(--blue);}

/* ════════════════════════════════
   TENANT — MAINTENANCE
════════════════════════════════ */
.mreq-item{background:var(--card);border-radius:12px;border:1.5px solid var(--border);padding:12px 13px;margin-bottom:9px;display:flex;gap:10px;align-items:flex-start;}
.mreq-ic{font-size:20px;flex-shrink:0;margin-top:1px;}
.mreq-title{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);margin-bottom:2px;}
.mreq-desc{font-size:12px;color:var(--muted);margin-bottom:5px;}
.mreq-foot{display:flex;gap:6px;align-items:center;}

/* ════════════════════════════════
   LANDLORD — DASHBOARD
════════════════════════════════ */
.lhdr{background:linear-gradient(160deg,var(--navy) 0%,#1A4070 100%);padding:18px 18px 20px;flex-shrink:0;}
.lhdr-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;}
.lhdr-greet{color:rgba(255,255,255,.6);font-size:12px;font-weight:600;margin-bottom:2px;}
.lhdr-name{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;color:#fff;}
.income-card{background:rgba(255,255,255,.1);border-radius:14px;padding:13px;border:1px solid rgba(255,255,255,.14);backdrop-filter:blur(8px);}
.ic-lbl{font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;color:rgba(255,255,255,.5);letter-spacing:.9px;text-transform:uppercase;margin-bottom:3px;}
.ic-amt{font-family:'Nunito',sans-serif;font-size:27px;font-weight:900;color:#fff;margin-bottom:9px;letter-spacing:-.5px;}
.ic-amt span{font-size:15px;font-weight:600;opacity:.65;}
.ic-row{display:flex;gap:8px;}
.ic-pill{background:rgba(255,255,255,.1);border-radius:8px;padding:7px 10px;flex:1;text-align:center;}
.ic-pill-v{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:#fff;display:block;}
.ic-pill-l{font-size:10px;color:rgba(255,255,255,.5);font-weight:600;}

/* room grid */
.rg{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:14px;}
.rt{background:var(--card);border-radius:10px;padding:9px 7px;text-align:center;border:1.5px solid var(--border);cursor:pointer;transition:all .15s;}
.rt:active{transform:scale(.96);}
.rt-num{font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;color:var(--muted);margin-bottom:3px;}
.rt-st{font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;padding:2px 4px;border-radius:4px;}
.st-paid{color:var(--green);} .st-pend{color:var(--amber);background:var(--amberBg);border-radius:4px;padding:2px 4px;}
.st-empty{background:var(--border);color:var(--muted);border-radius:4px;padding:2px 4px;}

/* quick actions */
.qa-grid{display:flex;gap:8px;overflow-x:auto;padding-bottom:2px;}
.qa-grid::-webkit-scrollbar{display:none;}
.qa-btn{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:11px 14px;text-align:center;cursor:pointer;flex-shrink:0;transition:all .15s;min-width:80px;}
.qa-btn:active{background:var(--border);}
.qa-ic{font-size:20px;margin-bottom:3px;}
.qa-lbl{font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;color:var(--navy);line-height:1.2;}

/* vacancy alert */
.vac-alert{background:var(--redBg);border:1.5px solid rgba(188,58,43,.2);border-radius:12px;padding:11px 13px;display:flex;gap:9px;align-items:flex-start;}
.vac-txt{font-size:13px;color:var(--red);line-height:1.4;}
.vac-txt strong{font-family:'Nunito',sans-serif;font-weight:800;}

/* inbox */
.inbox-item{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:12px 13px;margin-bottom:8px;cursor:pointer;display:flex;gap:9px;align-items:flex-start;transition:all .15s;}
.inbox-item:active{transform:scale(.99);}
.iav{width:35px;height:35px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;background:var(--tealBg);}
.icontent{flex:1;}
.iname{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);margin-bottom:1px;}
.imeta{font-size:11px;color:var(--muted);margin-bottom:3px;}
.iq{font-size:12px;color:var(--text);line-height:1.35;}
.itime{font-size:10px;color:var(--muted);white-space:nowrap;}
.ndot{width:7px;height:7px;background:var(--blue);border-radius:50%;margin-top:3px;flex-shrink:0;}

/* expense tracker */
.exp-item{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:12px 13px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:flex-start;}
.exp-left{display:flex;gap:9px;align-items:flex-start;}
.exp-ic{font-size:20px;flex-shrink:0;}
.exp-name{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);margin-bottom:2px;}
.exp-cat{font-size:11px;color:var(--muted);}
.exp-amt{font-family:'Nunito',sans-serif;font-size:15px;font-weight:900;color:var(--red);}
.exp-date{font-size:11px;color:var(--muted);text-align:right;}

/* maint tracker landlord */
.mt-item{background:var(--card);border:1.5px solid var(--border);border-radius:12px;padding:12px 13px;margin-bottom:8px;}
.mt-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px;}
.mt-title{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);}
.mt-room{font-size:11px;color:var(--muted);margin-bottom:5px;}
.mt-desc{font-size:12px;color:var(--muted);line-height:1.4;margin-bottom:8px;}
.mt-foot{display:flex;gap:7px;align-items:center;}

/* ── section wrapper ── */
.sec{padding:14px 14px 0;}
.sec-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;}

/* ── Tenant Registration ── */
.reg-wrap{display:flex;flex-direction:column;height:100%;background:var(--warm);}
.reg-hero{background:linear-gradient(135deg,var(--teal),#0D6B5A);padding:32px 24px 28px;color:#fff;}
.reg-hero-title{font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;margin-bottom:6px;}
.reg-hero-sub{font-size:13px;opacity:.85;line-height:1.4;}
.reg-body{padding:24px 20px;flex:1;}
.reg-step{font-size:11px;font-weight:700;color:var(--teal);text-transform:uppercase;letter-spacing:.5px;margin-bottom:16px;}
.otp-row{display:flex;gap:8px;margin-top:4px;}
.otp-inp{flex:1;height:48px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:22px;font-weight:800;text-align:center;color:var(--navy);background:#fff;outline:none;transition:border .2s;}
.otp-inp:focus{border-color:var(--teal);}
.reg-code-box{background:linear-gradient(135deg,var(--navy),var(--blue));border-radius:14px;padding:18px 20px;margin-bottom:18px;color:#fff;text-align:center;}
.reg-code-lbl{font-size:12px;opacity:.7;margin-bottom:6px;}
.reg-code-val{font-family:'Nunito',sans-serif;font-size:32px;font-weight:900;letter-spacing:6px;}
.reg-code-room{font-size:12px;opacity:.7;margin-top:4px;}

/* ── Landlord Tenant Management ── */
.tenant-card{background:var(--card);border:1.5px solid var(--border);border-radius:13px;padding:14px;margin-bottom:9px;}
.tc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px;}
.tc-name{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);}
.tc-room{font-size:11px;color:var(--muted);margin-top:2px;}
.tc-status-active{display:inline-flex;align-items:center;gap:4px;background:var(--greenBg);color:var(--green);font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px;}
.tc-status-pending{display:inline-flex;align-items:center;gap:4px;background:var(--amberBg);color:var(--amber);font-size:11px;font-weight:700;padding:3px 9px;border-radius:20px;}
.tc-code{display:flex;align-items:center;gap:8px;background:var(--warm);border-radius:9px;padding:8px 11px;margin-top:6px;}
.tc-code-lbl{font-size:11px;color:var(--muted);flex:1;}
.tc-code-val{font-family:'Nunito',sans-serif;font-size:16px;font-weight:900;color:var(--navy);letter-spacing:3px;}
.tc-code-copy{font-size:11px;color:var(--blue);font-weight:700;cursor:pointer;}

/* ── QR Code Screen ── */
.qr-wrap{display:flex;flex-direction:column;align-items:center;padding:28px 24px;text-align:center;}
.qr-title{font-family:'Nunito',sans-serif;font-size:18px;font-weight:900;color:var(--navy);margin-bottom:6px;}
.qr-sub{font-size:13px;color:var(--muted);margin-bottom:24px;line-height:1.5;}
.qr-box{background:#fff;border-radius:16px;padding:20px;box-shadow:var(--shLg);margin-bottom:20px;}
.qr-house{background:var(--navy);color:#fff;border-radius:10px;padding:10px 16px;font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;margin-bottom:18px;}
.qr-instruction{background:var(--blueLt,#EDF4FC);border-radius:12px;padding:14px 16px;text-align:left;width:100%;}
.qr-step{display:flex;gap:10px;align-items:flex-start;margin-bottom:10px;font-size:13px;color:var(--text);line-height:1.4;}
.qr-step:last-child{margin-bottom:0;}
.qr-step-num{background:var(--blue);color:#fff;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;flex-shrink:0;margin-top:1px;}

/* ── Primary Action Cards (Landlord) ── */
.primary-actions{display:flex;flex-direction:column;gap:10px;padding:14px 14px 0;}
.pa-card{background:var(--card);border:2px solid var(--border);border-radius:14px;padding:16px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:all .15s;}
.pa-card:active{transform:scale(.98);background:var(--warm);}
.pa-card.primary{background:var(--navy);border-color:var(--navy);}
.pa-card.primary .pa-title{color:#fff;}
.pa-card.primary .pa-sub{color:rgba(255,255,255,.65);}
.pa-ic-wrap{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.pa-ic-wrap.navy{background:rgba(255,255,255,.12);}
.pa-ic-wrap.blue{background:var(--blueLt,#EDF4FC);}
.pa-ic-wrap.teal{background:var(--tealBg);}
.pa-ic-wrap.amber{background:var(--amberBg);}
.pa-title{font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:var(--text);}
.pa-sub{font-size:12px;color:var(--muted);margin-top:2px;}
.pa-badge{margin-left:auto;background:var(--red);color:#fff;font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;padding:3px 8px;border-radius:20px;flex-shrink:0;}
.pa-arrow{margin-left:auto;color:var(--muted);font-size:18px;flex-shrink:0;}

/* ── Room info card (tenant) ── */
.room-info-card{background:linear-gradient(135deg,var(--teal),#0D6B5A);border-radius:14px;padding:16px;margin-bottom:14px;color:#fff;display:flex;justify-content:space-between;align-items:center;}
.ric-left{}
.ric-room{font-family:'Nunito',sans-serif;font-size:20px;font-weight:900;margin-bottom:2px;}
.ric-house{font-size:12px;opacity:.8;}
.ric-right{text-align:right;}
.ric-rent{font-family:'Nunito',sans-serif;font-size:22px;font-weight:900;}
.ric-due{font-size:11px;opacity:.75;margin-top:2px;}
.ric-paid{display:inline-flex;align-items:center;gap:4px;background:rgba(255,255,255,.2);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:700;margin-top:4px;}

/* ── Quick report button (tenant) ── */
.report-btn{background:var(--card);border:2px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;margin-bottom:14px;transition:all .15s;}
.report-btn:active{background:var(--warm);}
.report-ic{width:40px;height:40px;background:var(--redBg);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.report-text{flex:1;}
.report-title{font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;color:var(--text);}
.report-sub{font-size:12px;color:var(--muted);margin-top:1px;}
.report-arrow{color:var(--muted);font-size:18px;}

/* ── Onboarding empty states in Filipino ── */
.empty-fil{text-align:center;padding:36px 20px;color:var(--muted);}
.empty-fil-ic{font-size:42px;margin-bottom:12px;}
.empty-fil-title{font-family:'Nunito',sans-serif;font-size:16px;font-weight:800;color:var(--text);margin-bottom:6px;}
.empty-fil-sub{font-size:13px;line-height:1.5;}

/* ── Add tenant modal extras ── */
.invite-display{background:linear-gradient(135deg,var(--navy),var(--blue));border-radius:14px;padding:20px;text-align:center;margin:12px 0;}
.invite-lbl{font-size:12px;color:rgba(255,255,255,.7);margin-bottom:8px;}
.invite-code{font-family:'Nunito',sans-serif;font-size:36px;font-weight:900;color:#fff;letter-spacing:8px;}
.invite-room{font-size:12px;color:rgba(255,255,255,.65);margin-top:6px;}
.invite-hint{font-size:12px;color:var(--muted);text-align:center;margin-top:10px;line-height:1.5;}
</style>
</head>
<body>
<div class="phone">
  <div class="sb"><span id="clock">9:41</span><div style="display:flex;gap:6px">📶 🔋</div></div>

  <!-- ═══════════════════════════
       ROLE SELECT
  ═══════════════════════════ -->
  <div class="screen active" id="s-role">
    <div class="role-wrap">
      <div class="role-logo">Buhay <span>Boarding</span></div>
      <div class="role-tagline">Verified boarding houses in Burauen.<br>Who are you today?</div>
      <div class="role-cards">
        <div class="role-card" onclick="setRole('seeker')">
          <div class="role-ic">🔍</div>
          <div class="role-info">
            <div class="role-name">Looking for a Room</div>
            <div class="role-desc">Browse verified listings, ask questions, schedule visits</div>
          </div>
          <div class="role-arrow">›</div>
        </div>
        <div class="role-card" onclick="setRole('tenant')">
          <div class="role-ic">🏠</div>
          <div class="role-info">
            <div class="role-name">Current Tenant</div>
            <div class="role-desc">View announcements, house info, submit maintenance</div>
          </div>
          <div class="role-arrow">›</div>
        </div>
        <div class="role-card" onclick="goTo('t-register')" style="border-color:var(--teal);background:var(--tealBg)">
          <div class="role-ic">🔑</div>
          <div class="role-info">
            <div class="role-name" style="color:var(--teal)">New Tenant — First Time</div>
            <div class="role-desc">May invite code ka? I-register ang iyong account dito</div>
          </div>
          <div class="role-arrow" style="color:var(--teal)">›</div>
        </div>
        <div class="role-card" onclick="setRole('landlord')">
          <div class="role-ic">📋</div>
          <div class="role-info">
            <div class="role-name">Landlord</div>
            <div class="role-desc">Manage listings, inquiries, tenants, and financials</div>
          </div>
          <div class="role-arrow">›</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════
       SEEKER — HOME
  ═══════════════════════════ -->
  <div class="screen" id="s-home">
    <div class="shdr">
      <div class="shdr-top">
        <div>
          <div class="shdr-greet">Maayong buntag 👋</div>
          <div class="shdr-title">Buhay <span>Boarding</span></div>
        </div>
        <div class="av-btn" onclick="goTo('s-myinq')">💬</div>
      </div>
      <div class="sc-toggle">
        <button class="sc-btn on" onclick="switchSchool(this,'evsu')">EVSU Burauen</button>
        <button class="sc-btn" onclick="switchSchool(this,'bcc')">BCC</button>
      </div>
      <div class="srch">
        <span style="font-size:15px;color:var(--muted)">🔍</span>
        <input type="text" placeholder="Search boarding houses..." oninput="filterHouses(this.value)" id="srch-inp">
        <button class="fil-btn" onclick="toggleFilter()">⚡</button>
      </div>
    </div>
    <div class="filter-row" id="filter-row">
      <div class="chip on" onclick="setFilter('all',this)">All</div>
      <div class="chip" onclick="setFilter('available',this)">Available now</div>
      <div class="chip" onclick="setFilter('under2k',this)">Under ₱2k</div>
      <div class="chip" onclick="setFilter('wifi',this)">WiFi included</div>
      <div class="chip" onclick="setFilter('nocurfew',this)">No curfew</div>
    </div>
    <div class="scroll" style="padding:10px 0 90px">
      <div style="padding:0 14px 10px"><span class="slbl" id="houses-count">3 houses near EVSU</span></div>
      <div class="cards-list" id="houses-list"></div>
    </div>
    <div class="bnav">
      <div class="ni on"><span class="ni-ic">🏠</span><span class="ni-lb">Discover</span></div>
      <div class="ni" onclick="goTo('s-myinq')"><span class="ni-ic">💬</span><span class="ni-lb">Inquiries</span></div>
      <div class="ni" onclick="showToast('Profile coming soon!')"><span class="ni-ic">👤</span><span class="ni-lb">Profile</span></div>
      <div class="ni" onclick="goTo('s-role')"><span class="ni-ic">🔄</span><span class="ni-lb">Switch</span></div>
    </div>
  </div>

  <!-- ═══════════════════════════
       SEEKER — DETAIL
  ═══════════════════════════ -->
  <div class="screen" id="s-detail">
    <div class="topbar">
      <div class="back" onclick="goTo('s-home')">←</div>
      <div class="topbar-title" id="d-topname">Boarding House</div>
    </div>
    <div class="scroll" style="padding-bottom:90px">
      <div class="dhero" id="d-hero">
        <span class="dhero-ph">🏠</span>
        <div class="dhero-vbadge" id="d-vbadge">✓ Verified</div>
        <div class="dhero-photos">📷 8 photos</div>
      </div>
      <div class="dbody">
        <div class="dname" id="d-name">—</div>
        <div class="dloc" id="d-loc">📍 —</div>
        <div class="snap">
          <div class="snap-title">Room Snapshot</div>
          <div class="snap-grid" id="d-snap"></div>
        </div>
        <div class="rules-box" id="d-rules-box">
          <div class="snap-title">House Rules</div>
          <div id="d-rules"></div>
        </div>
        <div class="snap" id="d-tenants-snap" style="display:none">
          <div class="snap-title">Current Tenants</div>
          <div id="d-tenants-list"></div>
        </div>
      </div>
    </div>
    <div class="dactions" id="d-actions"></div>
  </div>

  <!-- ═══════════════════════════
       SEEKER — INQUIRY FORM
  ═══════════════════════════ -->
  <div class="screen" id="s-inquiry">
    <div class="topbar">
      <div class="back" onclick="goTo('s-detail')">←</div>
      <div class="topbar-title">Ask a Question</div>
    </div>
    <div class="fscroll">
      <div class="fintro">
        <span class="fintro-ic">💡</span>
        <div class="fintro-txt">This reaches the landlord directly. <strong>No cold messaging</strong> — your info is already structured so they can reply fast.</div>
      </div>
      <div class="fg"><label class="lbl">Your Name</label><input class="inp" type="text" id="inq-name" placeholder="e.g. Maria Santos"></div>
      <div class="fg"><label class="lbl">School</label>
        <select class="sel" id="inq-school">
          <option value="">Select school</option>
          <option>EVSU Burauen Campus</option>
          <option>Burauen Community College</option>
          <option>Other</option>
        </select>
      </div>
      <div class="fg"><label class="lbl">Course & Year Level</label><input class="inp" type="text" id="inq-course" placeholder="e.g. BSIT — 2nd Year"></div>
      <div class="fg"><label class="lbl">Target Move-in Date</label><input class="inp" type="date" id="inq-date"></div>
      <div class="fg">
        <label class="lbl">Your Question <span style="color:var(--muted);font-weight:400;font-size:11px;text-transform:none">(optional)</span></label>
        <textarea class="ta" id="inq-q" placeholder="Any specific question..." maxlength="200" oninput="document.getElementById('cc').textContent=this.value.length+'/200'"></textarea>
        <div style="text-align:right;font-size:11px;color:var(--muted);margin-top:3px" id="cc">0/200</div>
      </div>
    </div>
    <div class="ffoot">
      <button class="btn btn-navy" onclick="submitInquiry()">Send Inquiry →</button>
    </div>
  </div>

  <!-- ═══════════════════════════
       SEEKER — VISIT SCHEDULER
  ═══════════════════════════ -->
  <div class="screen" id="s-visit">
    <div class="topbar">
      <div class="back" onclick="goTo('s-detail')">←</div>
      <div class="topbar-title">Schedule a Visit</div>
    </div>
    <div class="fscroll">
      <div class="fintro">
        <span class="fintro-ic">📅</span>
        <div class="fintro-txt">Pick an available time slot. Landlord confirms within a few hours. <strong>No back-and-forth needed.</strong></div>
      </div>
      <div class="slbl" style="margin-bottom:10px">Available Slots</div>
      <div class="cal-grid" id="slot-grid"></div>
      <div id="visit-confirm-area" class="hidden">
        <div class="callout cl-green" style="margin-bottom:14px">
          <span class="callout-ic">✅</span>
          <div class="callout-txt"><strong>Slot selected!</strong> Tap confirm to send your visit request.</div>
        </div>
      </div>
    </div>
    <div class="ffoot">
      <button class="btn btn-navy" id="confirm-visit-btn" onclick="confirmVisit()" style="opacity:.4;pointer-events:none">Confirm Visit Request</button>
    </div>
  </div>

  <!-- ═══════════════════════════
       SEEKER — WAITLIST
  ═══════════════════════════ -->
  <div class="screen" id="s-waitlist">
