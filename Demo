let _adminPin = '';
function adminPinKey(k) {
  if (_adminPin.length >= 6) return;
  _adminPin += k;
  updateAdminPinDots();
  if (_adminPin.length === 6) setTimeout(checkAdminPin, 150);
}
function adminPinDel() {
  _adminPin = _adminPin.slice(0, -1);
  updateAdminPinDots();
  document.getElementById('admin-pin-error').textContent = '';
}
function updateAdminPinDots() {
  for (let i = 0; i < 6; i++) {
    const dot = document.getElementById('apd-' + i);
    if (dot) dot.classList.toggle('filled', i < _adminPin.length);
  }
}
function checkAdminPin() {
  if (_adminPin === getAdminPin()) {
    _adminPin = ''; updateAdminPinDots();
    document.getElementById('admin-pin-error').textContent = '';
    ensureAdminFields();
    adminLog('Admin logged in');
    goTo('a-home');
  } else {
    document.getElementById('admin-pin-error').textContent = 'Wrong PIN. Try again.';
    _adminPin = ''; updateAdminPinDots();
    const dots = document.getElementById('admin-pin-dots');
    if (dots) { dots.style.animation='shake .3s ease'; setTimeout(()=>dots.style.animation='',350); }
  }
}
function adminLogout() {
  _adminPin = '';
  showToast('Logged out of admin');
  goTo('s-role');
}

