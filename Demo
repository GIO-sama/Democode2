let _currentThreadId = null;

function openThread(inqId) {
  const mi  = state.myInquiries.find(i => i.id === inqId);
  const inq = state.inquiries.find(i => i.id === inqId);
  if (!mi) return;

  // Mark as read
  mi.read = true;

  // Seed messages array from existing inquiry data if not yet threaded
  if (!mi.messages) {
    mi.messages = [
      { from:'me', text: mi.q || '(No specific question)', time: mi.time }
    ];
    if (mi.reply) {
      mi.messages.push({ from:'them', text: mi.reply, time: 'Earlier' });
    }
    // Sync back to source inquiry too
    if (inq && !inq.messages) inq.messages = [...mi.messages];
  }

  _currentThreadId = inqId;

  const h = state.houses.find(x => x.id === mi.houseId);
  const statusLabels = {
    pending:'Awaiting Reply', replied:'Replied', interested:'Interested',
    not_a_fit:'Not a Fit', visit_scheduled:'Visit Scheduled',
    offered:'Room Offered', declined:'Declined'
  };
  const statusTags = {
    pending:'ta2', replied:'tgn', interested:'tg',
    not_a_fit:'tr', offered:'tgn', declined:'tn'
  };

  document.getElementById('thread-house-name').textContent = mi.houseName;
  document.getElementById('thread-house-sub').textContent  = h ? h.address : 'Burauen, Leyte';
  const badge = document.getElementById('thread-status-badge');
  badge.textContent  = statusLabels[mi.status] || mi.status;
  badge.className    = `tag ${statusTags[mi.status] || 'ta2'}`;
  badge.style.fontSize = '10px';

  renderThread(mi);
  goTo('s-thread');
}

function renderThread(mi) {
  const scroll = document.getElementById('thread-scroll');
  if (!scroll) return;
  const msgs = mi.messages || [];

  if (!msgs.length) {
    scroll.innerHTML = `<div style="text-align:center;padding:40px 20px;color:var(--muted);font-size:13px;">
      <i class="ph ph-chat-circle-dots" style="font-size:32px;display:block;margin-bottom:10px;color:var(--muted2);"></i>
      No messages yet
    </div>`;
    return;
  }

  scroll.innerHTML = msgs.map((m, i) => {
    const isMe = m.from === 'me';
    const showSender = i === 0 || msgs[i-1].from !== m.from;
    return `<div class="msg-row ${isMe ? 'from-me' : 'from-them'}">
      ${!isMe ? `<div style="width:32px;height:32px;background:var(--warm2);border-radius:50%;border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;align-self:flex-end;"><i class="ph ph-user-circle" style="color:var(--muted);"></i></div>` : ''}
      <div>
        ${showSender && !isMe ? `<div class="msg-sender">Landlord</div>` : ''}
        <div class="msg-bubble">${m.text}</div>
        <div class="msg-time" style="text-align:${isMe?'right':'left'}">${m.time}</div>
      </div>
    </div>`;
  }).join('');

  // Scroll to bottom
  setTimeout(() => { scroll.scrollTop = scroll.scrollHeight; }, 60);
}

function sendThreadMessage() {
  const inp = document.getElementById('thread-inp');
  const txt = inp?.value.trim();
  if (!txt || !_currentThreadId) return;

  const mi  = state.myInquiries.find(i => i.id === _currentThreadId);
  const inq = state.inquiries.find(i => i.id === _currentThreadId);
  if (!mi) return;

  if (!mi.messages) mi.messages = [];
  const msg = { from:'me', text: txt, time: 'Just now' };
  mi.messages.push(msg);
  if (inq) {
    if (!inq.messages) inq.messages = [...mi.messages];
    else inq.messages.push(msg);
    // Adding a follow-up moves status back to pending if it was replied
    if (inq.status === 'replied') { inq.status = 'pending'; mi.status = 'pending'; mi.read = true; }
  }
  save();

  inp.value = '';
  inp.style.height = 'auto';
  renderThread(mi);

  // Simulate landlord auto-reply after 2.5s (demo only)
  setTimeout(() => {
    const autoReplies = [
      'Salamat sa iyong mensahe! Susubukan kong sagutin agad.',
      'Noted po. Maaari ka bang mag-visit this week para makita ang kwarto?',
      'Yes po, available pa ang kwarto. Kausapin na lang natin ang detalye.',
      'Okay po, ipagpapaalam ko sa inyo kapag may update.',
    ];
    const reply = autoReplies[Math.floor(Math.random() * autoReplies.length)];
    const replyMsg = { from:'them', text: reply, time: 'Just now' };
    mi.messages.push(replyMsg);
    if (inq) { inq.messages = inq.messages || []; inq.messages.push(replyMsg); inq.reply = reply; }
    mi.reply = reply;
    mi.status = 'replied';
    if (inq) inq.status = 'replied';
    save();
    // Only re-render if thread is still open
    if (_currentThreadId === (mi.id)) renderThread(mi);
  }, 2500);
}
function withdrawInquiry(id) {
  // Remove from both inquiry lists
  state.inquiries    = state.inquiries.filter(i => i.id !== id);
  state.myInquiries  = state.myInquiries.filter(i => i.id !== id);
  save();
  renderMyInquiries();
  showToast('Inquiry withdrawn');
}

