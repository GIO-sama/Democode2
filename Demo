  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.inq-status-badge {
  position: absolute;
  top: 12px; right: 12px;
  font-family: 'Nunito', sans-serif;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .4px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 20px;
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.28);
  color: #fff;
}

/* Meta row */
.inq-meta-row {
  display: flex;
  gap: 8px;
  margin: 12px 18px 0;
}
.inq-meta-pill {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 12px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
}
.inq-meta-pill span {
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Question bubble */
.inq-q-wrap { margin: 12px 18px 0; }
.inq-q-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 7px;
}
.inq-q-bubble {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  border-top-left-radius: 4px;
  padding: 13px 15px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text);
  box-shadow: var(--sh-xs);
}

/* Actions */
.inq-actions-wrap { margin: 16px 18px 0; }
.inq-action-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 10px;
}
.inq-act-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 8px;
}
.inq-act-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 13px 10px;
  border-radius: 13px;
  border: none;
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 800;
  transition: transform .12s, box-shadow .12s;
}
.inq-act-btn:active { transform: scale(.97); }
.inq-act-btn i { font-size: 16px; }

/* Button variants */
.inq-act-offer {
  background: linear-gradient(135deg, var(--teal), #0D9480);
  color: #fff;
  box-shadow: 0 4px 14px rgba(11,122,106,.30);
}
.inq-act-visit {
  background: linear-gradient(135deg, #5B21B6, #7C3AED);
  color: #fff;
  box-shadow: 0 4px 14px rgba(91,33,182,.25);
}
.inq-act-replied {
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.18);
  color: var(--blue);
}
.inq-act-interested {
  background: #F0FDFA;
  border: 1.5px solid rgba(11,122,106,.18);
  color: var(--teal);
}
.inq-act-notfit {
  background: var(--warm2);
  border: 1.5px solid var(--border);
  color: var(--muted);
}
.inq-act-decline {
  background: #FEF2F2;
  border: 1.5px solid rgba(192,57,43,.15);
  color: var(--red);
}

/* Close button */
.inq-close-btn {
  display: block;
  width: calc(100% - 36px);
  margin: 12px 18px 0;
  padding: 13px;
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: 13px;
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--muted);
  cursor: pointer;
  transition: background .15s;
}
.inq-close-btn:active { background: var(--border); }


/* ── Small action buttons (maintenance, visits) ─────── */
.btn-green-sm {
  background: var(--greenBg, #DCFCE7);
  color: var(--green);
  border: 1.5px solid rgba(22,101,52,.2);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-green-sm:active { transform: scale(.97); }
.btn-red-sm {
  background: #FEF2F2;
  color: var(--red);
  border: 1.5px solid rgba(192,57,43,.18);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-red-sm:active { transform: scale(.97); }
</style>
</head>
