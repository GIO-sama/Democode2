function triggerSnapUpload(idx) {
  _snapUploadIdx = idx;
  const inp = document.getElementById('bhl-photo-file');
  if (inp) { inp.value = ''; inp.click(); }
}

function handleSnapPhotoUpload(event) {
  const file = event.target.files[0];
  if (!file || _snapUploadIdx === null) return;
  const reader = new FileReader();
  reader.onload = e => {
    const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
    if (h.snapshots && h.snapshots[_snapUploadIdx]) {
      h.snapshots[_snapUploadIdx].img = e.target.result;
      renderBhlSnapGrid();
      showToast('<i class="ph ph-check-circle"></i> Photo uploaded');
    }
    _snapUploadIdx = null;
  };
  reader.readAsDataURL(file);
}

