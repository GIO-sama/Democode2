}
.map-entry-pill:active { background: rgba(255,255,255,.22); }
.map-entry-pill i { font-size: 13px; }

/* ════════════════════════════════════════════════════
   INQUIRY DETAIL BOTTOM SHEET
════════════════════════════════════════════════════ */
.inq-sheet-overlay {
  position: absolute;
  inset: 0;
  z-index: 200;
  background: rgba(11,31,58,.52);
  backdrop-filter: blur(5px);
  display: flex;
  align-items: flex-end;
}
.inq-sheet-overlay.hidden { display: none !important; }
.inq-sheet {
  width: 100%;
  background: var(--warm);
  border-radius: 24px 24px 0 0;
  padding: 0 0 32px;
  box-shadow: 0 -8px 40px rgba(11,31,58,.22);
  max-height: 90%;
  overflow-y: auto;
  animation: sheetUp .28s cubic-bezier(.32,0,.2,1);
}
@keyframes sheetUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.inq-sheet-handle {
  width: 36px; height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 14px auto 0;
}

/* Hero */
.inq-hero {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px 18px 0;
  background: linear-gradient(135deg, var(--navy) 0%, #1558CC 100%);
  border-radius: 16px;
  padding: 16px 16px 16px 16px;
  position: relative;
  overflow: hidden;
}
.inq-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23fff' fill-opacity='.04'%3E%3Ccircle cx='20' cy='20' r='20'/%3E%3C/g%3E%3C/svg%3E") center/40px;
  pointer-events: none;
}
.inq-hero-avatar {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  border: 2px solid rgba(255,255,255,.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
}
.inq-hero-info { flex: 1; min-width: 0; }
.inq-hero-name {
  font-family: 'Nunito', sans-serif;
  font-size: 17px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.inq-hero-school {
  font-size: 12px;
  color: rgba(255,255,255,.65);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.inq-status-badge {
  position: absolute;
  top: 12px; right: 12px;
  font-family: 'Nunito', sans-serif;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .4px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 20px;
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.28);
  color: #fff;
}

/* Meta row */
.inq-meta-row {
  display: flex;
  gap: 8px;
  margin: 12px 18px 0;
}
.inq-meta-pill {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 12px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
}
.inq-meta-pill span {
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Question bubble */
.inq-q-wrap { margin: 12px 18px 0; }
.inq-q-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 7px;
}
.inq-q-bubble {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  border-top-left-radius: 4px;
  padding: 13px 15px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text);
  box-shadow: var(--sh-xs);
}

/* Actions */
.inq-actions-wrap { margin: 16px 18px 0; }
.inq-action-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 10px;
}
.inq-act-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 8px;
}
.inq-act-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 13px 10px;
  border-radius: 13px;
  border: none;
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 800;
  transition: transform .12s, box-shadow .12s;
}
.inq-act-btn:active { transform: scale(.97); }
.inq-act-btn i { font-size: 16px; }

/* Button variants */
.inq-act-offer {
  background: linear-gradient(135deg, var(--teal), #0D9480);
  color: #fff;
  box-shadow: 0 4px 14px rgba(11,122,106,.30);
}
.inq-act-visit {
  background: linear-gradient(135deg, #5B21B6, #7C3AED);
  color: #fff;
  box-shadow: 0 4px 14px rgba(91,33,182,.25);
}
.inq-act-replied {
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.18);
  color: var(--blue);
}
.inq-act-interested {
  background: #F0FDFA;
  border: 1.5px solid rgba(11,122,106,.18);
  color: var(--teal);
}
.inq-act-notfit {
  background: var(--warm2);
  border: 1.5px solid var(--border);
  color: var(--muted);
}
.inq-act-decline {
  background: #FEF2F2;
  border: 1.5px solid rgba(192,57,43,.15);
  color: var(--red);
}

/* Close button */
.inq-close-btn {
  display: block;
  width: calc(100% - 36px);
  margin: 12px 18px 0;
  padding: 13px;
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: 13px;
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--muted);
  cursor: pointer;
  transition: background .15s;
}
.inq-close-btn:active { background: var(--border); }


/* ── Small action buttons (maintenance, visits) ─────── */
.btn-green-sm {
  background: var(--greenBg, #DCFCE7);
  color: var(--green);
  border: 1.5px solid rgba(22,101,52,.2);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-green-sm:active { transform: scale(.97); }
.btn-red-sm {
  background: #FEF2F2;
  color: var(--red);
  border: 1.5px solid rgba(192,57,43,.18);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-red-sm:active { transform: scale(.97); }

/* ─── SAVED / HEART BUTTON ─────────────────── */
.lcard-heart {
  position: absolute;
  top: 10px; right: 10px;
  width: 34px; height: 34px;
  background: rgba(255,255,255,.92);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  border: none;
  font-size: 17px;
  color: var(--muted2);
  box-shadow: 0 2px 8px rgba(11,31,58,.18);
  transition: all .18s;
  z-index: 10;
  flex-shrink: 0;
}
.lcard-heart.saved { color: #E11D48; background: #FFF1F2; }
.lcard-heart:active { transform: scale(.9); }

/* ─── RENDER UTILITY CLASSES ─────────────────────────────────
   Replaces high-frequency inline styles produced by JS render functions.
   Browser caches computed styles for class selectors vs re-parsing
   inline style strings on every innerHTML rebuild.
──────────────────────────────────────────────────────────────── */
.sum-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:13px; }
.sum-row:last-child { border-bottom:none; }
.sum-lbl { color:var(--muted); }
.sum-val { font-weight:700; }
.sum-hdr { font-family:'Nunito',sans-serif; font-size:11px; font-weight:800; color:var(--muted); letter-spacing:.8px; text-transform:uppercase; margin-bottom:10px; }
/* ── ANNOUNCEMENT IMPROVEMENTS ────────────────────── */
.ann-render-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 16px; margin-bottom:10px; box-shadow:0 1px 4px rgba(11,31,58,.06); position:relative; }
.ann-render-card.pinned { border-color:var(--red); border-width:1.5px; }
.ann-pin-badge { position:absolute; top:-8px; left:14px; background:var(--red); color:#fff; font-family:'Nunito',sans-serif; font-size:9px; font-weight:800; padding:2px 8px; border-radius:20px; letter-spacing:.4px; text-transform:uppercase; }
.ann-render-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.ann-render-cat { font-family:'Nunito',sans-serif; font-size:10px; font-weight:800; padding:3px 9px; border-radius:20px; letter-spacing:.3px; }
.ann-render-time { font-size:11px; color:var(--muted); }
.ann-render-title { font-family:'Nunito',sans-serif; font-size:14px; font-weight:800; color:var(--text); margin-bottom:4px; }
.ann-render-body { font-size:13px; color:var(--text2); line-height:1.5; }

/* Edit mode */
.ann-edit-area { display:none; margin-top:12px; padding-top:12px; border-top:1px solid var(--border); }
.ann-edit-area.open { display:block; }
.ann-edit-title { width:100%; background:var(--warm2); border:1.5px solid var(--border); border-radius:8px; padding:9px 12px; font-family:'Nunito',sans-serif; font-size:14px; font-weight:700; color:var(--text); outline:none; margin-bottom:8px; }
.ann-edit-body  { width:100%; background:var(--warm2); border:1.5px solid var(--border); border-radius:8px; padding:9px 12px; font-family:'Nunito Sans',sans-serif; font-size:13px; color:var(--text); outline:none; resize:none; height:72px; line-height:1.5; }
.ann-edit-title:focus, .ann-edit-body:focus { border-color:var(--blue); background:var(--card); }

/* Tenant dismiss button */
.ann-dismiss-btn { margin-top:8px; padding-top:8px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; }
.ann-dismiss-btn button { background:none; border:none; font-family:'Nunito',sans-serif; font-size:11px; font-weight:700; color:var(--muted2); cursor:pointer; display:flex; align-items:center; gap:4px; padding:2px 0; }
.rc-name { font-family:'Nunito',sans-serif; font-size:16px; font-weight:900; color:var(--text); margin-bottom:3px; }
.rc-sub  { font-size:13px; color:var(--muted); }
.rc-sub2 { font-size:12px; color:var(--muted); }
.rc-right { display:flex; flex-direction:column; align-items:flex-end; gap:8px; }
.vc-name { font-family:'Nunito',sans-serif; font-size:14px; font-weight:800; margin-bottom:2px; }
.vc-meta { font-size:13px; color:var(--muted); margin-bottom:6px; }
.reply-block { margin-top:10px; background:var(--blueLt); border-left:3px solid var(--blue); border-radius:0 8px 8px 0; padding:10px 12px; }
.reply-block-lbl { font-family:'Nunito',sans-serif; font-size:10px; font-weight:800; color:var(--blue); letter-spacing:.5px; text-transform:uppercase; margin-bottom:4px; }
.reply-block-txt { font-size:13px; color:var(--text2); line-height:1.5; }
.mreq-body { flex:1; }
.mreq-time { font-size:11px; color:var(--muted); margin-left:6px; }

/* Static button patterns used across multiple screens */
.btn-navy-cta { background:var(--navy);color:#fff;border:none;border-radius:12px;padding:12px 24px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;cursor:pointer; display:inline-flex;align-items:center;gap:8px; }
.btn-close-sheet { width:100%;margin-top:16px;padding:13px;background:#F5F3EF;border:none;border-radius:12px;font-family:'Nunito',sans-serif;font-size:14px;font-weight:800;color:#6B7280;cursor:pointer; }

/* Clean section header for listing editor — Phosphor icon + divider, no emoji */
.editor-sec-hdr {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: var(--navy);
  letter-spacing: .5px;
  text-transform: uppercase;
  margin-bottom: 14px;
  margin-top: 24px;
  padding-bottom: 9px;
  border-bottom: 1.5px solid var(--border);
}
.editor-sec-hdr:first-child { margin-top: 0; }
.editor-sec-hdr i { font-size: 15px; color: var(--blue); flex-shrink: 0; }

/* Inquiry detail hero avatar — photo version */
.inq-hero-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; display:block; }

/* Photo consent toggle row */
.photo-consent-row {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.15);
  border-radius: var(--r);
  padding: 12px 14px;
  margin-top: 10px;
  cursor: pointer;
}
.photo-consent-row i { font-size: 18px; color: var(--blue); flex-shrink: 0; }
.photo-consent-txt { flex: 1; font-size: 12px; color: var(--text2); line-height: 1.4; }
.photo-consent-txt strong { font-family: 'Nunito', sans-serif; font-weight: 800; color: var(--text); display: block; margin-bottom: 1px; font-size: 13px; }
/* ═══════════════════════════════════════
   MESSAGING THREAD
═══════════════════════════════════════ */
.thread-wrap { display:flex; flex-direction:column; flex:1; overflow:hidden; }
.thread-header {
  background: var(--navy);
  padding: 13px 16px 14px;
  display: flex; align-items: center; gap: 12px; flex-shrink: 0;
}
.thread-house-name { font-family:'Nunito',sans-serif; font-size:15px; font-weight:800; color:#fff; flex:1; }
.thread-house-sub  { font-size:11px; color:rgba(255,255,255,.55); margin-top:1px; }
.thread-scroll { flex:1; overflow-y:auto; padding:14px 14px 0; -webkit-overflow-scrolling:touch; }
.thread-scroll::-webkit-scrollbar { display:none; }

.msg-row { display:flex; margin-bottom:12px; gap:8px; }
.msg-row.from-me  { flex-direction:row-reverse; }
.msg-bubble {
  max-width: 78%;
  padding: 10px 13px;
  border-radius: 16px;
  font-size: 14px;
  line-height: 1.5;
  color: var(--text);
}
.msg-row.from-them .msg-bubble {
  background: var(--card);
  border: 1px solid var(--border);
  border-top-left-radius: 4px;
  box-shadow: var(--sh-xs);
}
.msg-row.from-me .msg-bubble {
  background: var(--navy);
  color: #fff;
  border-top-right-radius: 4px;
}
.msg-time { font-size: 10px; color: var(--muted2); align-self: flex-end; margin-bottom: 2px; flex-shrink: 0; }
.msg-sender { font-family:'Nunito',sans-serif; font-size:10px; font-weight:800; color:var(--muted); margin-bottom:3px; }

.thread-input-bar {
  background: var(--warm);
  border-top: 1px solid var(--border);
  padding: 10px 14px 14px;
  display: flex; gap: 8px; align-items: flex-end; flex-shrink: 0;
}
.thread-inp {
  flex: 1;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 10px 14px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  outline: none;
  resize: none;
  max-height: 100px;
  min-height: 42px;
  transition: border-color .2s;
}
.thread-inp:focus { border-color: var(--blue); }
.thread-send-btn {
  width: 42px; height: 42px;
  background: var(--blue);
  border: none; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
  color: #fff; font-size: 18px;
  transition: background .15s, transform .12s;
}
.thread-send-btn:active { transform: scale(.92); background: var(--blue2); }
.thread-send-btn:disabled { background: var(--muted2); cursor: default; }

/* Last active indicator on listing cards */
.lcard-active { display:inline-flex; align-items:center; gap:4px; font-size:11px; color:var(--muted); font-weight:600; }
.lcard-active-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.lcard-active-dot.recent { background:var(--teal2); }
.lcard-active-dot.today  { background:var(--teal2); animation:pulse-dot 1.8s ease-in-out infinite; }
.lcard-active-dot.old    { background:var(--muted2); }

/* ── PERSISTENT CTA BAR ─────────────────────────────
   Sits between .scroll and .bnav (or at screen bottom).
   Buttons never scroll away — always in thumb reach.
──────────────────────────────────────────────────── */
.cta-bar {
  display: flex;
  gap: 10px;
  padding: 12px 16px 16px;
  flex-shrink: 0;
  background: var(--warm);
  border-top: 1px solid var(--border);
  box-shadow: 0 -4px 20px rgba(11,31,58,.07);
}
.cta-bar .btn, .cta-bar button {
  font-size: 15px;
  padding: 14px 18px;
  border-radius: 12px;
}
.cta-bar-solo { padding: 12px 16px 16px; flex-shrink:0; background:var(--warm); border-top:1px solid var(--border); box-shadow:0 -4px 20px rgba(11,31,58,.07); }
.match-badge { display:inline-flex; align-items:center; gap:4px; font-family:'Nunito',sans-serif; font-size:11px; font-weight:800; padding:3px 9px; border-radius:20px; margin-top:5px; }
.match-great   { background:var(--greenBg); color:var(--green); }
.match-good    { background:var(--blueLt);  color:var(--blue);  }
.match-partial { background:var(--amberBg); color:var(--amber); }
.match-low     { background:var(--warm2);   color:var(--muted); border:1px solid var(--border); }

/* ═══════════════════════════════════════
   ADMIN PANEL STYLES
═══════════════════════════════════════ */
.admin-topbar {
  background:#1a1a2e; padding:13px 16px 14px;
  display:flex; align-items:center; gap:12px; flex-shrink:0;
}
.admin-topbar-title { font-family:'Nunito',sans-serif; font-size:16px; font-weight:800; color:#fff; flex:1; }
.admin-topbar-badge {
  background:rgba(255,107,107,.2); border:1px solid rgba(255,107,107,.4);
  color:#ff6b6b; font-family:'Nunito',sans-serif; font-size:10px; font-weight:800;
  padding:3px 8px; border-radius:20px; letter-spacing:.3px;
}
.admin-bnav {
  flex-shrink:0; width:100%; background:#1a1a2e;
  border-top:1px solid rgba(255,255,255,.08);
  display:flex; padding:6px 0 env(safe-area-inset-bottom,10px);
}
.admin-ni { flex:1; display:flex; flex-direction:column; align-items:center; gap:3px; padding:6px 0; cursor:pointer; transition:opacity .15s; position:relative; }
.admin-ni:active { opacity:.6; }
.admin-ni-ic { font-size:20px; line-height:1; color:rgba(255,255,255,.35); transition:color .2s; }
.admin-ni-lb { font-family:'Nunito',sans-serif; font-size:11px; font-weight:700; color:rgba(255,255,255,.35); letter-spacing:.2px; transition:color .2s; }
.admin-ni.on .admin-ni-ic,.admin-ni.on .admin-ni-lb { color:#ff6b6b; }
.admin-ni.on::after { content:''; position:absolute; top:0; left:50%; transform:translateX(-50%); width:20px; height:2px; background:#ff6b6b; border-radius:0 0 2px 2px; }
.a-stat-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
.a-stat { background:var(--card); border:1px solid var(--border); border-radius:var(--r-lg); padding:14px 15px; box-shadow:var(--sh-xs); }
.a-stat-val { font-family:'Nunito',sans-serif; font-size:26px; font-weight:900; color:var(--text); margin-bottom:2px; }
.a-stat-lbl { font-size:11px; color:var(--muted); font-weight:600; }
.a-stat-sub { font-size:10px; color:var(--muted2); margin-top:2px; }
.a-stat.accent-blue  { border-color:rgba(21,88,204,.25);  background:var(--blueLt); }
.a-stat.accent-green { border-color:rgba(22,101,52,.2);   background:var(--greenBg); }
.a-stat.accent-amber { border-color:rgba(180,83,9,.2);    background:var(--amberBg); }
.a-stat.accent-red   { border-color:rgba(192,57,43,.2);   background:var(--redBg); }
.a-activity-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid var(--border); }
.a-activity-item:last-child { border-bottom:none; }
.a-activity-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; margin-top:4px; }
.a-activity-txt { font-size:12px; color:var(--text2); line-height:1.4; flex:1; }
.a-activity-txt strong { font-family:'Nunito',sans-serif; font-weight:800; color:var(--text); }
.a-activity-time { font-size:10px; color:var(--muted2); flex-shrink:0; }
.a-row { background:var(--card); border:1px solid var(--border); border-radius:var(--r-lg); padding:13px 14px; margin-bottom:8px; box-shadow:var(--sh-xs); }
.a-row-top { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:6px; }
.a-row-name { font-family:'Nunito',sans-serif; font-size:14px; font-weight:800; color:var(--text); }
.a-row-sub  { font-size:12px; color:var(--muted); margin-top:1px; }
.a-row-actions { display:flex; gap:6px; flex-wrap:wrap; margin-top:8px; }
.a-btn { font-family:'Nunito',sans-serif; font-size:11px; font-weight:800; padding:5px 11px; border-radius:6px; border:none; cursor:pointer; display:inline-flex; align-items:center; gap:4px; transition:all .15s; }
.a-btn:active { transform:scale(.96); }
.a-btn-verify  { background:var(--greenBg); color:var(--green); }
.a-btn-suspend { background:var(--redBg);   color:var(--red);   }
.a-btn-restore { background:var(--blueLt);  color:var(--blue);  }
.a-btn-edit    { background:var(--warm2);   color:var(--navy);  border:1px solid var(--border); }
.a-btn-view    { background:var(--warm2);   color:var(--navy);  border:1px solid var(--border); }
.a-btn-flag    { background:var(--amberBg); color:var(--amber); }
.a-btn-reset   { background:var(--purpleBg);color:var(--purple);}
.a-pill { display:inline-flex; align-items:center; gap:4px; font-family:'Nunito',sans-serif; font-size:10px; font-weight:800; padding:3px 9px; border-radius:20px; letter-spacing:.2px; }
.a-pill-active    { background:var(--greenBg); color:var(--green); }
.a-pill-pending   { background:var(--amberBg); color:var(--amber); }
.a-pill-suspended { background:var(--redBg);   color:var(--red);   }
.a-pill-verified  { background:#EFF6FF; color:#1558CC; }
.a-pill-self      { background:var(--warm2); color:var(--muted); border:1px solid var(--border); }
.a-section { padding:14px 14px 0; }
.a-section-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
.a-bar-row { margin-bottom:10px; }
.a-bar-label { display:flex; justify-content:space-between; font-size:12px; color:var(--text2); margin-bottom:4px; font-weight:600; }
.a-bar-track { height:8px; background:var(--warm2); border-radius:4px; overflow:hidden; }
.a-bar-fill  { height:100%; border-radius:4px; transition:width .5s ease; }
.admin-login-wrap { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px 28px; background:#1a1a2e; }
.admin-pin-row { display:flex; gap:10px; margin:20px 0; }
.admin-pin-dot { width:14px; height:14px; border-radius:50%; background:rgba(255,255,255,.15); border:2px solid rgba(255,255,255,.25); transition:all .2s; }
.admin-pin-dot.filled { background:#ff6b6b; border-color:#ff6b6b; }
.admin-keypad { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; width:100%; max-width:260px; }
.admin-key { background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:var(--r-lg); padding:16px 8px; text-align:center; font-family:'Nunito',sans-serif; font-size:20px; font-weight:800; color:#fff; cursor:pointer; transition:all .15s; user-select:none; }
.admin-key:active { background:rgba(255,107,107,.25); border-color:#ff6b6b; transform:scale(.94); }
.admin-key-sub { font-size:8px; color:rgba(255,255,255,.35); letter-spacing:.5px; display:block; margin-top:1px; }
.admin-key.del { color:rgba(255,255,255,.5); font-size:22px; }
.admin-key.empty { background:transparent; border:none; cursor:default; }
.maintenance-overlay { position:absolute; inset:0; background:#1a1a2e; display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:9999; padding:32px; }

/* ═══════════════════════════════════════════════════════════
   ADMIN DARK THEME — applies to all screens with id="a-*"
   Overrides light-mode vars with dark equivalents so every
   admin screen is consistently dark without touching JS.
═══════════════════════════════════════════════════════════ */
#a-home, #a-listings, #a-registry, #a-inquiries,
#a-maintenance, #a-financials, #a-announcements,
#a-logs, #a-settings {
  background: #0d0d1a;
}

/* Scroll containers */
#a-home .scroll, #a-listings .scroll, #a-registry .scroll,
#a-inquiries .scroll, #a-maintenance .scroll,
#a-financials .scroll, #a-announcements .scroll,
#a-logs .scroll, #a-settings .scroll {
  background: #0d0d1a;
}

/* Cards, rows, stat boxes — override var(--card) */
#a-home .card, #a-listings .card, #a-registry .card,
#a-inquiries .card, #a-maintenance .card,
#a-financials .card, #a-announcements .card,
#a-settings .card,
[id^="a-"] .a-stat,
[id^="a-"] .a-row,
[id^="a-"] .card-p,
[id^="a-"] .callout {
  background: #1a1a2e !important;
  border-color: rgba(255,255,255,.08) !important;
  box-shadow: 0 2px 8px rgba(0,0,0,.4) !important;
}

/* Text */
[id^="a-"] .a-stat-val,
[id^="a-"] .a-row-name,
[id^="a-"] .title-md,
[id^="a-"] .slbl,
[id^="a-"] .lbl,
[id^="a-"] .card-p strong {
  color: #fff !important;
}
[id^="a-"] .a-stat-lbl,
[id^="a-"] .a-stat-sub,
[id^="a-"] .a-row-sub,
[id^="a-"] .a-activity-txt,
[id^="a-"] .callout-txt {
  color: rgba(255,255,255,.55) !important;
}

/* Inputs, selects, textareas */
[id^="a-"] .inp,
[id^="a-"] .sel,
[id^="a-"] .ta {
  background: #12122a !important;
  border-color: rgba(255,255,255,.12) !important;
  color: #fff !important;
}
[id^="a-"] .inp::placeholder,
[id^="a-"] .ta::placeholder { color: rgba(255,255,255,.3) !important; }
[id^="a-"] .inp:focus,
[id^="a-"] .sel:focus,
[id^="a-"] .ta:focus {
  border-color: #ff6b6b !important;
  box-shadow: 0 0 0 3px rgba(255,107,107,.12) !important;
}

/* Action buttons — dark-friendly versions */
[id^="a-"] .a-btn-edit,
[id^="a-"] .a-btn-view {
  background: rgba(255,255,255,.08) !important;
  color: rgba(255,255,255,.8) !important;
  border-color: rgba(255,255,255,.12) !important;
}
[id^="a-"] .a-btn-verify  { background: rgba(74,222,128,.15) !important; color: #4ade80 !important; }
[id^="a-"] .a-btn-suspend { background: rgba(248,113,113,.15) !important; color: #f87171 !important; }
[id^="a-"] .a-btn-restore { background: rgba(96,165,250,.15) !important; color: #60a5fa !important; }
[id^="a-"] .a-btn-flag    { background: rgba(251,191,36,.15)  !important; color: #fbbf24 !important; }
[id^="a-"] .a-btn-reset   { background: rgba(167,139,250,.15) !important; color: #a78bfa !important; }

/* Pills */
[id^="a-"] .a-pill-active    { background: rgba(74,222,128,.15) !important; color: #4ade80 !important; }
[id^="a-"] .a-pill-pending   { background: rgba(251,191,36,.15) !important; color: #fbbf24 !important; }
[id^="a-"] .a-pill-suspended { background: rgba(248,113,113,.15) !important; color: #f87171 !important; }
[id^="a-"] .a-pill-verified  { background: rgba(96,165,250,.15) !important; color: #60a5fa !important; }
[id^="a-"] .a-pill-self      { background: rgba(255,255,255,.08) !important; color: rgba(255,255,255,.5) !important; border-color: rgba(255,255,255,.1) !important; }

/* Stat accents */
[id^="a-"] .a-stat.accent-blue  { background: rgba(96,165,250,.1)  !important; border-color: rgba(96,165,250,.25)  !important; }
[id^="a-"] .a-stat.accent-green { background: rgba(74,222,128,.1)  !important; border-color: rgba(74,222,128,.25)  !important; }
[id^="a-"] .a-stat.accent-amber { background: rgba(251,191,36,.1)  !important; border-color: rgba(251,191,36,.25)  !important; }
[id^="a-"] .a-stat.accent-red   { background: rgba(248,113,113,.1) !important; border-color: rgba(248,113,113,.25) !important; }

/* Bar charts */
[id^="a-"] .a-bar-track { background: rgba(255,255,255,.08) !important; }
[id^="a-"] .a-bar-label { color: rgba(255,255,255,.55) !important; }

/* Activity items */
[id^="a-"] .a-activity-item { border-color: rgba(255,255,255,.07) !important; }
[id^="a-"] .a-activity-txt strong { color: #fff !important; }
[id^="a-"] .a-activity-time { color: rgba(255,255,255,.3) !important; }

/* Section headers */
[id^="a-"] .a-section-hdr .slbl,
[id^="a-"] .a-section .slbl { color: rgba(255,255,255,.4) !important; }

/* Horizontal rules and dividers */
[id^="a-"] hr,
[id^="a-"] [style*="border-top:1px solid var(--border)"],
[id^="a-"] [style*="border-bottom:1px solid var(--border)"] {
  border-color: rgba(255,255,255,.07) !important;
}

/* Filter row chips on admin screens */
[id^="a-"] .chip {
  background: rgba(255,255,255,.06) !important;
  border-color: rgba(255,255,255,.12) !important;
  color: rgba(255,255,255,.55) !important;
}
[id^="a-"] .chip.on {
  background: rgba(255,107,107,.2) !important;
  border-color: #ff6b6b !important;
  color: #ff6b6b !important;
}

/* Settings-specific: maint status bar, warm2 backgrounds */
[id^="a-"] [style*="background:var(--warm2)"],
[id^="a-"] [style*="background:var(--warm)"] {
  background: rgba(255,255,255,.05) !important;
}
[id^="a-"] [style*="color:var(--muted)"] { color: rgba(255,255,255,.45) !important; }
[id^="a-"] [style*="color:var(--text)"]  { color: rgba(255,255,255,.9) !important; }
[id^="a-"] [style*="color:var(--text2)"] { color: rgba(255,255,255,.65) !important; }

