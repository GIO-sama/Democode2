function postPlatformAnn() {
  const type=document.getElementById('ap-ann-type').value;
  const title=document.getElementById('ap-ann-title').value.trim();
  const body=document.getElementById('ap-ann-body').value.trim();
  if (!title||!body) { showToast('Fill in title and message'); return; }
  if (!state.platformAnnouncements) state.platformAnnouncements=[];
  state.platformAnnouncements.unshift({id:state.nextId++,type,title,body,ts:Date.now(),active:true});
  save();
  document.getElementById('ap-ann-title').value='';
  document.getElementById('ap-ann-body').value='';
  renderPlatformAnns();
  renderPlatformBanner();
  showToast('<i class="ph ph-broadcast"></i> Broadcast sent to all users');
  adminLog(`Platform announcement: "${title}"`);
}
function renderPlatformAnns() {
  const list=document.getElementById('ap-ann-list');
  if (!list) return;
  const anns=state.platformAnnouncements||[];
  if (!anns.length) { list.innerHTML='<div style="text-align:center;padding:24px;color:var(--muted);font-size:13px;">No platform announcements yet.</div>'; return; }
  const typeColors={info:'var(--blue)',warning:'var(--amber)',maintenance:'var(--red)',feature:'var(--teal)'};
  list.innerHTML=anns.map(a=>`<div class="a-row">
    <div class="a-row-top"><div><div class="a-row-name">${a.title}</div><div class="a-row-sub" style="color:${typeColors[a.type]||'var(--blue)'};font-weight:700;text-transform:capitalize;">${a.type} · ${relTime(a.ts)}</div></div>
    <span class="a-pill ${a.active?'a-pill-active':'a-pill-suspended'}">${a.active?'Live':'Hidden'}</span></div>
    <div style="font-size:13px;color:var(--text2);margin-bottom:8px;">${a.body}</div>
    <div class="a-row-actions">
      <button class="a-btn ${a.active?'a-btn-suspend':'a-btn-restore'}" onclick="togglePlatformAnn(${a.id})">${a.active?'Hide':'Show'}</button>
      <button class="a-btn a-btn-edit" onclick="deletePlatformAnn(${a.id})"><i class="ph ph-trash"></i> Delete</button>
    </div>
  </div>`).join('');
}
function togglePlatformAnn(id) {
  const a=(state.platformAnnouncements||[]).find(x=>x.id===id);
  if (a) { a.active=!a.active; save(); renderPlatformAnns(); renderPlatformBanner(); }
}
function deletePlatformAnn(id) {
  state.platformAnnouncements=(state.platformAnnouncements||[]).filter(x=>x.id!==id);
  save(); renderPlatformAnns(); renderPlatformBanner(); showToast('Deleted');
}
function renderPlatformBanner() {
  const existing=document.getElementById('platform-ann-banner');
  if (existing) existing.remove();
  const active=(state.platformAnnouncements||[]).filter(a=>a.active);
  if (!active.length) return;
  const a=active[0];
  const tc={info:'var(--blue)',warning:'var(--amber)',maintenance:'var(--red)',feature:'var(--teal)'};
  const banner=document.createElement('div');
  banner.id='platform-ann-banner';
  banner.style.cssText=`background:${tc[a.type]||'var(--blue)'};padding:10px 16px;display:flex;align-items:center;gap:10px;flex-shrink:0;`;
  banner.innerHTML=`<i class="ph ph-megaphone" style="font-size:16px;color:#fff;flex-shrink:0;"></i><div style="flex:1;font-size:12px;color:#fff;line-height:1.4;"><strong>${a.title}</strong> — ${a.body}</div><div onclick="this.closest('#platform-ann-banner').remove()" style="color:rgba(255,255,255,.7);font-size:18px;cursor:pointer;">×</div>`;
