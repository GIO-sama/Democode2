  const room = document.getElementById('ic-room-display').textContent;
  showToast('Code copied: ' + code);
  closeInviteModal();
}

function copyCode(code, name) {
  showToast(`✓ Code ni ${name} — ${code} — nakopya!`);
}

// ════════════════════════════════════════
// QR CODE GENERATION
// ════════════════════════════════════════
function renderQRCode() {
  const container = document.getElementById('qr-code-display');
  if(!container) return;
  container.innerHTML = '';
  const house = state.houses.find(h => h.id === state.currentHouseId);
  if(document.getElementById('qr-house-name'))
    document.getElementById('qr-house-name').textContent = house?.name || 'Boarding House';
  try {
    new QRCode(container, {
      text: `buhayboarding://register?house=${state.currentHouseId}&name=${encodeURIComponent(house?.name||'')}`,
      width: 200, height: 200,
      colorDark: '#0D2B45', colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.H
    });
  } catch(e) {
    container.innerHTML = `<div style="width:200px;height:200px;background:var(--warm);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);text-align:center;padding:16px">QR Code para sa<br><strong>${house?.name}</strong></div>`;
  }
}

// ════════════════════════════════════════
// TENANT HOME — ROOM INFO
// ════════════════════════════════════════
function renderTenantHome() {
  // Get tenant profile — use registered profile or default
  const profile = state.tenantProfile || {
    name: 'Ana Reyes', room: 'R1', roomLabel: 'Room 1',
    rent: 1500, houseId: 1, houseName: 'Dela Cruz Boarding House',
    houseAddr: 'Purok 3, Burauen', paymentStatus: 'paid'
  };
  // Update header
  const nameEl = document.getElementById('t-tenant-name');
  if(nameEl) nameEl.textContent = profile.name;
  const houseNameEl = document.getElementById('t-house-name');
  if(houseNameEl) houseNameEl.textContent = profile.houseName;
  const houseAddrEl = document.getElementById('t-house-addr');
  if(houseAddrEl) houseAddrEl.textContent = `${profile.houseAddr} • ${profile.roomLabel || profile.room}`;
  // Room card
  const roomLbl = document.getElementById('t-room-label');
  if(roomLbl) roomLbl.textContent = profile.roomLabel || profile.room;
  const roomHouse = document.getElementById('t-room-house');
  if(roomHouse) roomHouse.textContent = profile.houseName;
  const roomRent = document.getElementById('t-room-rent');
  if(roomRent) roomRent.textContent = '₱' + (profile.rent||0).toLocaleString();
  const payStatus = document.getElementById('t-payment-status');
  if(payStatus) {
    if(profile.paymentStatus === 'paid') {
      payStatus.textContent = '✓ Bayad na';
      payStatus.style.background = 'rgba(255,255,255,.2)';
    } else {
      payStatus.textContent = '⏳ Hindi pa bayad';
      payStatus.style.background = 'rgba(255,200,0,.25)';
    }
  }
  // Announcements
  const newCount = state.announcements.filter(a=>a.isNew).length;
  const badge = document.getElementById('t-ann-badge');
  if(badge) badge.textContent = newCount > 0 ? newCount + ' bago' : 'Lahat';
  const list = document.getElementById('t-ann-list');
  const emptyEl = document.getElementById('t-ann-empty');
  if(!state.announcements.length) {
    if(list) list.innerHTML = '';
    if(emptyEl) emptyEl.classList.remove('hidden');
    return;
  }
  if(emptyEl) emptyEl.classList.add('hidden');
  const catMap = {reminder:{ic:'💵',bg:'var(--amberBg)',c:'var(--amber)'},info:{ic:'ℹ️',bg:'var(--blueLt,#EDF4FC)',c:'var(--blue)'},emergency:{ic:'🚨',bg:'var(--redBg)',c:'var(--red)'},activity:{ic:'🎉',bg:'var(--greenBg)',c:'var(--green)'}};
  if(list) list.innerHTML = state.announcements.map(a => {
    const cat = catMap[a.cat]||catMap.info;
    return `<div class="ann-card" onclick="markAnnRead(${a.id})">
      <div class="ann-hdr">
        <div class="ann-ic" style="background:${cat.bg};">${cat.ic}</div>
        <div class="ann-title">${a.title}</div>
        ${a.isNew ? '<div class="new-dot"></div>' : ''}
      </div>
      <div class="ann-body">${a.body}</div>
      <div class="ann-time">${a.time}</div>
    </div>`;
  }).join('');
}

function markAnnRead(id) {
  const ann = state.announcements.find(a=>a.id===id);
  if(ann) { ann.isNew = false; save(); renderTenantHome(); }
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════
renderHouses();
</script>
