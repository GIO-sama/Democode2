// Snapshots
const SNAP_ICONS = {
  'Bedroom':'ph-bed','Bathroom':'ph-shower','Window View':'ph-frame-corners',
  'Kitchen':'ph-cooking-pot','Laundry':'ph-t-shirt','Entrance':'ph-door',
  'Study Area':'ph-books','WiFi Router':'ph-wifi','WiFi':'ph-wifi',
  'Garden':'ph-tree','Private CR':'ph-shower','Common Area':'ph-house',
  'Photo':'ph-camera','Window':'ph-frame-corners',
};

function snapIcon(label) {
  const cls = SNAP_ICONS[label] || 'ph-image';
  return `<i class="ph ${cls}" style="font-size:24px;color:var(--muted);"></i>`;
}

let _snapUploadIdx = null; // which slot is being uploaded to

function renderBhlSnapGrid() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  const grid = document.getElementById('bhl-snap-grid');
  if(!grid) return;
  const snaps = h.snapshots || [];
  const gradStart = h.gradient.match(/#[0-9A-Fa-f]{6}/)?.[0] || '#1462A8';
  grid.innerHTML = snaps.map((s, i) => {
    if (s.img) {
      // Real uploaded photo
      return `<div class="snap-slot filled" style="padding:0;overflow:hidden;cursor:pointer;" onclick="triggerSnapUpload(${i})">
        <span class="snap-slot-del" onclick="event.stopPropagation();deleteSnap(${i})">×</span>
        <img src="${s.img}" alt="${s.label}" style="width:100%;height:100%;object-fit:cover;display:block;">
        <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,.45);padding:3px 6px;">
          <span class="snap-slot-label" style="color:#fff;">${s.label}</span>
        </div>
      </div>`;
    }
    // Icon placeholder — tap to upload
    return `<div class="snap-slot filled" style="background:${gradStart}18;border-color:${gradStart}44;cursor:pointer;" onclick="triggerSnapUpload(${i})">
      <span class="snap-slot-del" onclick="event.stopPropagation();deleteSnap(${i})">×</span>
      <span class="snap-slot-emoji">${snapIcon(s.label)}</span>
      <span class="snap-slot-label">${s.label}</span>
      <div style="position:absolute;bottom:4px;left:0;right:0;text-align:center;">
        <i class="ph ph-camera-plus" style="font-size:12px;color:var(--muted2);"></i>
      </div>
    </div>`;
  }).join('');
}

function triggerSnapUpload(idx) {
  _snapUploadIdx = idx;
  const inp = document.getElementById('bhl-photo-file');
  if (inp) { inp.value = ''; inp.click(); }
}

function handleSnapPhotoUpload(event) {
  const file = event.target.files[0];
  if (!file || _snapUploadIdx === null) return;
  // Track upload
  if (!state.uploadLog) state.uploadLog = [];
  const h0 = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  state.uploadLog.unshift({
    id: state.nextId++, type: 'listing_photo',
    user: profiles.landlord?.name || 'Landlord',
    house: h0?.name || '—',
    houseId: h0?.id || 1,
    filename: file.name,
    size: (file.size/1024).toFixed(1)+'KB',
    ts: Date.now()
  });
  adminLog(`Photo uploaded: ${file.name} (${(file.size/1024).toFixed(1)}KB) for ${h0?.name||'listing'}`);
  const reader = new FileReader();
  reader.onload = e => {
    const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
    if (h.snapshots && h.snapshots[_snapUploadIdx]) {
      h.snapshots[_snapUploadIdx].img = e.target.result;
      renderBhlSnapGrid();
      showToast('<i class="ph ph-check-circle"></i> Photo uploaded');
    }
    _snapUploadIdx = null;
  };
  reader.readAsDataURL(file);
}

function addSnapSlot() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  if(!h.snapshots) h.snapshots = [];
  if(h.snapshots.length >= 9) { showToast('Maximum 9 photo slots'); return; }
  h.snapshots.push({ label:'Photo' });
  renderBhlSnapGrid();
}

function addPresetSnap(ic_unused, label) {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  if(!h.snapshots) h.snapshots = [];
  if(h.snapshots.length >= 9) { showToast('Maximum 9 photo slots'); return; }
  if(h.snapshots.find(s => s.label === label)) { showToast(label + ' already added'); return; }
  h.snapshots.push({ label });
  renderBhlSnapGrid();
}

function deleteSnap(idx) {
  (state.houses.find(x => x.id === state.currentHouseId) || state.houses[0]).snapshots.splice(idx, 1);
  renderBhlSnapGrid();
}

// Amenity chips
function renderAmenityChips() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  const selectedSet = new Set(h.amenities || []);
  const renderGroup = (containerId, items) => {
    const el = document.getElementById(containerId);
    if(!el) return;
    el.innerHTML = items.map(item => `
      <div class="am-chip ${selectedSet.has(item.label) ? 'on' : ''}"
           onclick="toggleAmenity(this, '${item.label}')">
        <span style="display:inline-flex;align-items:center;">${item.ic}</span> ${item.label}
      </div>`).join('');
  };
  renderGroup('bhl-am-utilities', AMENITY_GROUPS.utilities);
  renderGroup('bhl-am-room',      AMENITY_GROUPS.room);
  renderGroup('bhl-am-location',  AMENITY_GROUPS.location);
  renderGroup('bhl-am-policy',    AMENITY_GROUPS.policy);
}

function toggleAmenity(el, label) {
  el.classList.toggle('on');
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  if(!h.amenities) h.amenities = [];
  if(el.classList.contains('on')) {
    if(!h.amenities.includes(label)) h.amenities.push(label);
  } else {
    h.amenities = h.amenities.filter(a => a !== label);
  }
}

// Save all changes back to state and re-render pins/cards
function saveBhlListing() {
  const h = state.houses.find(x => x.id === state.currentHouseId) || state.houses[0];
  const sv = id => document.getElementById(id)?.value;

  h.name        = sv('bhl-name')    || h.name;
  h.address     = sv('bhl-address') || h.address;
  h.price       = parseInt(sv('bhl-price')) || h.price;
  h.curfew      = sv('bhl-curfew')  || h.curfew;
  h.about       = sv('bhl-about')   || '';
  h.distanceEVSU = parseInt(sv('bhl-devsu')) || h.distanceEVSU;
  h.distanceBCC  = parseInt(sv('bhl-dbcc'))  || h.distanceBCC;
  h.lastActive   = 'Just now'; // landlord is active whenever they edit the listing

  // Save rule toggles
  saveBhlToggle();

  // Rebuild BH pin label in map if already loaded
  try {
    if (bbMap && typeof L !== 'undefined' && bbMarkers[h.id]) {
      const icon = L.divIcon({ className: '', iconSize: [1,1], iconAnchor: [50,54], html: buildPinHTML(h) });
      bbMarkers[h.id].setIcon(icon);
    }
  } catch(e) { /* map not loaded yet — safe to ignore */ }

  save();
  showToast('Listing updated ');
  setTimeout(() => goBack(), 600);
}


