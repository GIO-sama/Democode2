  border: 2px dashed var(--border2);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all .18s;
  background: var(--warm2);
}
.snap-slot:active { transform: scale(.97); }
.snap-slot.filled {
  border-style: solid;
  border-color: transparent;
}
.snap-slot-emoji { font-size: 26px; }
.snap-slot-label {
  font-family: 'Nunito', sans-serif;
  font-size: 9px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .4px;
  text-align: center;
  line-height: 1.2;
  padding: 0 4px;
}
.snap-slot-del {
  position: absolute;
  top: 4px; right: 4px;
  width: 18px; height: 18px;
  background: rgba(11,31,58,.55);
  border-radius: 50%;
  color: #fff;
  font-size: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.snap-slot-add {
  border-style: dashed;
  background: transparent;
}

/* Rules editor list */
.rule-editor-row {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r);
  padding: 11px 14px;
  margin-bottom: 8px;
  box-shadow: var(--sh-xs);
}
.rule-editor-emoji { font-size: 18px; flex-shrink: 0; width: 26px; text-align: center; }
.rule-editor-text { flex: 1; font-size: 13px; color: var(--text); font-weight: 600; }
.rule-editor-del {
  width: 28px; height: 28px;
  background: var(--redBg);
  border: none;
  border-radius: 8px;
  color: var(--red);
  font-size: 14px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.rule-add-row {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}
.rule-add-emoji-pick {
  width: 44px;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  font-size: 18px;
  text-align: center;
  cursor: pointer;
  padding: 10px 4px;
  flex-shrink: 0;
}
.rule-add-inp {
  flex: 1;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  padding: 10px 13px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  outline: none;
}
.rule-add-inp:focus { border-color: var(--blue); }
.rule-add-btn {
  width: 44px;
  background: var(--navy);
  border: none;
  border-radius: var(--r);
  color: #fff;
  font-size: 18px;
  cursor: pointer;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Amenity toggle chips */
.amenity-chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.am-chip {
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 7px 14px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: all .18s;
  user-select: none;
}
.am-chip.on {
  background: var(--navy);
  border-color: var(--navy);
  color: #fff;
}

/* Gradient picker */
.grad-grid {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 16px;
}
.grad-swatch {
  width: 38px; height: 38px;
  border-radius: 10px;
  cursor: pointer;
  border: 3px solid transparent;
  transition: all .18s;
  flex-shrink: 0;
}
.grad-swatch.on { border-color: var(--navy); transform: scale(1.12); }

/* About textarea */
.about-ta {
  width: 100%;
  background: var(--card);
  border: 1.5px solid var(--border);
  border-radius: var(--r);
  padding: 12px 15px;
  font-family: 'Nunito Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  outline: none;
  resize: none;
  height: 100px;
  line-height: 1.55;
  transition: border-color .2s;
  margin-bottom: 4px;
}
.about-ta:focus { border-color: var(--blue); }

/* Section label inside editor */
.editor-sec-lbl {
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: var(--muted);
  letter-spacing: .7px;
  text-transform: uppercase;
  margin-bottom: 10px;
  margin-top: 20px;
}
.editor-sec-lbl:first-child { margin-top: 0; }

/* Updated detail view: about section + custom snapshots */
.d-about {
  padding: 0 16px 12px;
  font-size: 13px;
  color: var(--text2);
  line-height: 1.6;
}
.d-photo-strip {
  display: flex;
  gap: 8px;
  padding: 12px 16px 4px;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}
.d-photo-strip::-webkit-scrollbar { display: none; }
.d-photo-slot {
  min-width: 96px;
  height: 72px;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.d-photo-slot-emoji { font-size: 22px; }
.d-photo-slot-label {
  font-family: 'Nunito', sans-serif;
  font-size: 8px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .4px;
  color: rgba(255,255,255,.85);
  background: rgba(0,0,0,.28);
  padding: 2px 6px;
  border-radius: 4px;
}

/* Sticky save bar in editor */
.bhl-save-bar {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: var(--warm);
  border-top: 1px solid var(--border);
  padding: 12px 16px env(safe-area-inset-bottom, 14px);
  z-index: 20;
}

.leaflet-control-attribution {
  font-size: 9px !important;
  opacity: .7;
}
/* Leaflet zoom control style */
.leaflet-control-zoom a {
  font-family: 'Nunito', sans-serif !important;
  font-weight: 800 !important;
}

/* ── MAP LAYER LEGEND (floating) ── */
.map-legend {
  position: absolute;
  bottom: 14px;
  left: 12px;
  z-index: 40;
  display: flex;
  flex-direction: column;
  gap: 5px;
  pointer-events: none;
}
.map-legend-row {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}
.map-layer-btn {
  background: rgba(255,255,255,.95);
  border: 1.5px solid rgba(11,31,58,.12);
  border-radius: 20px;
  padding: 5px 10px;
  font-family: 'Nunito', sans-serif;
  font-size: 10px;
  font-weight: 800;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 4px;
  box-shadow: 0 2px 8px rgba(11,31,58,.14);
  transition: all .18s;
  pointer-events: all;
  color: var(--muted);
  letter-spacing: .1px;
}
.map-layer-btn.on {
  color: var(--navy);
  border-color: var(--navy);
  background: rgba(255,255,255,1);
}
.map-layer-btn .lb-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* landmark tooltip */
.lm-tooltip {
  background: rgba(11,31,58,.88) !important;
  border: none !important;
  border-radius: 8px !important;
  color: #fff !important;
  font-family: 'Nunito', sans-serif !important;
  font-size: 11px !important;
  font-weight: 700 !important;
  padding: 5px 10px !important;
  box-shadow: 0 3px 10px rgba(0,0,0,.2) !important;
  white-space: nowrap !important;
}
.lm-tooltip::before { display: none !important; }

/* ── MAP BOTTOM SHEET ── */
.map-sheet-overlay {
  position: absolute;
  inset: 0;
  z-index: 50;
  pointer-events: none;
}
.map-sheet-overlay.active { pointer-events: all; }
.map-sheet-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(11,31,58,.18);
  opacity: 0;
  transition: opacity .25s;
}
.map-sheet-overlay.active .map-sheet-backdrop { opacity: 1; }
.map-sheet {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: var(--card);
  border-radius: 20px 20px 0 0;
  box-shadow: 0 -6px 32px rgba(11,31,58,.18);
  transform: translateY(100%);
  transition: transform .3s cubic-bezier(.32,0,.2,1);
  overflow: hidden;
}
.map-sheet-overlay.active .map-sheet {
  transform: translateY(0);
}
.map-sheet-handle {
  width: 36px; height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 12px auto 0;
}
.map-sheet-hero {
  margin: 14px 14px 0;
  border-radius: 14px;
  padding: 16px 16px 14px;
  position: relative;
  overflow: hidden;
}
.map-sheet-name {
  font-family: 'Nunito', sans-serif;
  font-size: 17px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 3px;
}
.map-sheet-addr {
  font-size: 12px;
  color: rgba(255,255,255,.7);
  display: flex;
  align-items: center;
  gap: 4px;
}
.map-sheet-avail {
  position: absolute;
  top: 12px; right: 12px;
  background: rgba(255,255,255,.22);
  border: 1px solid rgba(255,255,255,.35);
  border-radius: 20px;
  padding: 4px 10px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: #fff;
}
.map-sheet-stats {
  display: flex;
  margin: 12px 14px 0;
  background: var(--warm);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
}
.map-sheet-stat {
  flex: 1;
  padding: 11px 8px;
  text-align: center;
  border-right: 1px solid var(--border);
}
.map-sheet-stat:last-child { border-right: none; }
.map-sstat-v {
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 900;
  color: var(--navy);
}
.map-sstat-l {
  font-size: 10px;
  color: var(--muted);
  margin-top: 2px;
  font-weight: 600;
}
.map-sheet-dist {
  display: flex;
  gap: 8px;
  margin: 10px 14px 0;
}
.map-dist-pill {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.12);
  border-radius: 10px;
  padding: 9px 10px;
}
.map-dist-pill.teal {
  background: #F0FDFA;
  border-color: rgba(11,122,106,.12);
}
.map-dist-ic {
  font-size: 18px;
  flex-shrink: 0;
}
.map-dist-v {
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 900;
  color: var(--navy);
}
.map-dist-l {
  font-size: 10px;
  color: var(--muted);
  margin-top: 1px;
}
.map-sheet-actions {
  display: flex;
  gap: 10px;
  margin: 12px 14px 20px;
}

/* ── ENTRY PILL on Discover ── */
.map-entry-pill {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.22);
  border-radius: 20px;
  padding: 5px 11px 5px 9px;
  font-family: 'Nunito', sans-serif;
  font-size: 11px;
  font-weight: 800;
  color: rgba(255,255,255,.8);
  cursor: pointer;
  transition: background .15s;
  letter-spacing: .1px;
  flex-shrink: 0;
}
.map-entry-pill:active { background: rgba(255,255,255,.22); }
.map-entry-pill i { font-size: 13px; }

/* ════════════════════════════════════════════════════
   INQUIRY DETAIL BOTTOM SHEET
════════════════════════════════════════════════════ */
.inq-sheet-overlay {
  position: absolute;
  inset: 0;
  z-index: 200;
  background: rgba(11,31,58,.52);
  backdrop-filter: blur(5px);
  display: flex;
  align-items: flex-end;
}
.inq-sheet-overlay.hidden { display: none !important; }
.inq-sheet {
  width: 100%;
  background: var(--warm);
  border-radius: 24px 24px 0 0;
  padding: 0 0 32px;
  box-shadow: 0 -8px 40px rgba(11,31,58,.22);
  max-height: 90%;
  overflow-y: auto;
  animation: sheetUp .28s cubic-bezier(.32,0,.2,1);
}
@keyframes sheetUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.inq-sheet-handle {
  width: 36px; height: 4px;
  background: var(--border2);
  border-radius: 2px;
  margin: 14px auto 0;
}

/* Hero */
.inq-hero {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 16px 18px 0;
  background: linear-gradient(135deg, var(--navy) 0%, #1558CC 100%);
  border-radius: 16px;
  padding: 16px 16px 16px 16px;
  position: relative;
  overflow: hidden;
}
.inq-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23fff' fill-opacity='.04'%3E%3Ccircle cx='20' cy='20' r='20'/%3E%3C/g%3E%3C/svg%3E") center/40px;
  pointer-events: none;
}
.inq-hero-avatar {
  width: 52px; height: 52px;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
  border: 2px solid rgba(255,255,255,.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px;
  flex-shrink: 0;
}
.inq-hero-info { flex: 1; min-width: 0; }
.inq-hero-name {
  font-family: 'Nunito', sans-serif;
  font-size: 17px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 3px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.inq-hero-school {
  font-size: 12px;
  color: rgba(255,255,255,.65);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.inq-status-badge {
  position: absolute;
  top: 12px; right: 12px;
  font-family: 'Nunito', sans-serif;
  font-size: 10px;
  font-weight: 800;
  letter-spacing: .4px;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 20px;
  background: rgba(255,255,255,.18);
  border: 1px solid rgba(255,255,255,.28);
  color: #fff;
}

/* Meta row */
.inq-meta-row {
  display: flex;
  gap: 8px;
  margin: 12px 18px 0;
}
.inq-meta-pill {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 9px 12px;
  font-size: 12px;
  font-weight: 700;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
}
.inq-meta-pill span {
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Question bubble */
.inq-q-wrap { margin: 12px 18px 0; }
.inq-q-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 7px;
}
.inq-q-bubble {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 14px;
  border-top-left-radius: 4px;
  padding: 13px 15px;
  font-size: 14px;
  line-height: 1.55;
  color: var(--text);
  box-shadow: var(--sh-xs);
}

/* Actions */
.inq-actions-wrap { margin: 16px 18px 0; }
.inq-action-label {
  font-size: 10px;
  font-weight: 800;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 10px;
}
.inq-act-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 8px;
}
.inq-act-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 13px 10px;
  border-radius: 13px;
  border: none;
  cursor: pointer;
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 800;
  transition: transform .12s, box-shadow .12s;
}
.inq-act-btn:active { transform: scale(.97); }
.inq-act-btn i { font-size: 16px; }

/* Button variants */
.inq-act-offer {
  background: linear-gradient(135deg, var(--teal), #0D9480);
  color: #fff;
  box-shadow: 0 4px 14px rgba(11,122,106,.30);
}
.inq-act-visit {
  background: linear-gradient(135deg, #5B21B6, #7C3AED);
  color: #fff;
  box-shadow: 0 4px 14px rgba(91,33,182,.25);
}
.inq-act-replied {
  background: var(--blueLt);
  border: 1.5px solid rgba(21,88,204,.18);
  color: var(--blue);
}
.inq-act-interested {
  background: #F0FDFA;
  border: 1.5px solid rgba(11,122,106,.18);
  color: var(--teal);
}
.inq-act-notfit {
  background: var(--warm2);
  border: 1.5px solid var(--border);
  color: var(--muted);
}
.inq-act-decline {
  background: #FEF2F2;
  border: 1.5px solid rgba(192,57,43,.15);
  color: var(--red);
}

/* Close button */
.inq-close-btn {
  display: block;
  width: calc(100% - 36px);
  margin: 12px 18px 0;
  padding: 13px;
  background: transparent;
  border: 1.5px solid var(--border);
  border-radius: 13px;
  font-family: 'Nunito', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--muted);
  cursor: pointer;
  transition: background .15s;
}
.inq-close-btn:active { background: var(--border); }


/* ── Small action buttons (maintenance, visits) ─────── */
.btn-green-sm {
  background: var(--greenBg, #DCFCE7);
  color: var(--green);
  border: 1.5px solid rgba(22,101,52,.2);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-green-sm:active { transform: scale(.97); }
.btn-red-sm {
  background: #FEF2F2;
  color: var(--red);
  border: 1.5px solid rgba(192,57,43,.18);
  padding: 6px 12px;
  border-radius: 8px;
  font-family: 'Nunito', sans-serif;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transition: all .13s;
}
.btn-red-sm:active { transform: scale(.97); }

/* ─── SAVED / HEART BUTTON ─────────────────── */
.lcard-heart {
  position: absolute;
  top: 10px; right: 10px;
  width: 34px; height: 34px;
  background: rgba(255,255,255,.92);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  border: none;
  font-size: 17px;
  color: var(--muted2);
  box-shadow: 0 2px 8px rgba(11,31,58,.18);
  transition: all .18s;
  z-index: 10;
  flex-shrink: 0;
}
.lcard-heart.saved { color: #E11D48; background: #FFF1F2; }
.lcard-heart:active { transform: scale(.9); }

/* ─── RENDER UTILITY CLASSES ─────────────────────────────────
   Replaces high-frequency inline styles produced by JS render functions.
   Browser caches computed styles for class selectors vs re-parsing
   inline style strings on every innerHTML rebuild.
──────────────────────────────────────────────────────────────── */
.sum-row { display:flex; justify-content:space-between; padding:7px 0; border-bottom:1px solid var(--border); font-size:13px; }
.sum-row:last-child { border-bottom:none; }
.sum-lbl { color:var(--muted); }
.sum-val { font-weight:700; }
.sum-hdr { font-family:'Nunito',sans-serif; font-size:11px; font-weight:800; color:var(--muted); letter-spacing:.8px; text-transform:uppercase; margin-bottom:10px; }
/* ── ANNOUNCEMENT IMPROVEMENTS ────────────────────── */
.ann-render-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:14px 16px; margin-bottom:10px; box-shadow:0 1px 4px rgba(11,31,58,.06); position:relative; }
.ann-render-card.pinned { border-color:var(--red); border-width:1.5px; }
.ann-pin-badge { position:absolute; top:-8px; left:14px; background:var(--red); color:#fff; font-family:'Nunito',sans-serif; font-size:9px; font-weight:800; padding:2px 8px; border-radius:20px; letter-spacing:.4px; text-transform:uppercase; }
.ann-render-hdr { display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
.ann-render-cat { font-family:'Nunito',sans-serif; font-size:10px; font-weight:800; padding:3px 9px; border-radius:20px; letter-spacing:.3px; }
.ann-render-time { font-size:11px; color:var(--muted); }
.ann-render-title { font-family:'Nunito',sans-serif; font-size:14px; font-weight:800; color:var(--text); margin-bottom:4px; }
.ann-render-body { font-size:13px; color:var(--text2); line-height:1.5; }

/* Edit mode */
