function renderHouses() {
  const list = document.getElementById('houses-list');
  const countEl = document.getElementById('houses-count');
  // Only show houses that are self-verified OR admin-verified, not suspended, not brand new pending
  let houses = state.houses.filter(h =>
    h.adminStatus !== 'suspended' &&
    (h.selfVerified || h.adminVerified || h.verified)
  );

  // Sort
  const _distKey = state.school === 'evsu' ? 'distanceEVSU' : 'distanceBCC';
  const _activeOrder = {'Just now':0,'2h ago':1,'5h ago':2,'Today':3,'3 days ago':4,'1 week ago':5};
  if      (state.sort === 'match')  houses = [...houses].sort((a,b) => (computeMatchScore(b)?.score||0) - (computeMatchScore(a)?.score||0));
  else if (state.sort === 'price')  houses = [...houses].sort((a,b) => a.price - b.price);
  else if (state.sort === 'avail')  houses = [...houses].sort((a,b) => availableRooms(b) - availableRooms(a));
  else if (state.sort === 'active') houses = [...houses].sort((a,b) => (_activeOrder[a.lastActive]??99) - (_activeOrder[b.lastActive]??99));
  else                              houses = [...houses].sort((a,b) => a[_distKey] - b[_distKey]);

  // filter
  if(state.filter==='available') houses = houses.filter(h=>availableRooms(h)>0);
  else if(state.filter==='under2k') houses = houses.filter(h=>h.price<2000);
  else if(state.filter==='wifi') houses = houses.filter(h=>h.rules.wifi);
  else if(state.filter==='nocurfew') houses = houses.filter(h=>h.curfew==='No curfew');

  // search — name, address, amenities, price range keywords, curfew
  const q = document.getElementById('srch-inp')?.value?.toLowerCase() || '';
  if (q) {
    houses = houses.filter(h => {
      if (h.name.toLowerCase().includes(q))    return true;
      if (h.address.toLowerCase().includes(q)) return true;
      if ((h.amenities||[]).some(a => a.toLowerCase().includes(q))) return true;
      if (h.about && h.about.toLowerCase().includes(q)) return true;
      if (h.curfew && h.curfew.toLowerCase().includes(q)) return true;
      // Price keyword matching
      if ((q === 'mura' || q === 'cheap' || q === 'budget') && h.price <= 1500) return true;
      const priceMatch = q.match(/\d{3,5}/);
      if (priceMatch && h.price <= parseInt(priceMatch[0])) return true;
      // Rule keywords
      if (q.includes('wifi') && h.rules?.wifi) return true;
      if ((q.includes('no curfew') || q.includes('no curfew')) && h.curfew === 'No curfew') return true;
      if ((q.includes('cooking') || q.includes('lutuin')) && h.rules?.cooking) return true;
      return false;
    });
  }

  const school = state.school==='evsu'?'EVSU':'BCC';

  // FIX 11: Empty state when filter returns 0 results
  if (houses.length === 0) {
    const isSearch = document.getElementById('srch-inp')?.value?.trim();
    countEl.textContent = '0 houses near ' + school;
    const filterLabels = {available:'Available now',under2k:'Under ₱2,000',wifi:'WiFi included',nocurfew:'No curfew'};
    const filterName = filterLabels[state.filter] || '';
    list.innerHTML = `
      <div style="text-align:center;padding:48px 24px 32px;">
        <div style="width:72px;height:72px;background:var(--warm2);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
          <i class="ph ph-house-simple" style="font-size:32px;color:var(--muted2);"></i>
        </div>
        <div style="font-family:'Nunito',sans-serif;font-size:17px;font-weight:900;color:var(--navy);margin-bottom:8px;">
          ${isSearch ? 'No results for "'+isSearch+'"' : 'No houses match this filter'}
        </div>
        <div style="font-size:13px;color:var(--muted);line-height:1.6;margin-bottom:20px;">
          ${isSearch ? 'Try a different search term, or browse all listings.' : `Try a different filter — there are ${state.houses.filter(h=>h.selfVerified||h.adminVerified||h.verified).length} verified houses in Burauen.`}
        </div>
        <button onclick="setFilter('all',null);document.getElementById('srch-inp').value='';renderHouses();"
          class="btn-navy-cta">
          <i class="ph ph-x"></i> Clear Filter — Show All
        </button>
      </div>`;
    return;
  }

  countEl.textContent = houses.length+' house'+(houses.length!==1?'s':'')+' near '+school;

  list.innerHTML = houses.map(h=>{
    const avail = availableRooms(h);
    const isFull = avail===0;
    const hasWaitlist = h.waitlist.length>0;
    const dist = state.school==='evsu'?h.distanceEVSU:h.distanceBCC;
    const tagStr = h.amenities.map(a=>`<span class="tag tg">${a}</span>`).join('');
    const badge = isFull
      ? '<span class="lcard-badge" style="background:var(--red)">Full</span>'
      : h.adminVerified
        ? '<span class="lcard-badge" style="background:linear-gradient(135deg,#B45309,#D97706);"><i class="ph ph-seal-check"></i> BB Certified</span>'
        : h.selfVerified
          ? '<span class="lcard-badge" style="background:rgba(107,114,128,.75);"><i class="ph ph-seal-check"></i> Owner Verified</span>'
          : '<span class="lcard-badge" style="background:var(--teal)"> Verified ' + h.verified + '</span>';
    // Misfire 1 fix: only show waitlist count when >= 3 (below that it signals low demand)
    const rooms = isFull
      ? `<span class="lcard-rooms" style="background:rgba(239,68,68,.85);">${h.waitlist.length >= 3 ? h.waitlist.length + ' on waitlist' : 'Full'}</span>`
      : avail === 1
        ? `<span class="lcard-rooms" style="background:rgba(217,119,6,.9);"><i class="ph ph-warning"></i> Last room!</span>`
        : `<span class="lcard-rooms">${avail} room${avail!==1?'s':''} left</span>`;
    const firstPill = !isFull && h.waitlist.length < 3
      ? `<span style="font-size:10px;font-weight:600;color:rgba(255,255,255,.75);padding:2px 8px;background:rgba(255,255,255,.15);border-radius:20px;">Be first to inquire</span>`
      : '';
    const cta = isFull
      ? `<button class="btn" style="background:var(--amberBg);color:var(--amber);font-size:12px;padding:8px 13px;border-radius:8px;border:none;font-family:'Nunito',sans-serif;font-weight:800;cursor:pointer;"> Join Waitlist</button>`
      : `<button class="btn btn-blue" style="font-size:12px;padding:8px 13px;border-radius:8px">Inquire Now</button>`;
    const isSaved = state.savedHouses.includes(h.id);
    const matchHtml = matchBadgeHtml(h);
    return `
      <div class="lcard" onclick="openHouse(${h.id})">
        <div class="lcard-img" style="background:${h.gradient}">
          <span class="lcard-img-ph"><i class="ph ph-house"></i></span>
          <div style="position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,.35);backdrop-filter:blur(4px);border-radius:6px;padding:3px 8px;display:flex;align-items:center;gap:5px;">
            <i class="ph ph-camera" style="font-size:11px;color:rgba(255,255,255,.7);"></i>
            <span style="font-size:10px;color:rgba(255,255,255,.7);font-family:'Nunito Sans',sans-serif;font-weight:600;">Photos during verification visit</span>
          </div>
          ${badge}${rooms}${firstPill}
          <button class="lcard-heart ${isSaved?'saved':''}" onclick="event.stopPropagation();toggleSaved(${h.id})" id="heart-${h.id}">
            <i class="ph ${isSaved?'ph-heart-fill':'ph-heart'}"></i>
          </button>
        </div>
        <div class="lcard-body">
          <div class="lcard-name">${h.name}</div>
          <div class="lcard-loc"><i class="ph ph-map-pin"></i> ${dist} min walk from ${school} gate</div>
          <div class="lcard-tags">${tagStr}</div>
          ${matchHtml}
          <div class="lcard-foot">
            <div>
              <div class="lcard-price">₱${h.price.toLocaleString()}<span>/mo</span></div>
              ${lastActiveHtml(h.lastActive)}
            </div>
            ${cta}
          </div>
        </div>
      </div>`;
  }).join('');
}


