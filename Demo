// ════════════════════════════════════════
function renderAdminFinancials() {
  const body=document.getElementById('a-financials-body');
  if (!body) return;
  const totalRev  = state.houses.reduce((s,h)=>s+h.rooms.filter(r=>r.status!=='empty').reduce((rs,r)=>rs+r.amount,0),0);
  const totalExp  = state.expenses.reduce((s,e)=>s+Number(e.amount),0);
  const net       = totalRev-totalExp;
  const occ       = Math.round(state.houses.reduce((s,h)=>s+h.rooms.filter(r=>r.status!=='empty').length,0)/Math.max(1,state.houses.reduce((s,h)=>s+h.rooms.length,0))*100);
  const houseRows = state.houses.map(h=>({ name:h.name, rev:h.rooms.filter(r=>r.status!=='empty').reduce((s,r)=>s+r.amount,0), occ:h.rooms.filter(r=>r.status!=='empty').length, total:h.rooms.length })).sort((a,b)=>b.rev-a.rev);
  const maxRev    = houseRows[0]?.rev||1;
  const inqByHouse= state.houses.map(h=>({ name:h.name, count:state.inquiries.filter(i=>i.houseId===h.id).length })).sort((a,b)=>b.count-a.count);
  const maxInq    = inqByHouse[0]?.count||1;

  body.innerHTML = `
    <div class="a-stat-grid" style="margin-bottom:14px;">
      <div class="a-stat accent-green"><div class="a-stat-val">₱${totalRev.toLocaleString()}</div><div class="a-stat-lbl">Est. Monthly Revenue</div></div>
      <div class="a-stat accent-red"><div class="a-stat-val">₱${totalExp.toLocaleString()}</div><div class="a-stat-lbl">Total Expenses</div></div>
      <div class="a-stat ${net>=0?'accent-green':'accent-red'}"><div class="a-stat-val" style="color:${net>=0?'var(--green)':'var(--red)'};">${net>=0?'+':''}₱${net.toLocaleString()}</div><div class="a-stat-lbl">Net (Rev − Exp)</div></div>
      <div class="a-stat accent-blue"><div class="a-stat-val">${occ}%</div><div class="a-stat-lbl">Platform Occupancy</div></div>
    </div>
    <div class="card card-p" style="margin-bottom:14px;">
      <div class="slbl" style="margin-bottom:14px;">Revenue by House</div>
      ${houseRows.map(h=>`<div class="a-bar-row">
        <div class="a-bar-label"><span>${h.name.replace(/ Boarding House| Residence/,'')}</span><span style="font-family:'Nunito',sans-serif;font-weight:800;">₱${h.rev.toLocaleString()} <span style="font-weight:600;color:var(--muted);font-size:11px;">(${h.occ}/${h.total})</span></span></div>
        <div class="a-bar-track"><div class="a-bar-fill" style="width:${Math.round(h.rev/maxRev*100)}%;background:var(--teal);"></div></div>
      </div>`).join('')}
    </div>
    <div class="card card-p" style="margin-bottom:14px;">
      <div class="slbl" style="margin-bottom:14px;">Most Inquired</div>
      ${inqByHouse.map(h=>`<div class="a-bar-row">
        <div class="a-bar-label"><span>${h.name.replace(/ Boarding House| Residence/,'')}</span><span style="font-family:'Nunito',sans-serif;font-weight:800;">${h.count} inquiries</span></div>
        <div class="a-bar-track"><div class="a-bar-fill" style="width:${Math.round(h.count/Math.max(1,maxInq)*100)}%;background:var(--blue);"></div></div>
      </div>`).join('')}
    </div>
    <div class="card card-p">
      <div class="slbl" style="margin-bottom:14px;">Occupancy Rate</div>
      ${houseRows.map(h=>{ const r=Math.round(h.occ/Math.max(1,h.total)*100); return `<div class="a-bar-row">
        <div class="a-bar-label"><span>${h.name.replace(/ Boarding House| Residence/,'')}</span><span style="font-family:'Nunito',sans-serif;font-weight:800;color:${r===100?'var(--red)':r>=75?'var(--amber)':'var(--green)'};">${r}%</span></div>
