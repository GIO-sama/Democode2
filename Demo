function availableRooms(h) {
  return (h.rooms || []).filter(r => r.status === 'empty').length;
}

function save() {
  try {
    // Strip non-serializable available() method from houses before saving
    const housesClean = state.houses.map(({available, ...rest}) => rest);
    localStorage.setItem('bb_state', JSON.stringify({
      inquiries:              state.inquiries,
      announcements:          state.announcements,
      maintenanceRequests:    state.maintenanceRequests,
      expenses:               state.expenses,
      myInquiries:            state.myInquiries,
      myMaintenanceRequests:  state.myMaintenanceRequests,
      nextId:                 state.nextId,
      houses:                 housesClean,
      visits:                 state.visits,
      pendingTenants:         state.pendingTenants,
      tenantProfile:          state.tenantProfile,
      seekerProfile:          state.seekerProfile,
      visitSlots:             state.visitSlots,
    }));
  } catch(e){}
}
function load() {
  try {
    const d = JSON.parse(localStorage.getItem('bb_state'));
    if(d) {
      state.inquiries = d.inquiries || state.inquiries;
      state.announcements = d.announcements || state.announcements;
      state.maintenanceRequests = d.maintenanceRequests || state.maintenanceRequests;
      state.expenses = d.expenses || state.expenses;
      state.myInquiries = d.myInquiries || [];
      state.myMaintenanceRequests = d.myMaintenanceRequests || [];
      state.nextId = d.nextId || 10;
      if(d.houses) {
        d.houses.forEach(dh => {
          const sh = state.houses.find(h=>h.id===dh.id);
          if(sh) { sh.rooms = dh.rooms; sh.waitlist = dh.waitlist; }
        });
      }
    }
  } catch(e){}
}
